<?php

use Drupal\block_content\Entity\BlockContent;
use Drupal\paragraphs\Entity\Paragraph;

/**
 * Implements hook_theme().
 *
 * Defines templates for the ASU Profile entity view modes.
 */
function webspark_webdir_theme($existing, $type, $theme, $path) {
  return [
    // Profile entity template (default / block embed).
    'asu_profile' => [
      'render element' => 'elements',
      'template' => 'asu-profile',
      'path' => $path . '/templates',
    ],
    // Full page view mode template.
    'asu_profile__full' => [
      'render element' => 'elements',
      'template' => 'asu-profile--full',
      'path' => $path . '/templates',
      'base hook' => 'asu_profile',
    ],
    // Grid view mode template.
    'asu_profile__grid' => [
      'render element' => 'elements',
      'template' => 'asu-profile--grid',
      'path' => $path . '/templates',
      'base hook' => 'asu_profile',
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_HOOK().
 */
function webspark_webdir_theme_suggestions_asu_profile(array $variables): array {
  $suggestions = [];
  $view_mode = $variables['elements']['#view_mode'] ?? 'default';
  $suggestions[] = 'asu_profile__' . $view_mode;
  return $suggestions;
}

/**
 * Implements hook_preprocess_HOOK() for profile entities.
 */
function webspark_webdir_preprocess_asu_profile(&$variables): void {
  /** @var \Drupal\webspark_webdir\Entity\Profile $entity */
  $entity = $variables['elements']['#asu_profile'];
  $variables['profile'] = $entity;
  $variables['view_mode'] = $variables['elements']['#view_mode'] ?? 'default';
  $variables['profile_type'] = $entity->get('profile_type')->value ?? 'local';

  // Display format is derived from the view mode.
  // 'grid' view mode = grid display; everything else = list.
  $variables['display_format'] = ($variables['view_mode'] === 'grid') ? 'grid' : 'list';

  // Provide the profile URL. For remote profiles, link to ASU Search.
  // For local profiles, link to the canonical entity page if available.
  $variables['profile_url'] = '';
  if ($variables['profile_type'] === 'from_directory') {
    $asurite_val = $entity->get('asurite')->value ?? '';
    if ($asurite_val) {
      $variables['profile_url'] = 'https://search.asu.edu/profile/' . $asurite_val;
    }
  }
  elseif (!$entity->isNew()) {
    try {
      $variables['profile_url'] = $entity->toUrl('canonical')->toString();
    }
    catch (\Exception $e) {
      // Route may not exist yet (e.g., during Layout Builder preview).
      $variables['profile_url'] = '';
    }
  }

  // Provide content array from elements.
  foreach (\Drupal\Core\Render\Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }

  // Provide the module path for fallback images.
  $variables['module_path'] = \Drupal::service('extension.list.module')
    ->getPath('webspark_webdir');

  // For remote profiles, provide template variables for directory data.
  // Note: Stale profile data is refreshed via cron, not during rendering.
  if ($variables['profile_type'] === 'from_directory') {
    $asurite_id = $entity->get('asurite')->value ?? '';
    $variables['asurite_id'] = $asurite_id;
    // Keep app_path_folder available for the fallback anonymous image.
    $variables['app_path_folder'] = \Drupal::service('webspark_webdir.helper_functions')
      ->getAppPathFolder('app-webdir-ui');
  }

  // Provide the profile image URL and alt text.
  $variables['profile_image_url'] = '';
  $variables['profile_image_alt'] = '';

  // Generate a cache-busting value for profile images, rounded to the nearest
  // 100 seconds so the URL stays stable for short periods but still rotates.
  $variables['image_cache_break'] = (string) (intdiv(\Drupal::time()->getRequestTime(), 100) * 100);

  // For remote profiles, use the image_url field (plain URL from the API).
  if ($variables['profile_type'] === 'from_directory' && !$entity->get('image_url')->isEmpty()) {
    $variables['profile_image_url'] = $entity->get('image_url')->value;
    $variables['profile_image_alt'] = $entity->get('name')->value ?? 'Profile image';
  }
  // For local profiles, use the media entity reference with image style.
  elseif (!$entity->get('image')->isEmpty()) {
    $media = $entity->get('image')->entity;
    if ($media && $media->hasField('field_media_image') && !$media->get('field_media_image')->isEmpty()) {
      $file = $media->get('field_media_image')->entity;
      if ($file) {
        // Apply the block_image_1_1_sml_rounded image style for profile images.
        $image_style = \Drupal::entityTypeManager()
          ->getStorage('image_style')
          ->load('block_image_1_1_sml_rounded');
        if ($image_style) {
          $variables['profile_image_url'] = $image_style->buildUrl($file->getFileUri());
        }
        else {
          $variables['profile_image_url'] = \Drupal::service('file_url_generator')
            ->generateAbsoluteString($file->getFileUri());
        }
        $variables['profile_image_alt'] = $media->get('field_media_image')->alt ?? '';
      }
    }
  }
  // Attach the base library for profiles.
  $variables['#attached']['library'][] = 'webspark_webdir/profile';

  // Attach CSS for the full view mode.
  if ($variables['view_mode'] === 'full') {
    $variables['#attached']['library'][] = 'webspark_webdir/profile-full';
  }
}

/**
 * Implements hook_preprocess_HOOK()
 */
function webspark_webdir_preprocess_block__web_directory(&$variables)
{
  if (empty($variables['block'])) {
    return;
  }

  $blockContent = $variables['block'];
  if (!($blockContent instanceof BlockContent)) {
    return;
  }

  $config = \Drupal::config('webspark_webdir.settings');

  $searchType = '';
  if ($blockContent->hasField('field_component_type')) {
    $searchType = $blockContent->field_component_type->value;
  }

  $peopleSearch = '';
  if ($blockContent->hasField('field_people_search')) {
    $peopleSearch = $blockContent->field_people_search->value;
  }

  $asuriteIds = '';
  if ($blockContent->hasField('field_asurite_ids')) {
    $asuriteIds = $blockContent->field_asurite_ids->value;
  }

  $deptIds = '';
  if ($blockContent->hasField('field_department_ids')) {
    $deptIds = $blockContent->field_department_ids->value;
  }

  $filterEmployee = '';
  if ($blockContent->hasField('field_filter_employee')) {
    $filterEmployee = $blockContent->field_filter_employee->value;
  }

  $filterCampus = '';
  if ($blockContent->hasField('field_filter_campus')) {
    $filterCampus = $blockContent->field_filter_campus->value;
  }

  $filterExpertise = '';
  if ($blockContent->hasField('field_filter_expertise')) {
    $filterExpertise = $blockContent->field_filter_expertise->value;
  }

  $filterTitle = '';
  if ($blockContent->hasField('field_filter_title')) {
    // Because some titles have commas and ampersands in them, we need to
    // split the data and encode it before we use a comma as a separator in JS.
    $value = $blockContent->field_filter_title->value;
    $array = !empty($value) ? preg_split('/\r?\n|\r/', $value) : [];
    $array = array_map(function($value) {
      return rawurlencode($value);
    }, $array);
    $filterTitle = implode(',', $array);
  }

  $usePager = TRUE;
  if ($blockContent->hasField('field_webdir_use_pager')) {
    $usePager = $blockContent->field_webdir_use_pager->value;
  }

  $profilesPerPage = 20;
  if ($blockContent->hasField('field_webdir_items_to_display')) {
    $profilesPerPage = $blockContent->field_webdir_items_to_display->value;
  }

  $defaultSort = '';
  if ($blockContent->hasField('field_default_sort')) {
    if ($searchType === 'faculty_rank') {
      $defaultSort = 'faculty_rank';
    }
    else {
      $defaultSort = $blockContent->field_default_sort->value;
    }
  }

  $doNotDisplayProfiles = '';
  if ($blockContent->hasField('field_webdir_exclude_profiles')) {
    $doNotDisplayProfiles = $blockContent->field_webdir_exclude_profiles->value;
  }

  $grid = 'false';
  if ($blockContent->hasField('field_display_as_grid')) {
    $grid = $blockContent->field_display_as_grid->value == 1 ? 'true' : 'false';
  }

  $alphaFilter = "true";
  if ($blockContent->hasField('field_webdir_disable_alpha')) {
    // Note, we negate here. Easier to roll out backwards compability like this.
    $alphaFilter = !($blockContent->field_webdir_disable_alpha->value) ? 'true' : 'false';
  }

  $appPathFolder = \Drupal::service('webspark_webdir.helper_functions')->getAppPathFolder('app-webdir-ui');

  $customPadding = '';
  if ($blockContent->hasField('field_spacing_top')) {
    $customPadding .= $blockContent->field_spacing_top->value;
  }
  if ($blockContent->hasField('field_spacing_bottom')) {
    $customPadding .= ' ' . $blockContent->field_spacing_bottom->value;
  }

  $renderFields = '';
  if ($blockContent->hasField('field_anchor_menu_settings')) {
    $renderer = \Drupal::service('renderer');
    foreach ($blockContent->field_anchor_menu_settings as $item) {
      $itemValue = $item->getValue();
      if($itemValue['target_id']){
        $targetParagraph = Paragraph::load($itemValue['target_id']);
        $viewBuilder = \Drupal::entityTypeManager()->getViewBuilder($targetParagraph->getEntityTypeId());
        $renderArray = $viewBuilder->view($targetParagraph, 'default');
        $renderFields .= $renderer->render($renderArray);
      }
    }
  }

  $markup = <<<HTML
$renderFields
<div
  class="webdir-container {$customPadding}"
  id="webdir-container-{$blockContent->id()}"
  data-search-type="{$searchType}"
  data-search-url="{$config->get('api')}"
  data-search-api-version="{$config->get('api_version')}"
  data-people-search="{$peopleSearch}"
  data-asurite-ids="{$asuriteIds}"
  data-dept-ids="{$deptIds}"
  data-filter-employee="{$filterEmployee}"
  data-filter-expertise="{$filterExpertise}"
  data-filter-title="{$filterTitle}"
  data-filter-campuses="{$filterCampus}"
  data-use-pager="{$usePager}"
  data-profiles-per-page="{$profilesPerPage}"
  data-default-sort="{$defaultSort}"
  data-do-not-display-profiles="{$doNotDisplayProfiles}"
  data-grid="{$grid}"
  data-alpha-filter="{$alphaFilter}"
  data-app-path-folder="{$appPathFolder}"
></div>
HTML;

  $variables['content']['placeholder'] = [
    '#markup' => $markup,
  ];

  $variables['#attached']['library'][] = 'webspark_webdir/search-ui';
}

/**
 * Implements hook_cron().
 *
 * Refreshes stale remote profile data from the ASU Directory API.
 * Profiles sourced from the directory are checked for freshness and updated
 * if their cached data is older than 24 hours.
 */
function webspark_webdir_cron(): void {
  /** @var \Drupal\Core\Entity\EntityTypeManagerInterface $entity_type_manager */
  $entity_type_manager = \Drupal::entityTypeManager();
  /** @var \Drupal\webspark_webdir\Service\RemoteProfileFetcher $fetcher */
  $fetcher = \Drupal::service('webspark_webdir.remote_profile_fetcher');

  // Load all directory-sourced profiles.
  $profile_ids = $entity_type_manager
    ->getStorage('asu_profile')
    ->getQuery()
    ->accessCheck(FALSE)
    ->condition('profile_type', 'from_directory')
    ->condition('asurite', '', '<>')
    ->range(0, 50)
    ->execute();

  if (empty($profile_ids)) {
    return;
  }

  $profiles = $entity_type_manager
    ->getStorage('asu_profile')
    ->loadMultiple($profile_ids);

  foreach ($profiles as $profile) {
    $asurite_id = $profile->get('asurite')->value ?? '';
    if (empty($asurite_id)) {
      continue;
    }

    // Only refresh if cache is stale.
    if (!$fetcher->isCacheFresh($asurite_id)) {
      try {
        $remote_data = $fetcher->refreshProfile($asurite_id);
        if ($remote_data) {
          $affiliations = $fetcher->fetchAffiliations($asurite_id);
          $profile->populateFromRemoteData($remote_data, $affiliations);
          $profile->save();
        }
      }
      catch (\Exception $e) {
        \Drupal::logger('webspark_webdir')->warning('Cron: Failed to refresh profile for ASURITE @id: @message', [
          '@id' => $asurite_id,
          '@message' => $e->getMessage(),
        ]);
      }
    }
  }
}

