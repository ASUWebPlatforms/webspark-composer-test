{
  "name": "renovation",
  "description": "A theme based on Radix.",
  "private": true,
  "scripts": {
    "postinstall": "find node_modules/ -name '*.info' -type f -delete && cp ./config.js ./config.local.js",
    "dev": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "production": "mix --production"
  },
  "devDependencies": {
    "bootstrap": "5.3.0",
    "browser-sync": "^3.0.4",
    "browser-sync-webpack-plugin": "^2.4.0",
    "cross-env": "^7.0.3",
    "jquery": "^3.7.1",
    "laravel-mix": "^6.0.49",
    "sass": "^1.99.0",
    "sass-loader": "^12.1.0"
  },
  "dependencies": {
    "@asu/unity-bootstrap-theme": "1.37.4",
    "@popperjs/core": "^2.11.8"
  },
  "resolutions": {
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "lodash": "^4.18.0",
    "socket.io-parser": "^4.2.6",
    "webpack": "5.105.4",
    "webpack-cli": "^4.0.0"
  },
  "overrides": {
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "lodash": "^4.18.0",
    "socket.io-parser": "^4.2.6",
    "webpack": "5.105.4",
    "webpack-cli": "^4.0.0"
  }
}
