{#
/**
 * @file
 * Template for the license expiry mail.
 *
 * Available variables:
 * - license_entity: The license entity.
 * - purchased_entity: The entity which was purchased to obtain this license.
 * - purchased_entity_url: The URL of the purchased entity.
 *
 * @ingroup themeable
 */
#}
<table width="640" align="center" style="margin: 40px auto; border: 2px solid #efefef; font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;">
  <tbody>
    <tr>
      <td style="padding: 20px;">
        <p style="text-align: center;"><img src="https://lodestar.asu.edu/sites/default/files/2022-07/lodestar-logo-rgb-padded.png" /></p>
      </td>
    </tr>
    <tr>
      <td style="padding: 20px;">
	    {{ '<p style="font-size: 28px; font-weight: bold;"><span style="background: #ffc627;">License expiration</span></p>'|t }}
      </td>
    </tr>
    <tr>
      <td style="padding: 20px;">
            {{ '<p style="font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;"><span style="background: #000000; font-weight: bold; color: #ffffff;">Your purchase of @license has now expired.</span></p>'|t({'@license': license_entity.label}) }}

            {% if (purchased_entity) %}
              {{ '<p style="font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;">You may renew it now by repurchasing <a href="https://lodestar.asu.edu/nonprofit-jobs/how-post-job-board">on our website</a>.</p>' }}
            {% endif %}
      </td>
    </tr>
    <tr>
        <td style="padding: 20px;">
        {% block additional_information %}
            <p style="font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;">Please contact us if you have any questions.</p><p style="font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;">Sincerely,</p><p style="font-family: Arial,Helvetica,Verdana,sans-serif; font-size: 14px;"><strong>ASU Lodestar Center for Philanthropy and Nonprofit Innovation</strong><br />400 E. Van Buren St. | Suite 900 | Phoenix, AZ 85004<br />Ph: (602) 496-0500 | Fax: (602) 496-0952<br /><a href="mailto:nonprofit@asu.edu" style="color: #8c1d40;">nonprofit@asu.edu</a> | <a href="https://lodestar.asu.edu" style="color: #8c1d40;">lodestar.asu.edu</a></p>
        {% endblock %}
        </td>
    </tr>
  </tbody>
</table>