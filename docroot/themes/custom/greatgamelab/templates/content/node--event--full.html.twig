{#
/**
 * @file
 * Custom Template for a Blog Article Node component.
 */
#}

{%
  set classes = [
  'node',
  node.bundle|clean_class,
  node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
  'spacing-top-96',
  'spacing-bottom-96',
]
%}

{% set event_date = node.field_event_date.date %}
{% set date = event_date|date('l, F j, Y, g:i A') %}
{% set past_date = event_date|date('F j, Y') %}
{% set timezone = event_date|date('T') %}
{% set current_timestamp = 'now'|date('U') %}
{% set location = content.field_location|render|striptags|trim %}

<div class="layout__fixed-width">
    <div class="max-size-container center-container bg-white">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <article {{ attributes.addClass(classes) }} >
                    {{ title_prefix }}
                    {{ title_suffix }}
                    {% block content %}
                        <div class="ggl-article-title mx-auto">
                          <h1>{{ node.label }}</h2>
                             <p class="lead"><strong>{{ content.field_sub_head }}</strong></p>
                        </div>
                        <div class="ggl-article-image mt-8 mb-5 mx-auto">
                            {{ content.field_media }}
                        </div>
                        <div class="ggl-article-body set-piece-body mx-auto spacing-top-48">
                            <div class="ggl-article-body__event_content">
                                {{ content.body }}
                            </div>
                            <div class="ggl-article-body__event_details mt-4">
                                
                                <p class="ggl-article-event-date my-3">
                                <strong>Date:</strong>
                                {% if event_date|date('U') > current_timestamp %}
                                     {{ date }} {{ timezone }}
                                {% else %}
                                    <em>This event was held on {{ past_date }} {{ timezone }}</em>
                                {% endif %}
                                </p>
                                <p class="ggl-article-event-location my-3">
                                    <strong>Location:</strong> 
                                {% if location == 'Online' and event_date|date('U') <= current_timestamp %}
                                        Archived online event
                                    {% else %}
                                        {{ location }}
                                    {% endif %}
                                </p>
                            </div>
                            
                            <p class="mt-8"><a href="/events">Back to Events</a></p>
                        </div>
                    {% endblock %}
                    </article>
                </div>
            </div>
        </div>
    </div>
</div>
