{#
/**
 * @file
 * Custom Template for a Blog Article Node component.
 */
#}

{%
  set classes = [
  'node',
  node.bundle|clean_class,
  node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
  'spacing-top-96',
  'spacing-bottom-96',
]
%}

<div class="layout__fixed-width">
    <div class="max-size-container center-container bg-white">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <article {{ attributes.addClass(classes) }} >
                    {{ title_prefix }}
                    {{ title_suffix }}
                    {% block content %}
                        <div class="ggl-article-image mb-5 mx-auto">
                            {{ content.field_media|render }}
                        </div>
                        <div class="ggl-article-title mx-auto">
                          <h1>{{ node.label }}</h2>
                          <p class="ggl-article-pub-date mt-5 mb-8">{{ content.field_date_published|render }}</p>
                        </div>
                        <div class="ggl-article-subhead lead-md mx-auto">
                          <p class="lead"><strong>{{ content.field_sub_head }}</strong></p>
                        </div>

                        <div class="ggl-article-body set-piece-body mx-auto">

                            <div class="ggl-article-body__article_content mt-4 mb-6">
                                {{ content.body }}
                            </div>
<p class="mt-4">
    <a href="{{ node.field_link_to_publication.0.url }}" class="btn btn-gold">
        {{ node.field_link_to_publication.0.title }}<i class="fa-solid fa-arrow-up-right-from-square ps-2"></i>
    </a>
</p>
                            <p class="mt-4"><a href="/media">Back to Media</a></p>
                        </div>
                    {% endblock %}
                    </article>
                </div>
            </div>
        </div>
    </div>
</div>
