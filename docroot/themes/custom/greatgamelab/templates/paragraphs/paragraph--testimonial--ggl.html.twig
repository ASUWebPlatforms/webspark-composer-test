{% block paragraph %}
<div class="div ggl-blockquote" id="testimonial-{{ paragraph.uuid.value }}">
   
  <div class="uds-blockquote uds-content-align accent-gold default default">
    <svg title="Open quote" role="presentation" viewBox="0 0 302.87 245.82">
      <path d="M113.61,245.82H0V164.56q0-49.34,8.69-77.83T40.84,35.58Q64.29,12.95,100.67,0l22.24,46.9q-34,11.33-48.72,31.54T58.63,132.21h55Zm180,0H180V164.56q0-49.74,8.7-78T221,35.58Q244.65,12.95,280.63,0l22.24,46.9q-34,11.33-48.72,31.54t-15.57,53.77h55Z"></path>
    </svg>

    <blockquote>
      {% if paragraph.field_formatted_text.value %}
      <p>{{ paragraph.field_formatted_text.value|raw }}</p>
      {% endif %}
        <div class="citation">
          <div class="citation-content">
            {% if paragraph.field_citation_author.value %}
            <cite class="name">{{ paragraph.field_citation_author.value }}</cite>
            {% endif %}
            {% if paragraph.field_citation_title.value %}
            <cite class="description">{{ paragraph.field_citation_title.value }}</cite>
            {% endif %}
          </div>
        </div>
    </blockquote>  
  </div>
</div>
{% endblock paragraph %}

