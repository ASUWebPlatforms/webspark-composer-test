{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
    'block',
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
  ] %}
<div {{ attributes.addClass(classes).setAttribute('data-block-uuid', uuid).setAttribute('loading', 'lazy') }}>
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes }}>
      {{ label }}
    </h2>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    <div class="slideshow-container carousel-items">
      {{ content }}

      <a class="prev" onclick="currentSlide(-1)">❮</a>
      <a class="next" onclick="currentSlide(1)">❯</a>
    </div>
    <div style="text-align:center">
      {% set slideID = 0 %}
      {% set field_val = content.field_carousel_paragraph %}
      {% for key,value in field_val %}
          {% if content.field_carousel_paragraph[slideID] %}   
            {% set slideID = slideID+1 %}   
            <span class="dot" onclick="showReqSlides({{ slideID }})"></span> 
          {% endif %}   
          
      {% endfor %}
    </div>
  {% endblock %}
</div>

