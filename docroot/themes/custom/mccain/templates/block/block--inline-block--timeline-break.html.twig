{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'clearfix',
] %}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}

  {% block content %}
     <h3><span class="highlight-gold"> {{ content.field_timeline_entry }}</span></h3>
  {% endblock %}
    {{ title_suffix }}
</div>
