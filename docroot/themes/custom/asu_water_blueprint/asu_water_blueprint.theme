<?php

/**
 * @file
 * Functions to support theming.
 */

function asu_water_blueprint_theme_suggestions_select_alter(array &$suggestions, array $variables, $hook) {
  $suggestions[] = $hook . '__' . $variables['element']['#name'];
}

function asu_water_blueprint_preprocess_item_list__search_results(&$variables) {
  if (isset($_GET['keys'])) {
    $variables['keywords'] = $_GET['keys'];
  }
}
