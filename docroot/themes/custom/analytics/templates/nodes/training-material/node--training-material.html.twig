{#
/**
 * @file
 * Template for a Training Material node.
 */
#}

{% set classes = [
  'node',
  node.isPromoted() ? 'node--promoted',
  node.isSticky() ? 'node--sticky',
  not node.isPublished() ? 'node--unpublished',
  node.bundle|clean_class,
  node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
  'pb-12'
] %}

{% set data = {
  'type': node.bundle,
  'heading': node.title.value,
  'description': node.field_description.value,
  'author': node.getOwner.field_name.value|default(node.getOwner.name.value),
  'pills': [
    { 'title': 'Data Domain', 'data': node.field_data_area|map((item) => item.entity) },
    { 'title': 'Source System', 'data': node.field_source_system|map((item) => item.entity) },
  ],
  'source': node.field_url.value
} %}

<article{{ attributes.addClass(classes) }}>
  <div class="container">
    {{ include('@partials/heroes/hero-training.twig', data) }}

    {% block content %}
      {{ content }}
    {% endblock %}
  </div>
</article>
