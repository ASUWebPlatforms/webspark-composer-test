{{ attach_library('renovation/banners') }}
{% set color = node.field_notification_category.value == 'danger' ? 'orange' : node.field_notification_category.value == 'warning' ? 'blue' : 'gray' %}

<section class="banner-{{ color }}">
  <div class="banner uds-content-align" role="banner">
    <div class="banner-icon">
      <span title="Banner" class="fa fa-icon fa-bell"></span>
    </div>
    <div class="banner-content">
      <h3 class="tw-mt-0">{{ node.title.value }}</h3>
    </div>
    <div class="banner-buttons">
      <a href="{{ node|entity_url }}" role="button" class="btn btn-md btn-dark">
        View Notification
      </a>
    </div>
    <div class="banner-close">
      <button type="button"
        class="btn btn-circle btn-circle-alt-black close"
        aria-label="Close"
        data-ga-event="modal"
        data-ga-action="close"
        data-ga-name="onclick"
        data-ga-type="click"
        data-ga-section="{{ node.title.value }}"
        data-ga-region="main content"
        data-ga-text="close cross">
        <span class="fas fa-times"></span>
      </button>
    </div>
  </div>
</section>
