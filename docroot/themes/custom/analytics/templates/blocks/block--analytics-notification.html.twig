{#
/**
 * @file
 * Template for a Block component.
 *
 * Available config:
 * - html_tag: The HTML tag for the block.
 * - block_utility_classes: An array of utility classes for block.
 */
#}

{% set block_classes = [
  'block',
  bundle ? 'block--' ~ bundle|clean_class,
  id ? 'block--' ~ id|replace({"_": "-"})|clean_class,
]|merge(block_utility_classes ? block_utility_classes : []) %}

<div{{ attributes|without('id').addClass(block_classes) }}>
  {% block content %}
    {{ content }}
  {% endblock %}
</div>
