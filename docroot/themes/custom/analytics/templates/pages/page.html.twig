{#
/**
 * @file
 * Template for the main page.
 */
#}
<div class="page page-wrapper-webspark">
  <main class="pt-5 pb-5">
    {% if page.header %}
      <div class="container">
        {{ page.header }}
      </div>
    {% endif %}

    {% if page.notifications %}
      <div class="page__notifications center-container max-size-container uds-full-width">
        {{ page.notifications }}
      </div>
    {% endif %}

    {% if page.pre_content %}
      <div class="page__pre-content center-container max-size-container">
        <div class="container">
          {{ page.pre_content }}
        </div>
      </div>
    {% endif %}

    <div id="skip-to-content" class="page__content center-container max-size-container">
      {% if page.sidebar_first %}
        {{ page.sidebar_first }}
      {% endif %}

      {% block analytics_before_content %}{% endblock %}

      {% if page.content %}
        {{ page.content }}
      {% endif %}

      {% block analytics_after_content %}{% endblock %}

      {% if page.sidebar_second %}
        {{ page.sidebar_second }}
      {% endif %}
    </div>
  </main>

  {% if page.footer %}
    <footer class="page__footer" id="asu-footer" role="contentinfo">
      {{ page.footer }}
    </footer>
  {% endif %}
</div>
