{%
set classes = [
dom_id ? 'js-view-dom-id-' ~ dom_id,
]
%}
<div{{ attributes.addClass(classes) }}>
    {{ title_prefix }}
    {{ title }}
    {{ title_suffix }}

    {% if header %}
        <header>
            {{ header }}
        </header>
    {% endif %}

    {{ exposed }}

    {{ attachment_before }}

<div class="programs-list d-flex flex-sm-row flex-column align-items-stretch flex-wrap">
    {{ rows }}
</div>
    {{ empty }}
    {{ pager }}
    {{ attachment_after }}
    {{ more }}

    {% if footer %}
        <footer>
            {{ footer }}
        </footer>
    {% endif %}

</div>

