{#
/**
 * @file
 * Template for a block.
 */
#}

{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
]
%}

<div{{ attributes.addClass(classes) }}>
  <div class="bg-image-desktop">
    {{content.field_banner_background}}
  </div>
  <div class="bg-image-mobile">
    {{content.field_banner_background_mobile}}
  </div>

  <div class="overlay-box">
    <div class="container mt-5 mb-5">
      {{content.body}}
    </div>
  </div>
  {# {{ content.field_anchor_menu_settings }}
  {{ content.field_tooltip }}
  {% include '@asu_edu/image-parallax/section-cta-buttons.twig' with {
    card: card,
    component: 'image-parallax-overlay',
  } %} #}
</div>
