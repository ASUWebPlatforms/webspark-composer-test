{#
/**
 * @file
 * Template for the main page.
 */
#}
{% if page.header %}
  <header>
      {{ page.header }}
  </header>
{% endif %}
<main>
  <div class="page page-wrapper-webspark">
    <div class="pt-5 pb-5">

      {% if page.pre_content %}
        <div class="page__pre-content center-container max-size-container">
          <div class="container">
            {{ page.pre_content }}
          </div>
        </div>
      {% endif %}

      {% if page.content %}
        <div id="skip-to-content" class="page__content center-container container">
          {% if page.sidebar_right or page.sidebar_left %}
          <div class="row">
            {% if page.sidebar_left %}
            <div class="col-md-4 pe-md-5">
              {{ page.sidebar_left }}
            </div>
            {% endif %}
           <div class="col-md-8">
            {{ page.content }}
           </div> 
           {% if page.sidebar_right %}
           <div class="col-md-4 ps-md-5">
            {{ page.sidebar_right }}
           </div>
           {% endif %}
           </div>
          {% else %}
          {{ page.content }}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</main>
{% if page.footer %}
  <footer class="page__footer" id="asu-footer" role="contentinfo">
    {{ page.footer }}
  </footer>
{% endif %}
