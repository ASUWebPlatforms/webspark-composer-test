
{% if content %}
    <div{{ attributes.addClass('layout__full-width') }}>
        {% if content.first %}
            <div {{ region_attributes.first.addClass('layout__region', 'layout__region--first') }}>
                <section class="uds-story-hero{% if hero_style is not empty %} uds-story-hero-lg entry-header{% endif %}">
                    {% for key, item in content.first %}
                        {% if loop.first %}
                            {{ item.content }}
                        {% endif %}
                    {% endfor %}
                    <div class="content">
                        {% for key, item in content.first %}
                            {% if not loop.first %}
                                {% if loop.index == 3 and content.field_author_uto.x-default.0 %}
                                    <div class="container">{{ item.content }}</div>
                                    <div class="container authorContainer"><p class="articleAuthor"><strong>Written by:</strong> {{ content.field_author_uto.x-default.0 ? content.field_author_uto.x-default.0 : 'The Enterprise Technology Newsroom' }}, on&nbsp;{{ drupal_view('uto_authors', 'block_1') }}</p></div>
                                {% elseif loop.index < 8 %}
                                    <div class="container">{{ item.content }}</div>
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </div>
                </section>
            </div>
        {% endif %}
    </div>
{% endif %}