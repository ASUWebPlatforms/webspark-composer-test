{#{{ dump() }}#}
{#
/**
 * @file
 * Template for the main page.
 */
#}
{% if page.header %}
  <header>
      {{ page.header }}
  </header>
{% endif %}
{% set unpublished = is_published is same as '0' ? 'node--unpublished' : '' %}
<main>
  <div class="page page-wrapper-webspark {{ unpublished }}">
    <div class="pt-5 pb-5">

      {% if page.pre_content %}
        <div class="page__pre-content center-container max-size-container">
          <div class="container">
            {{ page.pre_content }}
          </div>
        </div>
      {% endif %}

      {#      degree_sidebar: Degree Sidebar#}
      {#      degree_search_results: Degree Search Results#}


      {% if page.degree_search_results %}
        <div id="skip-to-content" class="container">
          <div class="layout layout--two-col">
            <aside class="layout__region layout__region--sidebar">
              {{ page.degree_sidebar }}
            </aside>
            <div class="layout__region layout__region--main">
              {{ page.degree_search_results }}
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</main>
{% if page.footer %}
  <footer class="page__footer" id="asu-footer" role="contentinfo">
    {{ page.footer }}
  </footer>
{% endif %}
