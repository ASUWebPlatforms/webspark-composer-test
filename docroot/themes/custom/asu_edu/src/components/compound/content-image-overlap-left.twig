<div class="container">
  {% for card in cards %}

	<div class="row">
		<div class="col-md-12">

			<div class="uds-image-overlap content-left">
				<img class="img-fluid" src="{{ card.media }}" alt="Generic image from PlaceIMG">
				<div class="content-wrapper">
          {% include '@renovation/headings/card-heading.twig' with {
            html_tag : 'h3',
            heading: card.heading,
          } %}

          <div>{{ card.body|raw }}</div>

          {% if card.links %}
            <div class="card-button">
              {% for cta in card.links %}
                {% include '@renovation/links/cta-link.twig' with {
                  url: cta.uri,
                  label: cta.title,
                  size: '',
                  options: cta.options,
                  color: 'maroon',
                } %}
              {% endfor %}
            </div>
          {% endif %}

          {% if card.ctas %}
            <div class="card-button">
              {% for cta in card.ctas %}
                {% include '@renovation/links/cta-link.twig' with {
                  url: cta.uri,
                  label: cta.title,
                  size: loop.first ? '' : '-sm',
                  options: cta.options,
                  color: 'maroon',
                } %}
              {% endfor %}
            </div>
          {% endif %}

				</div>
			</div>

		</div>
	</div>
  {% endfor %}
</div>

