{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    'uds-blockquote alt-citation accent-gold uds-content-align'
  ]
%}

{% block paragraph %}
<div class="spacing-bottom-96">
	<div class="bg topo-white bg-top bg-percent-100 layout__full-width spacing-top-96 spacing-bottom-96">
	
	  <div{{ attributes.addClass(classes) }}>
	    {% block content %}
	    	
	    	  <svg title="Open quote" role="presentation" viewBox="0 0 302.87 245.82">
	    			<path d="M113.61,245.82H0V164.56q0-49.34,8.69-77.83T40.84,35.58Q64.29,12.95,100.67,0l22.24,46.9q-34,11.33-48.72,31.54T58.63,132.21h55Zm180,0H180V164.56q0-49.74,8.7-78T221,35.58Q244.65,12.95,280.63,0l22.24,46.9q-34,11.33-48.72,31.54t-15.57,53.77h55Z" />
			  </svg>
		      <blockquote>
		        
		          {{content.field_blockquote_body}}
		        
		        <div class="citation">
		          <div class="citation-content">
		            <cite class="name">{{content.field_blockquote_author}}</cite>
		            <cite class="description">{{content.field_blockquote_author_title}}</cite>
		          </div>
		        </div>
		      </blockquote>
	    	
		 
	    {% endblock %}
	    </div>
	  
	  </div>
  </div>
{% endblock paragraph %}

