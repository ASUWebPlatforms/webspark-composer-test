{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    'asu-image-carousel-container block block-layout-builder block-inline-blockcarousel-image'
  ]
%}

      		
			{% block paragraph %}
			  <div{{ attributes.addClass(classes) }}>
			    	{% block content %}
			    	
			    	<div class="image-carousel-containerr" id="imageCarouselContainertaco">
			    	
			    		<div
					        class="glide image-carousel aligned-carousel slider-start glide--ltr glide--slider glide--swipeable"
					        id="glide-532"
					        data-remove-side-background="false"
					        data-image-auto-size="true"
					        data-has-shadow="true"
					        data-current-index="0"
					      >
					        <div class="glide__track slider-start" data-glide-el="track">
					          <ul
					            class="glide__slides"
					            style="
					              transition: transform 400ms cubic-bezier(0.165, 0.84, 0.44, 1) 0s;
					              width: 1836px;
					              transform: translate3d(124px, 0px, 0px);
					            "
					          >
					          
					          {{ content }}
					          
					          </ul>
					        </div>
					        
					        <div
          role="group"
          class="glide__bullets"
          data-glide-el="controls[nav]"
          data-testid="bullets-container"
        >
          <button
            type="button"
            class="glide__bullet glide__bullet--active"
            data-glide-dir="=0"
            aria-label="Slide view 1"
          ></button
          ><button
            type="button"
            class="glide__bullet"
            data-glide-dir="=1"
            aria-label="Slide view 2"
          ></button>
        </div>
        <div
          class="glide__arrows"
          data-glide-el="controls"
          data-testid="arrows-container"
        >
          <button
            type="button"
            class="glide__arrow glide__arrow--prev glide__arrow--disabled"
            data-glide-dir="<"
            aria-label="Previous slide"
          >
            <svg
              class="svg-inline--fa fa-chevron-left arrow-icon"
              aria-hidden="true"
              focusable="false"
              data-prefix="fas"
              data-icon="chevron-left"
              role="img"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 320 512"
              data-fa-i2svg=""
            >
              <path
                fill="currentColor"
                d="M34.52 239.03L228.87 44.69c9.37-9.37 24.57-9.37 33.94 0l22.67 22.67c9.36 9.36 9.37 24.52.04 33.9L131.49 256l154.02 154.75c9.34 9.38 9.32 24.54-.04 33.9l-22.67 22.67c-9.37 9.37-24.57 9.37-33.94 0L34.52 272.97c-9.37-9.37-9.37-24.57 0-33.94z"
              ></path></svg
            ><!-- <span class="fas fa-chevron-left arrow-icon"></span> Font Awesome fontawesome.com --></button
          ><button
            type="button"
            class="glide__arrow glide__arrow--next"
            data-glide-dir=">"
            aria-label="Next slide"
          >
            <svg
              class="svg-inline--fa fa-chevron-right arrow-icon"
              aria-hidden="true"
              focusable="false"
              data-prefix="fas"
              data-icon="chevron-right"
              role="img"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 320 512"
              data-fa-i2svg=""
            >
              <path
                fill="currentColor"
                d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"
              ></path></svg
            ><!-- <i class="fas fa-chevron-right arrow-icon"></i> Font Awesome fontawesome.com -->
          </button>
        </div>
        
			    		</div>
			    	
			    	
			    	
			    	</div>
								
		      
				      			
		      			
		      			 	
		      		
			  		{% endblock %}
				</div>
				
				
				


			{% endblock paragraph %}
	  
		 







