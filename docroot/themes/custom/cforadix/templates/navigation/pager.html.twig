{#
/**
 * @file
 * CFO theme override for Drupal pager.
 *
 * Fixes Renovation pager UX issue where a separate "last page" control renders
 * without visible text (blank button), and hardens disabled controls so they
 * are not links with undefined hrefs.
 *
 * Variables are provided by template_preprocess_pager().
 *
 * @see template_preprocess_pager()
 */
#}

{% if items %}
  <div class="container">
    <nav role="navigation" aria-labelledby="{{ heading_id }}">
      <ul class="pagination">
        {# Previous #}
        {% if items.previous %}
          <li class="page-item">
            <a
              class="page-link page-link-icon"
              href="{{ items.previous.href }}"
              title="{{ 'Go to previous page'|t }}"
              rel="prev"{{ items.previous.attributes|without('href', 'title', 'rel', 'class') }}
              data-ga-event="select"
              data-ga-action="click"
              data-ga-name="onclick"
              data-ga-type="pagination"
              data-ga-section="pagination title"
              data-ga-region="main content"
              data-ga-text="previous">
              <span class="visually-hidden">{{ 'Previous page'|t }}</span>
            </a>
          </li>
        {% else %}
          <li class="page-item disabled">
            <span class="page-link page-link-icon" aria-disabled="true">
              <span class="visually-hidden">{{ 'Previous page'|t }}</span>
            </span>
          </li>
        {% endif %}

        {# First page (always shown as "1") #}
        {% if items.first %}
          <li class="page-item">
            <a
              class="page-link"
              href="{{ items.first.href }}"
              title="{{ 'First Page'|t }}"{{ items.first.attributes|without('href', 'title', 'class') }}
              data-ga-event="select"
              data-ga-action="click"
              data-ga-name="onclick"
              data-ga-type="pagination"
              data-ga-section="pagination title"
              data-ga-region="main content"
              data-ga-text="first page">
              <span class="visually-hidden">{{ 'First page'|t }}</span>
              <span aria-hidden="true">1</span>
            </a>
          </li>
        {% else %}
          <li class="page-item active">
            <span class="page-link" aria-current="page">
              <span class="visually-hidden">{{ 'Current page'|t }}</span>
              <span aria-hidden="true">1</span>
            </span>
          </li>
        {% endif %}

        {# Ellipsis before #}
        {% if ellipses.previous and current != 3 %}
          <li class="page-item" role="presentation"><span class="page-link">&hellip;</span></li>
        {% endif %}

        {# Page numbers (exclude page 1; include last page number normally) #}
        {% for key, item in items.pages %}
          {% if key != 1 %}
            <li class="page-item {{ current == key ? 'active' : '' }}">
              {% if current == key %}
                <span class="page-link" aria-current="page">
                  <span class="visually-hidden">{{ 'Current page'|t }}</span>
                  {{- key -}}
                </span>
              {% else %}
                {% set title = 'Go to page @key'|t({'@key': key}) %}
                <a
                  class="page-link"
                  href="{{ item.href }}"
                  title="{{ title }}"{{ item.attributes|without('href', 'title', 'class') }}
                  data-ga-event="select"
                  data-ga-action="click"
                  data-ga-name="onclick"
                  data-ga-type="pagination"
                  data-ga-section="pagination title"
                  data-ga-region="main content"
                  data-ga-text="{{ title }}">
                  <span class="visually-hidden">{{ 'Page'|t }}</span>
                  {{- key -}}
                </a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}

        {# Ellipsis after #}
        {% if ellipses.next and current != pager_max - 2 %}
          <li class="page-item" role="presentation"><span class="page-link">&hellip;</span></li>
        {% endif %}

        {#
          Intentionally do NOT render items.last.
          The Renovation pager outputs a separate "last page" control which can
          appear as a blank button. The last page remains reachable via the
          numbered links and Next control.
        #}

        {# Next #}
        {% if items.next %}
          <li class="page-item">
            <a
              class="page-link page-link-icon"
              href="{{ items.next.href }}"
              title="{{ 'Go to next page'|t }}"
              rel="next"{{ items.next.attributes|without('href', 'title', 'rel', 'class') }}
              data-ga-event="select"
              data-ga-action="click"
              data-ga-name="onclick"
              data-ga-type="pagination"
              data-ga-section="pagination title"
              data-ga-region="main content"
              data-ga-text="next page">
              <span class="visually-hidden">{{ 'Next page'|t }}</span>
            </a>
          </li>
        {% else %}
          <li class="page-item disabled">
            <span class="page-link page-link-icon" aria-disabled="true">
              <span class="visually-hidden">{{ 'Next page'|t }}</span>
            </span>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
{% endif %}
