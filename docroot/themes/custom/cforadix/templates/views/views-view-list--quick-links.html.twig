<section class="is-section pb-space-lg mt-space-xxl quicklinks-tab-block">
    <div class="container">
        <div class="row">
            {% for row in rows %}
                {% set link = row.content['#row'].nid %}
                <div class="col-lg-3 col-md-6 mr-space-md my-space-xxs">
                    <a href="node/{{link}} " class="btn-gold btn btn-lg btn-block btn-text">
                        {{ row.content['#row'].node_field_data_title }}
                    </a>
                </div>
            {% endfor %}
        </div> 
    </div>
</section>