{#
/**
 * @file
 * Field template for Product content type that renders field labels.
 *
 * Renovation's default field.html.twig strips all labels. This template
 * restores label rendering for product fields to match the original
 * Access theme display (plain text labels, not bold).
 *
 * Uses Bootstrap 5 utility classes for layout/spacing where possible,
 * keeping custom CSS only for styles without Bootstrap equivalents.
 *
 * The title field is excluded so Renovation's field--node--title.html.twig
 * handles it with proper heading component styling.
 */
#}
{% if field_name == 'title' %}
  {% include "field--node--title.html.twig" %}
{% elseif field_name == 'field_comments' %}
  {# Comment formatter uses lazy builders for the form. Render from
     the raw element to ensure the lazy builder placeholder resolves. #}
  <div class="product-field product-field--above product-field--field-comments d-flex align-items-start overflow-hidden mt-3">
    <div class="product-field__label">{{ label }}:</div>
    <div class="product-field__items">
      {{ element[0] }}
    </div>
  </div>
{% elseif label_hidden %}
  {% for item in items %}
    {{ item.content }}
  {% endfor %}
{% else %}
  <div class="product-field product-field--{{ label_display }} product-field--{{ field_name|clean_class }} mt-3{% if label_display == 'inline' %} d-flex flex-wrap align-items-baseline{% endif %}">
    {% if label_display == 'inline' %}
      <span class="product-field__label me-1">{{ label }}:</span>
      {%- for item in items -%}
      <span class="product-field__item">{{ item.content }}</span>
      {%- if not loop.last %}, {% endif -%}
      {%- endfor %}
    {% else %}
      <div class="product-field__label">{{ label }}</div>
      {% for item in items %}
        <div class="product-field__item">{{ item.content }}</div>
      {% endfor %}
    {% endif %}
  </div>
{% endif %}