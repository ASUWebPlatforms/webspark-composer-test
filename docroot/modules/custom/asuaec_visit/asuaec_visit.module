/**
 * @param array $variables
 *   An associative array containing:
 *   - children: The view results for this day.
 *   - timestamp: The day timestamp.
 *   - date_format
 *   - date_pattern
 *
 * Available variables:
 * - elements: Original variables passed to this template.
 * - attributes: HTML attributes for the wrapper.
 * - timestamp: The datetime value.
 * - date: The formatted date value.
 * - empty: Wether or not this day as content.
 * - content: Custom content.
 * - rows: A list of view rows including the following:
 *   - content: The content as a render array.
 *   - attributes: The date field name used to get this content.
 *   - from: A timestamp.
 *   - to: Another timestamp (empty for single value date field).
 *   - item: The date field item. Useful to get date type (e.g. 'created', 'changed', 'date', 'datetime', 'allday').
 *   - calendar_filter: The date field used to retrieve this content.
 *
 *
 * Prepares variables for a Calendar mini calendar template:
 * calendar-view-day--visitd9_main_calendar_v2--block-1.html.twig
 * Default template: calendar-view-day.html.twig
 *
 * Also, remove rows when Test mode is '1' and when capacity is met.
 */
function asuaec_visit_preprocess_calendar_view_day__visitd9_main_calendar_v2__block_1(&$variables) {
//    ksm($variables['timestamp'], "timestamp"); // ex.1684911600 - Wednesday, May 24, 2023 12:00:00 AM

    //-------------------------------------------------------------------------------------------
    // Prepare variable for YYYYMMDD to use it in twig template: calendar-view-day.html.twig
    $timestamp = $variables['timestamp'];
    $date = new DateTime();
    $date->setTimestamp($timestamp);
    $variables['date_string_formatted'] =  trim(strval($date->format('Ymd'))); // YYYYMMDD
//    ksm($variables['date_string_formatted'], 'date_string_formatted');


    //-------------------------------------------------------------------------
    // Grab Legend/toggle value from visit-event and barrett entity
    // and insert them as css classes for later use. For example, "self-guided"

    $variables['has_event'] = 'no-event'; // Changed on 2/1/2024
    // If there is event on the date
    if(is_array($variables['rows']) && sizeof($variables['rows']) > 0) {
//        $variables['has_event'] = 'has-event'; // Changed on 2/1/2024


//        ksm(sizeof($variables['rows']), "size of rows");
//        ksm($variables['rows'][0][0]['content']['#row']->_entity->get('date')->getValue(), "date array"); //<-- Worked!

        $variables['legend_toggle'] = []; // Array will contain css classes.

        // Iterate by time of the date
        foreach($variables['rows'] as $theindex => $event_array) {
//            ksm($theindex, "theindex");
//            ksm(sizeof($event_array), "size of event_array"); //<--- Always 3 because "content", "attributes" and "#values"

            // Iterate event by the starttime on the date
            $i = 0;
            foreach($event_array as $key => $the_event_array) {
//                ksm($key, "key");
//                ksm($the_event_array, "the_event_array"); //<--- Doesn't work.

                    if($key == 'content') {
//                        ksm($variables['rows'][$theindex], "testing2");
//                        ksm($the_event_array, "the_event_array");

                        // Load the parent entity
                        $eventseries_id = $variables['rows'][$theindex]['content']['#row']->eventseries_field_data_eventinstance_field_data_id;
                        $entity_type_eventseries = 'eventseries';
                        $entity_id_eventseries = $eventseries_id;
                        $entity_eventseries  = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);

                        // Load the instance entity
                        $eventinstance_id = $variables['rows'][$theindex]['content']['#row']->id;
                        $entity_type_eventinstance = 'eventinstance';
                        $entity_id_eventinstance = $eventinstance_id;
                        $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);


                        //------------Check end date-------------------// // Added on 2/5/2024.
                        // If end time is after 5pm, check start date/time.
                        // In DB, event is stored in UTC. Calendar is using UTC.
                        // If start date is different from end date, look at the calendar date for this iteration. if calendar date is not matching with start date, remove the row. In other words, only display event based on start date. -------------//
//                        ksm($eventinstance_id, "eventinstance_id");
                        // DB query
                        // Get row with $eventinstance_id from eventinstance_field_data table
                        $database = \Drupal::database();
                        $query = $database->select('eventinstance_field_data', 'eventinstance_field_data');
                        $query->fields('eventinstance_field_data', ['id', 'date__value', 'date__end_value']);
                        $query->condition('eventinstance_field_data.id', $eventinstance_id,'=');
                        $result = $query->execute();
                        $theevent = [];
                        foreach($result as $data){
//                            $theevent['instance_id'] = $data->id;
                            $theevent['start_datetime'] = $data->date__value;
                            $theevent['end_datetime'] = $data->date__end_value;
                        }
//                        ksm($theevent['start_datetime'], "start datetime from DB");
//                        ksm($theevent['end_datetime'], "end datetime from DB");
                        // Create PHP Date object
                        // Start date
                        $start_date_obj_fromdb = DateTime::createFromFormat("Y-m-d\TH:i:s", $theevent['start_datetime'], new DateTimeZone('UTC')); // 2024-05-17T15:00:00
                        $start_date = $start_date_obj_fromdb->format('Ymd');
                        // End date
                        $end_date_obj_fromdb = DateTime::createFromFormat("Y-m-d\TH:i:s", $theevent['end_datetime'], new DateTimeZone('UTC')); // 2024-05-17T15:00:00
                        $end_date = $end_date_obj_fromdb->format('Ymd');

                        // Date of the calendar
//                        ksm($timestamp, "timestamp of the calendar date");
//                        ksm($variables['date_string_formatted'], 'yyyymmdd of the calendar date');

                        if($start_date === $end_date) {
                            // No problem when the start date and the end date is matching.
                        } else {
                            if($variables['date_string_formatted'] === $start_date) {
                                // Event will stay in the calendar.
                            } else {
                                // Remove event
                                unset($variables['rows'][$theindex][$key]); // Remove a row
                                continue; // Go to next iteration.
                            }
                        }
                        //------------END OF Check end date.-------------------//


                        //--------------Capacity for Visit event and top-level Barrett tour----------------//

                        // Get capacity to use -- If capacity is overwriten use capacity from Event instance. Otherwise, use capacity from Event series.
                        $capacity = _get_capacity_to_use($entity_eventseries, $entity_eventinstance);
                        // Get how many people registered for the event here
                        $registrant_count = _get_registrant_count($eventseries_id, $variables, $theindex);

                        if($capacity != '') {
                            if ($registrant_count >= $capacity) { // Already full.
//                                ksm("inside if - capacity - Row will be removed.");
//                                ksm($registrant_count, "registrant_count");
//                                ksm($capacity, "capacity");
                                // Remove the row
                                unset($variables['rows'][$theindex][$key]); // Remove a row
                                continue; // Go to next iteration.
                            }
                        }
                        // --------------END OF Capacity----------------//


                        //--------------Test mode----------------//
                        // Get user role and Test mode value here as well. If not admin AND Test mode is 1, then, don't add CSS class to date.

                        // Get Test mode value
                        $temp_array_testmode = $entity_eventseries->get('field_test_mode')->getValue();
                        if ($temp_array_testmode[0]['value'] == 1) { // If Test mode is "1"
//                            ksm("Test mode is on");
                            // Get user role
                            $roles = \Drupal::currentUser()->getRoles();

                            // if not visit_admin or admin, remove the row
                            if(!(in_array('visit_admin', $roles) || in_array('administrator', $roles))) { // Do something if user doesn't have role visit_admin
                                unset($variables['rows'][$theindex][$key]); // Remove a row
                                continue;

                            } else { // if visit_admin or admin, leave the row and add CSS class to each date.
                                $temp_array = $entity_eventseries->get('field_legend_toggle')->getValue();
                                foreach ($temp_array as $legend) {
                                    // Insert Legend/toggle into array if it is not already in the array.
                                    //                            ksm($legend['value'], "legend value");
                                    //                            ksm($variables['legend_toggle'], "var legend_toggle array");
                                    if (!in_array($legend['value'], $variables['legend_toggle'])) {
                                        array_push($variables['legend_toggle'], $legend['value']);
                                    }
                                }
                                $variables['has_event'] = 'has-event'; // Added on 2/1/2024
                            }

                        } else { // When Test mode is not 1, add CSS class to each date.
//                            ksm("Test mode is off");
                            //                        ksm($entity->get('field_legend_toggle')->getValue(), "legend toggle");
                            $temp_array = $entity_eventseries->get('field_legend_toggle')->getValue();
                            //                        ksm($temp_array, "temp_array");
                            foreach ($temp_array as $legend) {
                                // Insert Legend/toggle into array if it is not already in the array.
                                //                            ksm($legend['value'], "legend value");
                                //                            ksm($variables['legend_toggle'], "var legend_toggle array");
                                if (!in_array($legend['value'], $variables['legend_toggle'])) {
                                    array_push($variables['legend_toggle'], $legend['value']);
                                }
                            }
                            $variables['has_event'] = 'has-event'; // Added on 2/1/2024
                        } // END OF if ($temp_array_testmode[0]['value'] == 1)
                        //--------------END OF Test mode----------------//

                    } // END OF if($key2 == 'content')
            } // END OF foreach($event_array as $key => $the_event_array)
        } // END OF foreach($variables['rows'] as $theindex => $event_array)

        // Prepare $variables['legend_toggle_string'] that contains all CSS classes to add
        $variables['legend_toggle_string'] = '';
        foreach($variables['legend_toggle'] as $css_class){
            $variables['legend_toggle_string'] .= ' ' . $css_class;
        }
    } // END OF if(is_array($variables['rows']) && sizeof($variables['rows']) > 0)
    else {
        $variables['has_event'] = 'no-event';
    }

} // END OF function asuaec_visit_preprocess_calendar_view_day__visitd9_main_calendar_v2__block_1(&$variables)


/**
 * @param $entity_eventseries
 * @param $entity_eventinstance
 *
 * If capacity is overwriten use capacity from Event instance.
 * Otherwise, use capacity from Event series.
 *
 * Returns capacity.
 * Returns '' if capacity is not set at all.
 */
function _get_capacity_to_use($entity_eventseries, $entity_eventinstance) {
    // Get Event series entity's capacity
    $capacity_eventseries = $entity_eventseries->get('field_capacity')->getValue();
    // Get Event instance's capacity
    $overwrite_capacity_eventinstance = $entity_eventinstance->get('field_overwrite_capacity')->getValue()[0]['value']; // 0:No overwrite, 1: Overwrite

    $capacity = '';
    if($overwrite_capacity_eventinstance == '1') { // Overwrite
        // Get capacity value from Event instance
        $capacity_eventinstance = '';
        $capacity_eventinstance = $entity_eventinstance->get('field_capacity_event_instance')->getValue();

        if(sizeof($capacity_eventinstance) > 0) {
            // Use Event instance's capacity
            $capacity = $capacity_eventinstance[0]['value'];

        } else { // Just in case if capacity is not set in Event instance, use Event series's capacity
            if(sizeof($capacity_eventseries) > 0) {
                // Use Event series's capacity
                $capacity = $capacity_eventseries[0]['value'];
            }
        }

    } // END OF if($overwrite_capacity_eventinstance == '1')
    else { // No overwrite
        if(sizeof($capacity_eventseries) > 0) {
            // Use Event series's capacity
            $capacity = $capacity_eventseries[0]['value'];
        }
    }
    return $capacity;
} // END OF function _get_capacity_to_use


/**
 * @param $entity_eventseries
 * @param $entity_eventinstance
 *
 * If start time is overwriten use start time from Event instance.
 * Otherwise, use start time from Event series.
 *
 * Returns start time in 2023-05-17T15:00:00 format. It is in UTC.
 */
function _get_starttime_to_use($entity_eventinstance) {
    // NOTES: For date/time, we can just use Event instance entity.
    $starttime_eventinstance = $entity_eventinstance->get('date')->getValue()[0]['value'];
    return $starttime_eventinstance;
}


/**
 * @param $variables
 * @param $theindex
 * @param $eventseries_id
 * @param $event_start_date in 2023-05-17T15:00:00 format. It is in UTC.
 *
 * Count how many people are registared including guests.
 *
 * Returns $registrant_count which includes $guest_count.
 * Returns 0 if registrant_count is not set at all.
 */
function _get_registrant_count($eventseries_id, $variables = null, $theindex = null, $event_start_date = null) {
    // Get start date
    // When $variables and $theindex is null, $event_start_date should be passed.
    if(!is_null($variables)) {
        $event_date_array = $variables['rows'][$theindex]['content']['#row']->_entity->get('date')->getValue();
        $event_start_date = $event_date_array[0]['value']; // in 2023-05-17T15:00:00 format in UTC.
    }

    // Get timestamp of actual tour
    $date_obj_actualtour = DateTime::createFromFormat("Y-m-d\TH:i:s", $event_start_date, new DateTimeZone('UTC'));
    $start_timestamp_actualtour = $date_obj_actualtour->getTimestamp();

    // Get date only of the actual tour in Phoenix time --- Added on 6/23/2023.
    $date_obj_actualtour->setTimeZone(new DateTimeZone('America/Phoenix'));
    $dateonly_actualtour = $date_obj_actualtour->format('Y-m-d');
//    \Drupal::logger('visit')->notice("dateonly_actualtour:" . $dateonly_actualtour);

    // Get timestamp that we use for Event ID
    // NOTES: Added Time only field in Event series. For the timestamp that we use for Event ID, calculate the timestamp using the date that was clicked and the Time only field value.
    $timestamp_for_eventid = _get_timestamp_for_eventid($eventseries_id, $dateonly_actualtour, $start_timestamp_actualtour);
//    ksm($timestamp_for_eventid, "timestamp_for_eventid - _get_registrant_count()");

    // The event id is: (Event series entity id)-(timestamp using the Time only field).
    $event_id = $eventseries_id . '-' . $timestamp_for_eventid;
//    \Drupal::logger('visit')->notice("event_id:" . $event_id);

    // DB access
    $nodeStorage = \Drupal::entityTypeManager()->getStorage('node');
    $ids = $nodeStorage->getQuery()
        ->accessCheck(FALSE)
        ->condition('type', 'student_registered_visits') // type = bundle id (machine name)
        ->condition('field_student_event_id', $event_id, '=')
        ->execute();
//    \Drupal::logger('visit')->notice("ids:<pre>" . print_r($ids, true) . "</pre>");
    $student_registered_nodes = $nodeStorage->loadMultiple($ids);
    // Registrant count
    $registrant_count = sizeof($student_registered_nodes);
    // Guest count
    $guest_count = 0;
    foreach ($student_registered_nodes as $nid => $node) {
        $field_student_guests_array = $node->get('field_student_guests')->getValue();
        if(sizeof($field_student_guests_array) > 0) {
            $field_student_guests = $node->get('field_student_guests')->getValue()[0]['value'];
            $guest_count = $guest_count + $field_student_guests;
        }
    }
    // Put together registrant count and guest count
    $registrant_count = $registrant_count + $guest_count;
    return $registrant_count;
}


/**
 * Prepares variables for a Day agendas template:
 * views-view-unformatted--visitd9-day-agenda--block-1.html.twig -- Used for day agendas on the right side.
 *
 * Send the following to the twig file:
 * - Event Seried ID
 * - Event start date/time in timestamp
 * - Privacy value - private, public and comingsoon
 * - Publish date - Used in "Coming soon - registration opens January 2"
 * - event_type
 * - event_date -> datetime
 *
 *
 * @param array $variables
 *   An associative array containing:
 *   - children: The view results for this day.
 *   - timestamp: The day timestamp.
 *   - date_format
 *   - date_pattern
 */
function asuaec_visit_preprocess_views_view_unformatted(&$variables){
    $view = $variables['view'];
    if($view->id() != 'visitd9_day_agenda') {
        return;
    }

    $rows = $variables['rows'];
    foreach ($rows as $id => $row) {

//        ksm($rows[$id]['content']['#eventinstance'], "eventinstance"); //<----Works!
//        ksm($rows[$id]['content']['#eventinstance']->getEventSeries(), "event series"); //<----Works!

//        ksm($rows[$id]['content']['#row'], "test4"); //<----Works!
//        ksm($rows[$id]['content']['#row']->id, "Event instance id"); //<----Works!
//        ksm($rows[$id]['content']['#row']->eventseries_field_data_eventinstance_field_data_id, "Event series id"); //<----Works!
//        ksm($rows[$id]['content']['#row']->_entity->getType(), "Event type"); //<---Works


        //----------------------------------------------
        // Prepare event_instance_id
        $variables['event_instance_id'][$id] = $rows[$id]['content']['#row']->id;
//        ksm($rows[$id]['content']['#row']->id, "event instance id");


        //----------------------------------------------
        // Prepare event_series_id and event_timestamp

        // Prepare variable for Event Seried ID
//        $variables['event_series_id'][$id] = $rows[$id]['content']['#eventinstance']->getEventSeries()->id();
        $variables['event_series_id'][$id] = $rows[$id]['content']['#row']->eventseries_field_data_eventinstance_field_data_id;

////        ksm($variables['event_series_id'][$id] = $rows[$id]['content']['#eventinstance'], "eventinstance");
//        $eventseries_type = $rows[$id]['content']['#eventinstance']->getType();
        $eventseries_type = $rows[$id]['content']['#row']->_entity->getType(); //<---Works!
////        ksm($eventseries_type); // visit_event


        // Prepare variable for Event start date/time in timestamp
////        ksm($rows[$id]['content']['#eventinstance']->get('date')->value, "event date"); //<----2022-11-01T15:00:00
//        $datetime_string = $rows[$id]['content']['#eventinstance']->get('date')->value; //<----2022-11-01T15:00:00
        $datetime_string = $rows[$id]['content']['#row']->eventinstance_field_data_date__value; //<----2022-11-01T15:00:00
        $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $datetime_string, new DateTimeZone('UTC'));
        $timestamp = $date_obj->getTimestamp();
        $date_obj->setTimeZone(new DateTimeZone('America/Phoenix'));

        // Start timestamp
        $variables['timestamp_start'][$id] = $timestamp;

        // event_date ex. Wed, 05/03/23 03:00 pm
//        $variables['event_date'][$id] = $date_obj->format('D, m/d/y h:i a'); // Let's use this field for SF Event name. Changing format. 6/14/2023
        $variables['datetime'][$id] = $date_obj->format('Y/m/d H:i:s');
        // dateonly ex. 2023-05-03
        $variables['dateonly'][$id] = $date_obj->format('Y-m-d');
        // Start time
        $variables['time_start'][$id] = $date_obj->format('h:i a');
        // Timestamp for event id which we calculate using the Time Only field in Event series entity.
        $variables['timestamp_for_eventid'][$id] = _get_timestamp_for_eventid($variables['event_series_id'][$id], $variables['dateonly'][$id], $timestamp);
        // Prepare variable for Event end date/time in timestamp
        $datetime_string = $rows[$id]['content']['#row']->eventinstance_field_data_date__end_value;
        $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $datetime_string, new DateTimeZone('UTC'));
        // End timestamp
        $timestamp = $date_obj->getTimestamp();
        $date_obj->setTimeZone(new DateTimeZone('America/Phoenix'));
        $variables['timestamp_end'][$id] = $timestamp;
        // End time
        $variables['time_end'][$id] = $date_obj->format('h:i a');


        //---------------------------------------------
        // Load the parent entity
        $entity_type_eventseries = 'eventseries';
        $entity_id_eventseries = $variables['event_series_id'][$id];
        $entity_eventseries = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);


        // Load the instance entity
        $entity_type_eventinstance = 'eventinstance';
        $entity_id_eventinstance = $rows[$id]['content']['#row']->id;
        $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);


        //--------------Capacity for Visit event----------------//

        // Get capacity to use -- If capacity is overwriten use capacity from Event instance. Otherwise, use capacity from Event series.
        $capacity = _get_capacity_to_use($entity_eventseries, $entity_eventinstance);

        // Get how many people registered for the event here
        $registrant_count = _get_registrant_count($variables['event_series_id'][$id], $variables, $id);

        if($capacity != '') {
            if($registrant_count >= $capacity) { // Already full. <--- I feel like it hsould be >=. weird. But if I use >=, it doesn't work.
                // Remove the row
                unset($variables['rows'][$id]); // Remove a row
                continue; // Go to next iteration.
            }
        }
        // --------------END OF Capacity----------------//


        //--------------Test mode----------------//

        // Get the field_test_mode and remove row when Test mode is 1.
        $temp_array_testmode = $entity_eventseries->get('field_test_mode')->getValue();
//        ksm($temp_array_testmode, "temp_array_testmode from asuaec_visit_preprocess_views_view_unformatted");

        //--------------Dealing with Test mode----------------//
        // If Test mode is "1", get user role. If not admin, remove the row.
        if ($temp_array_testmode[0]['value'] == 1) { // If Test mode is "1"
            // Get user role
            $roles = \Drupal::currentUser()->getRoles();

            // if not visit_admin or admin, remove the row
            if(!(in_array('visit_admin', $roles) || in_array('administrator', $roles))) { // Do something if user doesn't have role visit_admin
                //        if(in_array('visit_admin', $roles)) { // Do something if user doesn't have role visit_admin -----JUST FOR DEVELOPMENT
                unset($variables['rows'][$id]); // Remove a row
            }
        }  // END OF if ($temp_array_testmode[0]['value'] == 1)

        //--------------END OF Test mode----------------//



        //---------------------------
        // Prepare Privacy value

        // Get the field_privacy
        $temp_array_privacy = $entity_eventseries->get('field_privacy')->getValue();
        $privacy = $temp_array_privacy[0]['target_id']; // tid - 23: Private, 24: Public, 22: Coming soon
        switch($privacy) {
            case '23': // Private
                $variables['privacy'][$id] = 'private';
                break;
            case '24': // Public
                $variables['privacy'][$id] = 'public';
                break;
            case '22': // Coming soon
                $variables['privacy'][$id] = 'comingsoon';
                break;
        }


        //---------------------------
        // Prepare Publish date value - Publish date is only for visit_event
        if($eventseries_type == 'visit_event') {
            $temp_array_publishdate = $entity_eventseries->get('field_publish_date')->getValue();
            if(sizeof($temp_array_publishdate) > 0){
                $publish_date = $temp_array_publishdate[0]['value']; // 2023-01-02
                $date_obj = date_create($publish_date); // Get Php Date object
                $variables['publish_date_formatted'][$id] = date_format($date_obj, 'F j');
            } else {
                $variables['publish_date_formatted'][$id] = '';
            }
        }

        //---------------------------
        // Prepare classes value for legend_toggle
        $variables['legend_toggle'] = [];
        $temp_array = $entity_eventseries->get('field_legend_toggle')->getValue();
//        ksm($temp_array, "temp array");
        foreach ($temp_array as $legend) {
            // Insert Legend/toggle into array if it is not already in the array.
            //                            ksm($legend['value'], "legend value");
            //                            ksm($variables['legend_toggle'], "var legend_toggle array");
            if (!in_array($legend['value'], $variables['legend_toggle'])) {
                array_push($variables['legend_toggle'], $legend['value']);
            }
        }
//        ksm($variables['legend_toggle'], "var legend_toggle after each" );
        $variables['legend_toggle_string'][$id] = '';
        foreach($variables['legend_toggle'] as $css_class){
            $variables['legend_toggle_string'][$id] .= ' ' . $css_class;
        }
//        ksm($variables['legend_toggle_string'][$id], "legend_toggle_string");

        //---------------------------
        // Prepare event_type
        $variables['event_type'][$id] =  _getValueOfEvent($entity_eventseries, 'field_evtype');

        //---------------------------
        // Prepare event_displaytitle
        $variables['event_display_title'][$id] =  _getValueOfEvent($entity_eventseries, 'field_display_title');

        //---------------------------
        // Prepare visitor_type
        $variables['visitor_type'][$id] =  _getValueOfEvent($entity_eventseries, 'field_visitor_type');

    } // END OF foreach ($rows as $id => $row) {
} // END OF function asuaec_visit_preprocess_views_view_unformatted(&$variables)


/**
 * @param $eventseries_id
 * @param $dateonly // date only ex. 2023-05-03 or 20230503 in Phoenix time. Date that was clicked.
 * @param $timestamp_actualtour
 * @return int|mixed
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 *
 * Helping function
 * Return timestamp that we can use for event id which we calculate using the Time only field in Event series entity.
 * If Original time only field is empty, if $timestamp_actualtour is passed, it will use $timestamp_actualtour.
 * If Original time only field is empty, if $timestamp_actualtour is not passed, it will return ''.*
 */
function _get_timestamp_for_eventid($eventseries_id, $dateonly, $timestamp_actualtour = '') {
    $ret_value = '';
    // Load the Event series entity
    $entity_type_eventseries = 'eventseries';
    $entity_id_eventseries = $eventseries_id;
    $entity_eventseries  = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);

    // Get Time only field value from Event series entity
    $timeonly = _getValueOfEvent($entity_eventseries, 'field_start_time_for_eventid', null);
//    ksm($timeonly, "timeonly timestamp"); // 36000
//    ksm($dateonly, "dateonly"); // 2023-06-27   Y-m-d

    // dateonly - If it comes in as YYYYmmdd

    if($timeonly != '') {

        // Get the timestamp for the date at 0 o'clock.
        if(strpos($dateonly, '-') == false) {
            $date_obj = DateTime::createFromFormat("Ymd\TH:i:s", $dateonly . 'T00:00:00', new DateTimeZone('America/Phoenix'));
        } else {
            $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $dateonly . 'T00:00:00', new DateTimeZone('America/Phoenix'));
        }
        $timestamp_at0oclock = $date_obj->getTimestamp();
//        ksm($timestamp_at0oclock, "timestamp_at0oclock");
        // Combine timestamp value at 0 o'clock and Time only field value
        $timestamp_for_eventid = $timestamp_at0oclock + intval($timeonly);
//        ksm($timestamp_for_eventid, "timestamp_for_eventid");
//        ksm($timestamp_actualtour, "start timestamp for actual event");
        $ret_value = $timestamp_for_eventid;

    } else {
        $ret_value = $timestamp_actualtour;
    }
    return $ret_value;
}


/**
 * @param $entity_eventseries
 * @param $field_name
 * @param null $overwrite_field_name
 * @return mixed|string
 *
 * Helping function
 * Get field value from Event Series entity
 */
function _getValueOfEvent($entity_eventseries, $field_name, $overwrite_field_name = null) { // $overwrite_field_name is a boolean field.
    $ret_value = '';
    $temp_array = $entity_eventseries->get($field_name)->getValue();
    if(sizeof($temp_array) > 0){
        $ret_value = $temp_array[0]['value'];
    } else {
        $ret_value = '';
    }
    return $ret_value;
}


/**
 * @param \Drupal\field\Entity\FieldStorageConfig $definition
 *   The field definition.
 * @param \Drupal\Core\Entity\ContentEntityInterface|null $entity
 *   The entity being created if applicable.
 * @param bool $cacheable
 *   Boolean indicating if the results are cacheable.
 *
 * @return array
 *   An array of possible key and value options.
 *
 * @see options_allowed_values()
 *
 * Set dynamic allowed values for the college(s) field in Additional tour Paragraph.
 */
function asuaec_visit_allowed_values_function(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL) {
//    \Drupal::logger('visit')->notice("testing1:" . $entity->bundle());
    $options = [];
    // field_college field inside paragraph additional_tour
    // Allowed values will be coming from database.
    if ($entity->bundle() == 'additional_tour') {

        $database = \Drupal::database();
        $table = 'asu_ugrad_interest_category_degrees';
        $field_array = array('categoryprogramcode', 'categoryprogramDesrc100');
        $orderby = 'categoryprogramDesrc100';
        $query = $database->select($table, 't');
        $query->fields('t', $field_array);
//    $query->condition($field_state, $state, '=');
        $query->orderBy($orderby, 'ASC');
        $result = $query->distinct()->execute();
//        $options = [];
        foreach ($result as $record) {
            if ($record->categoryprogramDesrc100 == "Business, W. P. Carey School of" && $record->categoryprogramcode == "UGES") {
                continue;
            }
            if ($record->categoryprogramDesrc100 == "Interdisciplinary Arts and Sciences, New College of" && $record->categoryprogramcode == "UGES") {
                continue;
            }
            $program_code = $record->categoryprogramcode; // "UGES"
            $college_name = $record->categoryprogramDesrc100; // Business, W. P. Carey School of
            $options[$program_code] = $college_name;
        }
        unset($options['UGHO']);
        asort($options);

//        \Drupal::logger('visit')->notice("options:<pre>" . print_r($options, true) . "</pre>");
    }
    return $options;
}


/**
 * @param ViewExecutable $view
 *
 * hook_views_pre_render
 *
 * Insert value in placeholder in Day agenda:
 * - Display title
 * - Additional tour
 * - Barrett tour under Exp ASU
 */
function asuaec_visit_views_pre_render(\Drupal\views\ViewExecutable $view) {

    if ($view->id() == 'visitd9_day_agenda') {

        // Clear cache
        \Drupal::service('cache.render')->invalidateAll();

        $current_path = \Drupal::service('path.current')->getPath();
        $result = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
        $uriSegment_array = explode('/',$result);
//        ksm($uriSegment_array, "uriSegment_array");
            //0 => string (0) ""
            //⇄1 => string (9) "dayevents"
            //⇄2 => string (8) "20230620"
            //⇄3 => string (5) "Tempe"
            //⇄4 => string (16) "Graduate student"
            //⇄5 => string (1) "0"
        $lastUriSegment = end($uriSegment_array);
        $category_id = $lastUriSegment; // For Ugrad, the tid for Visit bucket. For Grad, it becomes 0.
        // Get the date clicked
        $thedate_clicked = $uriSegment_array[2]; // 20221122
        // Get Person type because for Grad, we don't need to worry about Additional tour/Barrett tour under Exp ASU.
        $person_type = $uriSegment_array[4];

        $barrett_under_expasu = false;
        foreach($view->result as $key => $rr){
//            ksm($key, "key");

            // Get Parent id (Event series ID)
            $parent_id = $view->result[$key]->_entity->get('eventseries_id')->getValue();
            // ksm($parent_id, "parent_id"); // Event series entity id
            // Load parent Event series entity
            if(isset($parent_id)) {
                $entity_type = 'eventseries';
                $entity_id = $parent_id[0]['target_id'];
//                ksm($entity_id, "entity_id"); // Event series
                $entity = \Drupal::entityTypeManager()->getStorage($entity_type)->load($entity_id);
                $barrett_entity_ids_array = [];
                $addtour_paragraph_entity_ids_array = [];
                $barretttour_under_expasu_entity_ids_array = [];
                //                ksm($parent_id[0]['target_id'], "parent_id 0 target_id"); // Event series entity id


                //--------Display title ---------------//

                // NOTES:
                // Get Display title and plug it into field_placeholder_display_title.
                // if Display title is empty, use just title.
                $display_title_array = $entity->get('field_display_title')->getValue();
                if(sizeof($display_title_array) > 0) {
                    $display_title = '<h4>' . $display_title_array[0]['value'] . '</h4>';
                } else {
                    $title_array = $entity->get('title')->getValue();
                    $display_title = '<h4>' . $title_array[0]['value'] . '</h4>';
                }
                $output_formattablemarkup_displaytitle = new FormattableMarkup($display_title, []);
                $rr->_entity->set('field_placeholder_display_title', $output_formattablemarkup_displaytitle); //<-- This worked!

                //--------END OF Display title ---------------//


                // NOTES: Grad doesn't have Additional tour or Barrett under Exp ASU
                if($person_type == "Graduate student") {
                    continue; // Go to the next iteration.
                }


                //----------------------------------------------------------------------------------------------//
                //-------- Proess for Additional tour and Barrett tour under Exp ASU starts here ---------------//

                // Get array of colleges based on category ID (Visit bucket)
                $collegesArrayBasedOnCat = _get_collegearray_basedoncategory($category_id);

                // For "Visit event"
                if($entity->bundle() == "visit_event") {

					$campus = $entity->get('field_campus')->getValue(); //Added by Arcahana
					$campus_value = $campus[0]['value']; //Added by Arcahana

                    //------ Barrett under Experience ASU --------//
                    // Get Barrett tour display title and time under Experience ASU

                    // Get "Overwrite Barrett tour" boolean value first.
                    $overwrite_barretttour_array = $view->result[$key]->_entity->get('field_overwrite_barretttour')->getValue();
                    $overwrite_barretttour = $overwrite_barretttour_array[0]['value']; // 0 or 1: 1 means to overwrite.

                    if($overwrite_barretttour == '1') { // Overwrite
                        // Get Barrett tour instance under Experience ASU
                        $instance_barrett_tour = $view->result[$key]->_entity->get('field_barrett_tours_event_instan')->getValue();
//                        ksm($instance_barrett_tour, "instance_barrett_tour");
                        // When sizeof($instance_barrett_tour) == 0, there is no Barrett tour.
                        if(sizeof($instance_barrett_tour) > 0) { // Overwritten
                            foreach($instance_barrett_tour as $thearray) {
                                array_push($barretttour_under_expasu_entity_ids_array, $thearray['target_id']);
                            }
//                            ksm($barretttour_under_expasu_entity_ids_array, "barretttour_under_expasu_entity_ids_array - Overwritten");
                        }

                    } else { // No overwrite
                        // Get Barrett Event series entity ids that were attached to the visit_event Event series entity
                        foreach($entity->get('field_barrett_tours')->getValue() as $thearray) {
                            array_push($barretttour_under_expasu_entity_ids_array, $thearray['target_id']);
                        }
//                        ksm($barretttour_under_expasu_entity_ids_array, "barretttour_under_expasu_entity_ids_array - No overwritten");
                    }
//                    ksm($barretttour_under_expasu_entity_ids_array, "barretttour_under_expasu_entity_ids_array - after if");

                    if(sizeof($barretttour_under_expasu_entity_ids_array) > 0) {
                        $output_barrett = '';
                        $barrett_under_expasu = true;
                        // NOTES: _prepare_output_barrett() calls the function to check capacity.
                        $output_barrett = _prepare_output_barrett($barretttour_under_expasu_entity_ids_array, $thedate_clicked, $barrett_under_expasu);
                        if($output_barrett != '') {
                            $output_formattablemarkup_barrett = new FormattableMarkup($output_barrett, []);
                            $rr->_entity->set('field_placeholder_for_barrett', $output_formattablemarkup_barrett);
                        }
                    } // END OF if(sizeof($barretttour_under_expasu_entity_ids_array) > 0)

                    //-------- END OF Barrett under Experience ASU --------------//


                    //-------- Additional tours/Academic sessions ---------------//

                    // Get "Overwrite Additional tour" boolean value first.
                    $overwrite_addtour_array = $view->result[$key]->_entity->get('field_overwrite_addtour')->getValue();
                    $overwrite_addtour = $overwrite_addtour_array[0]['value']; // 0 or 1. 1 means to overwrite.

                    if($overwrite_addtour == '1') { // Overwrite
                        // Get Add tour instance
                        $instance_add_tour = $view->result[$key]->_entity->get('field_additional_tours_eventinst')->getValue();
                        // When sizeof($instance_add_tour) == 0, there is no additional tour.
                        if(sizeof($instance_add_tour) > 0) { // Overwritten
                            foreach($instance_add_tour as $thearray) {
                                array_push($addtour_paragraph_entity_ids_array, $thearray['target_id']);
                            }
//                        ksm($addtour_paragraph_entity_ids_array, "addtour_paragraph_entity_ids_array - Overwritten");
                        }

                    } else { // No overwrite
                        foreach($entity->get('field_additional_tours')->getValue() as $thearray) {
                            array_push($addtour_paragraph_entity_ids_array, $thearray['target_id']);
                        }
//                        ksm($addtour_paragraph_entity_ids_array, "addtour_paragraph_entity_ids_array - No overwritten");
                    }

                    // Let's just do Entity load here for Additional tour.
                    // NOTES: _prepare_output_addtours() calls the function to check capacity and to check college that is associated with Visit bucket that were selected.
                    $output_addtours = [];
                    if(sizeof($addtour_paragraph_entity_ids_array) > 0) {
                        $output_addtours = _prepare_output_addtours($addtour_paragraph_entity_ids_array, $collegesArrayBasedOnCat, $thedate_clicked, $entity_id, $campus_value); // In this case, $entity_id is Event series entity id. $campus_value added by Archana
//                        ksm($output_addtours, "output addtours");

                        if($output_addtours > 0) {
                            $output_formattablemarkup_addtour = new FormattableMarkup($output_addtours['output'], []);
                            $rr->_entity->set('field_placeholder_for_addtour2', $output_formattablemarkup_addtour); // NOTES: field_placeholder_for_addtour2 has to be plain text in order to display in full_html.
                        }

                    } // END OF if(sizeof($addtour_paragraph_entity_ids_array) > 0)

                    //----------- END OF Additional tours/Academic sessions ---------------//


                    //----------------------------------------------------------------------------------------------//
                    //-------- Event description - Added on 7/21/2023 ---------------//

                    // Find out if there is College session included
                    // NOTE: If College session is included, display field_event_description.
                    // If College session is not included, display field_event_description_no_acad.
                    // Insert one of them into field_placeholder_description in Event instance.
                    if(array_key_exists('collegesession_included', $output_addtours) && $output_addtours['collegesession_included'] == true) { // College session is included

                        // Get Event description values from Event Series
                        $event_description_w_collegesession = $entity->hasField('field_event_description_html') ? $entity->get('field_event_description_html')->getValue() : '';
                        $rr->_entity->set('field_placeholder_for_descr_html', $event_description_w_collegesession);
                    } else {
                        $event_description_no_collegesession = $entity->hasField('field_event_descr_no_collegesess') ? $entity->get('field_event_descr_no_collegesess')->getValue() : '';
                        $rr->_entity->set('field_placeholder_for_descr_html', $event_description_no_collegesession);
                    }


                } // END OF if($entity->bundle() != "visit_event")

                if($entity->bundle() == "barrett") {

                    //-------- For Barrett solo: "I prefer to only visit with Barrett, The Honors College." - Added on 7/24/2023 ---------------//

                    // NOTE: For Barrett solo (top-level) just insert the text into field_placeholder_for_message
                    // NOTE: Now it could be Academic facility tour. Only for Event type of "Barrett tour", display "I prefer to only visit with Barrett, The Honors College".

                    // Get Event type
                    $event_type = $entity->get('field_evtype')->getValue()[0]['value'];
                    if($event_type == "Barrett tour") {
                      //Code added by Archana for Barrett tooltip
                      $barrett_tip_data = "<p>Established in 1988, Barrett has been recognized as the \"gold standard\" among honors colleges in the nation. An undergraduate student can be engaged in the Barrett experience at any of ASU’s four metropolitan Phoenix campuses.</p>";
                      $barrett_info_tool_tip = '<div class="custom-tooltip"><div class="custom-tooltip-container-acadsessions"><button tabindex="0" class="uds-tooltip uds-tooltip-button uds-tooltip-dark" aria-describedby="tooltip-desc-1"><span class="fa-stack"><svg class="campus-svg svg-inline--fa fa-circle fa-w-16 fa-stack-2x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="circle" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="#8c1d40" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg><svg class="svg-inline--fa fa-info fa-w-6 fa-stack-1x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="info" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 512" data-fa-i2svg=""><path fill="#ffffff" d="M20 424.229h20V279.771H20c-11.046 0-20-8.954-20-20V212c0-11.046 8.954-20 20-20h112c11.046 0 20 8.954 20 20v212.229h20c11.046 0 20 8.954 20 20V492c0 11.046-8.954 20-20 20H20c-11.046 0-20-8.954-20-20v-47.771c0-11.046 8.954-20 20-20zM96 0C56.235 0 24 32.235 24 72s32.235 72 72 72 72-32.235 72-72S135.764 0 96 0z"></path></svg></span></button><div role="tooltip" class="custom-tooltip-description" id="tooltip-desc-1"><button style="color:#fff;" type="button" class="btn btn-default popup-close-btn"><svg class="svg-inline--fa fa-window-close fa-w-16" aria-hidden="true" focusable="false" data-prefix="fa" data-icon="window-close" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="currentColor" d="M464 32H48C21.5 32 0 53.5 0 80v352c0 26.5 21.5 48 48 48h416c26.5 0 48-21.5 48-48V80c0-26.5-21.5-48-48-48zm-83.6 290.5c4.8 4.8 4.8 12.6 0 17.4l-40.5 40.5c-4.8 4.8-12.6 4.8-17.4 0L256 313.3l-66.5 67.1c-4.8 4.8-12.6 4.8-17.4 0l-40.5-40.5c-4.8-4.8-4.8-12.6 0-17.4l67.1-66.5-67.1-66.5c-4.8-4.8-4.8-12.6 0-17.4l40.5-40.5c4.8-4.8 12.6-4.8 17.4 0l66.5 67.1 66.5-67.1c4.8-4.8 12.6-4.8 17.4 0l40.5 40.5c4.8 4.8 4.8 12.6 0 17.4L313.3 256l67.1 66.5z"></path></svg></button><div class="formatted-text">'.$barrett_tip_data.'</div></div></div></div>';

                                //$rr->_entity->set('field_placeholder_message_text', new FormattableMarkup("<p>I prefer to only visit with Barrett, The Honors College.</p>", []));
                      $rr->_entity->set('field_placeholder_message_text', new FormattableMarkup("<div class='acad-session-div'>I prefer to only visit with Barrett, The Honors College.$barrett_info_tool_tip</div>", []));

                    } // END OF if($event_type == "Barrett tour")
                    //-------- END OF For Barrett solo: "I prefer to only visit with Barrett, The Honors College." ---------------//


                    //-------- Event description - Added on 7/21/2023 ---------------//

                    // Get Event description values from Event Series
                    $event_description = $entity->hasField('field_event_description_html') ? $entity->get('field_event_description_html')->getValue() : '';
                    // NOTE: For Barrett solo (top-level) just insert field_event_description into field_placeholder_description
                    $rr->_entity->set('field_placeholder_for_descr_html', $event_description);


                    //-------- END OF Event description - Added on 7/21/2023 ---------------//

                } // END OF if($entity->bundle() == "barrett")
            } // END OF if(isset($parent_id))
        } // END OF foreach($view->result as $key => $rr)
    } // END OF if ($view->id() == 'visitd9_day_agenda')
   /** code added by Archana to update sun devil days view to change views output Register/Watch link text value based on event date and create JS variables **/
  if ($view->id() == "new_sun_devil_days" && ( ($view->current_display == 'block_1') || ($view->current_display == 'block_2') || ($view->current_display == 'block_3') || ($view->current_display == 'block_4') || ($view->current_display == 'block_5' ) || ($view->current_display == 'block_12' )))  {
    foreach($view->result as $value){
      $over_capacity_value = $value->_entity->get('field_capacity_event_instance')->value;
      //ksm($over_capacity_value);
      $entity_instance_id = $value->_entity->get('id')->value;
      $entity_series_id = $value->_relationship_entities['eventseries_id']->get('id')->value;
      $privcay_tid = $value->_relationship_entities['eventseries_id']->get('field_privacy')->target_id;
      $event_end_date = $value->_entity->get('date')->end_value;
      $event_start_date = $value->_entity->get('date')->value;
      $unixstarttime = strtotime("{$event_start_date} -7 hours");
      $unixtotime = strtotime("{$event_end_date} -7 hours");
      $personType = $value->_relationship_entities['eventseries_id']->get('field_visitor_type')->value;
      $campus = $value->_relationship_entities['eventseries_id']->get('field_campus')->value;
      $overwrite_capacity = $value->_entity->get('field_overwrite_capacity')->value;
      $series_capacity = $value->_relationship_entities['eventseries_id']->get('field_capacity')->value;

      //ksm($series_capacity);
      $timeonly = $value->_relationship_entities['eventseries_id']->get('field_start_time_for_eventid')->value;
      $event_date_time = date("Y/m/d H:i:s", strtotime("{$event_start_date} -7 hours"));


      $just_date = date("Y-m-d", strtotime($event_start_date));
      $end_date_string = strtotime($event_end_date);
      $start_date_format = date("Y-m-d", strtotime("{$event_start_date} -7 hours"));
      //$start_time_format = date("F jS, Y", $date_string);
      $start_time_format = date("h:i a", strtotime("{$event_start_date} -7 hours"));
      $end_date_format = date("Y-m-d", strtotime("{$event_end_date} -7 hours"));
      $end_time_format = date("h:i a", strtotime("{$event_end_date} -7 hours"));


      $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $event_start_date, new DateTimeZone('UTC'));
      $date_obj->setTimeZone(new DateTimeZone('America/Phoenix'));
      $dateonly = $date_obj->format('Y-m-d');
      $display_title = $value->_relationship_entities['eventseries_id']->get('field_display_title')->value;
      if($timeonly != '') {

        // Get the timestamp for the date at 0 o'clock.
        if(strpos($dateonly, '-') == false) {
          $date_obj = DateTime::createFromFormat("Ymd\TH:i:s", $dateonly . 'T00:00:00', new DateTimeZone('America/Phoenix'));
        } else {
          $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $dateonly . 'T00:00:00', new DateTimeZone('America/Phoenix'));
        }
        $timestamp_at0oclock = $date_obj->getTimestamp();
        // Combine timestamp value at 0 o'clock and Time only field value
        $timestamp_for_eventid = $timestamp_at0oclock + intval($timeonly);
        $ret_value = $timestamp_for_eventid;

      } else {
        $ret_value = $timestamp_actualtour;
      }
      $event_id = $entity_series_id.'-'.$ret_value;
      //ksm($event_id);
      //ksm($entity_series_id);
//			ksm($ret_value);
      $persontype_no_space = str_replace(' ','-',$personType);
      $database = \Drupal::database();
      $nquery = $database->select('node__field_student_event_id', 'sei');
