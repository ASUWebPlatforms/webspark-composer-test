/* helper added by Archana function to get total registrant */
function _get_sundevilregistrant_count($event_id){
	/* code to query the students registartnts content to get count of sun devil day registrants and their guests */
			$database = \Drupal::database();
            $nquery = $database->select('node__field_student_event_id', 'sei');
            $nquery->fields('sei', ['entity_id']);
            $nquery->condition('sei.field_student_event_id_value', $event_id,'=');
            $nresult = $nquery->execute();
            foreach($nresult as $ndata){
                $nid[$ndata->entity_id] = $ndata->entity_id;
            }
            if(!empty($nid)){

                $gquery = $database->select('node__field_student_guests', 'fsg');
                $gquery->fields('fsg', ['field_student_guests_value']);
                $gquery->condition('fsg.entity_id', $nid,'IN');
                $gresult = $gquery->execute();
                foreach($gresult as $gdata){
                    $guests[] = $gdata->field_student_guests_value;
                }

                $total_registratnts = count($nid) + array_sum($guests);
            }
            else{
                $total_registratnts = 0;
            }
	return $total_registratnts;
}


function asuaec_visit_preprocess_views_view_table__new_sun_devil_days_v2__block_6(&$variables){
  $view = $variables['view'];
  if($view->id() != 'new_sun_devil_days_v2') {
    return;
  }
  $view->element['#attached']['library'][] = 'asuaec_visit/sundevilJsLib';

  $rows = $variables['rows'];
  foreach ($rows as $id => $row) {
//    ksm($id, "id"); // Serial number from 0

//    if($eventinstance_id == '6313') {
//      ksm($rows[$id]['columns'], "rows id columns");
//      \Drupal::logger('visit')->notice("rows id columns:<pre>" . print_r($rows[$id]['columns'], true) . "</pre>");
//    }

    // Event instance id
    $eventinstance_id = trim(strip_tags($rows[$id]['columns']['id']['content'][0]['field_output']['#markup']->__toString()));
    // Event series id
    //$eventseries_id = trim(strip_tags($rows[$id]['columns']['eventseries_id']['content'][0]['field_output']['#markup']->__toString())); //<---This was empty when not logged in and resulted in error. Added a different View field to get event series id.
    $eventseries_id = trim(strip_tags($rows[$id]['columns']['id_1']['content'][0]['field_output']['#markup']->__toString()));
    // Person type
    $personType = trim(strip_tags($rows[$id]['columns']['field_visitor_type_1']['content'][0]['field_output']['#markup']->__toString()));
    $persontype_no_space = preg_replace('/\s+/', '', $personType);
    // Event type
    $etype = trim(strip_tags($rows[$id]['columns']['field_evtype']['content'][0]['field_output']['#markup']->__toString()));

    // Start timestamp
    $startend_timestamp = trim(strip_tags($rows[$id]['columns']['date__value_1']['content'][0]['field_output']['#markup']->__toString()));
    $temp_array = explode('-',  preg_replace('/\s+/', '', $startend_timestamp));
    $unixstarttime = trim($temp_array[0]);
    $unixtotime = trim($temp_array[1]);

    // Event id = series id + unix start time
    $event_id = $eventseries_id . '-' . $unixstarttime;

    // Display time
    $datetime = new DateTime();
    $datetime->setTimestamp($unixstarttime);
    $datetime->setTimezone(new DateTimeZone('America/Phoenix'));
    $event_date_time = $datetime->format('Y/m/d H:i:s'); // Adjust the format as needed

    // Just date
    $just_date = $datetime->format('Y-m-d');

    // Time
    $start_time_format = $datetime->format('h:i a');

    $datetime2 = new DateTime();
    $datetime2->setTimestamp($unixtotime);
    $datetime2->setTimezone(new DateTimeZone('America/Phoenix'));
    $end_time_format = $datetime2->format('h:i a');

    // Campus
    $campus = trim(strip_tags($rows[$id]['columns']['field_campus']['content'][0]['field_output']['#markup']->__toString()));
    // Display title
    $display_title = trim(strip_tags($rows[$id]['columns']['field_display_title']['content'][0]['field_output']['#markup']->__toString()));

    // Prepare variables to be used in Views template: views-view-table--new-sun-devil-days-v2--block-6.html.twig
    $variables['register_href'][$id] = "/registration-form?eid=$event_id&seriesid=$eventseries_id&etype=$etype&dt=$event_date_time&from=$start_time_format&to=$end_time_format&ts=$unixstarttime&ts2=$unixtotime&date=$just_date&instid=$eventinstance_id&campus=$campus&int=y&ptype=y&c-aid=null&c-eid=null";

    $variables['register_btn_name'][$id] = "$personType|$etype|$unixstarttime|$unixtotime|$display_title|$campus|$start_time_format|$end_time_format";

    $variables['register_btn_class'][$id] = "btn btn-maroon sundevil-btn register-btn-{$event_id}{$persontype_no_space}";


    //--------------Capacity for Visit event and top-level Barrett tour----------------//
    $variables['capacity'][$id] = 'not_full';
    // Get capacity to use -- If capacity is overwriten use capacity from Event instance. Otherwise, use capacity from Event series.

    // Load the series entity
    $entity_type_eventseries = 'eventseries';
    $entity_id_eventseries = $eventseries_id;
    $entity_eventseries  = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);

    // Load the instance entity
    $entity_type_eventinstance = 'eventinstance';
    $entity_id_eventinstance = $eventinstance_id;
    $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);

    $capacity = _get_capacity_to_use($entity_eventseries, $entity_eventinstance);
//    if($eventinstance_id == '6313') {
//      ksm($capacity, "capacity");
//    }
    // Get how many people registered for the event here
    // $event_start_date in 2023-05-17T15:00:00 format. It is in UTC.
    $datetime3 = new DateTime();
    $datetime3->setTimestamp($unixstarttime);
    $datetime3->setTimezone(new DateTimeZone('UTC'));
    $event_start_date = $datetime3->format('Y-m-d\TH:i:s');
//    if($eventinstance_id == '6313') {
//      ksm($event_start_date, "event_start_date in UTC");
//    }
    $registrant_count = _get_registrant_count($eventseries_id, null, null, $event_start_date);
//    if($eventinstance_id == '6313') {
//      ksm($registrant_count, "registrant_count");
//    }

    if($capacity != '') {
      if ($registrant_count >= $capacity) { // Already full.
        // Remove the row
        //unset($variables['rows'][$id]); // Remove a row

        // Registration closed
        $variables['capacity'][$id] = 'full';

        continue; // Go to next iteration.
      }
    }
    // --------------END OF Capacity----------------//

    // --------------Privacy------------------------//
    $privacy = trim(strip_tags($rows[$id]['columns']['field_privacy']['content'][0]['field_output']['#markup']->__toString()));
    if($privacy == 'Coming soon') {
      $variables['privacy'][$id] = 'coming_soon';
    } else if($privacy == 'Registration closed') {
      $variables['privacy'][$id] = 'registration_closed';
    }





  } // END OF foreach ($rows as $id => $row) {
} // END OF function asuaec_visit_preprocess_views_view_table__new_sun_devil_days__block_6(&$variables)


function asuaec_visit_preprocess_views_view_table__new_sun_devil_days_v3(&$variables){
  $view = $variables['view'];
  if($view->id() != 'new_sun_devil_days_v3') {
    return;
  }
  $view->element['#attached']['library'][] = 'asuaec_visit/sundevilJsLib';

  $rows = $variables['rows'];
  foreach ($rows as $id => $row) {
    // --------------Test mode------------------------//
    $test_mode = trim(strip_tags($rows[$id]['columns']['field_test_mode']['content'][0]['field_output']['#markup']->__toString()));
    $roles = \Drupal::currentUser()->getRoles();
    if ($test_mode === 'On') {
      if(!(in_array('visit_admin', $roles) || in_array('administrator', $roles) || in_array('site_builder', $roles))) { // Anonymous user
        unset($variables['rows'][$id]); // Remove a row
        continue;
      }
    }
    // --------------END OF Test mode-----------------//

    // Event instance id
    $eventinstance_id = trim(strip_tags($rows[$id]['columns']['id']['content'][0]['field_output']['#markup']->__toString()));
    // Event series id
    //$eventseries_id = trim(strip_tags($rows[$id]['columns']['eventseries_id']['content'][0]['field_output']['#markup']->__toString())); //<---This was empty when not logged in and resulted in error. Added a different View field to get event series id.
    $eventseries_id = trim(strip_tags($rows[$id]['columns']['id_1']['content'][0]['field_output']['#markup']->__toString()));
    // Person type
//    $personType = trim(strip_tags($rows[$id]['columns']['field_visitor_type_1']['content'][0]['field_output']['#markup']->__toString()));
//    $persontype_no_space = preg_replace('/\s+/', '', $personType);
    // Event type
    $etype = trim(strip_tags($rows[$id]['columns']['field_evtype']['content'][0]['field_output']['#markup']->__toString()));

    $display_title = trim(strip_tags($rows[$id]['columns']['field_display_title']['content'][0]['field_output']['#markup']->__toString())); // Added on 4/3/2026

    // Start timestamp
    $startend_timestamp = trim(strip_tags($rows[$id]['columns']['date__value_1']['content'][0]['field_output']['#markup']->__toString()));
    $temp_array = explode('-',  preg_replace('/\s+/', '', $startend_timestamp));
    $unixstarttime = trim($temp_array[0]);
    $unixtotime = trim($temp_array[1]);


    // Display time
    $datetime = new DateTime();
    $datetime->setTimestamp($unixstarttime);
    $datetime->setTimezone(new DateTimeZone('America/Phoenix'));
    $event_date_time = $datetime->format('Y/m/d H:i:s'); // Adjust the format as needed

    // Just date
    $just_date = $datetime->format('Y-m-d');

    // Time
    $start_time_format = $datetime->format('h:i a');

    $datetime2 = new DateTime();
    $datetime2->setTimestamp($unixtotime);
    $datetime2->setTimezone(new DateTimeZone('America/Phoenix'));
    $end_time_format = $datetime2->format('h:i a');

    // Get timestamp for Event id
    $starttime_for_eventid = trim(strip_tags($rows[$id]['columns']['field_start_time_for_eventid']['content'][0]['field_output']['#markup']->__toString()));
//    ksm($starttime_for_eventid, "starttime_for_eventid"); // 09:00 am

    $newDateTime = DateTime::createFromFormat("Y-m-d h:i a", $just_date . '' . $starttime_for_eventid, new DateTimeZone('America/Phoenix'));
    $timestamp_for_eventid = $newDateTime->getTimestamp();
//    ksm($timestamp_for_eventid, "timestamp_for_eventid");

    // Event id = series id + timestamp for Event id
//    $event_id = $eventseries_id . '-' . $unixstarttime;
    $event_id = $eventseries_id . '-' . $timestamp_for_eventid;

    // Campus
    $campus = trim(strip_tags($rows[$id]['columns']['field_campus']['content'][0]['field_output']['#markup']->__toString()));
    // Display title
    $display_title = trim(strip_tags($rows[$id]['columns']['field_display_title']['content'][0]['field_output']['#markup']->__toString()));

    // Prepare variables to be used in Views template: views-view-table--new-sun-devil-days-v2--block-6.html.twig
    // Switched to /registration-form-v2 on 4/3/2026.
    // Needed to add the display title on 4/3/2026.
    $variables['register_href'][$id] = "/registration-form-v2?eid=$event_id&seriesid=$eventseries_id&etype=$etype&dt=$event_date_time&from=$start_time_format&to=$end_time_format&ts=$unixstarttime&ts2=$unixtotime&date=$just_date&instid=$eventinstance_id&campus=$campus&displaytitle=$display_title&intlist=y&ptypelist=y&c-aid=null&c-eid=null";

//    $variables['register_btn_name'][$id] = "$personType|$etype|$unixstarttime|$unixtotime|$display_title|$campus|$start_time_format|$end_time_format";
    $variables['register_btn_name'][$id] = "noptype|$etype|$unixstarttime|$unixtotime|$display_title|$campus|$start_time_format|$end_time_format";

//    $variables['register_btn_class'][$id] = "btn btn-maroon sundevil-btn register-btn-{$event_id}{$persontype_no_space}";
//    $variables['register_btn_class'][$id] = "btn btn-maroon btn-sm sundevil-btn register-btn-{$event_id}noptype";
    $variables['register_btn_class'][$id] = "btn btn-maroon sundevil-btn register-btn-{$event_id}noptype";



    //--------------Capacity for Visit event and top-level Barrett tour----------------//
    $variables['capacity'][$id] = 'not_full';
    // Get capacity to use -- If capacity is overwriten use capacity from Event instance. Otherwise, use capacity from Event series.

    // Load the series entity
    $entity_type_eventseries = 'eventseries';
    $entity_id_eventseries = $eventseries_id;
    $entity_eventseries  = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);

    // Load the instance entity
    $entity_type_eventinstance = 'eventinstance';
    $entity_id_eventinstance = $eventinstance_id;
    $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);

    $capacity = _get_capacity_to_use($entity_eventseries, $entity_eventinstance);
//    if($eventinstance_id == '6313') {
//      ksm($capacity, "capacity");
//    }
    // Get how many people registered for the event here
    // $event_start_date in 2023-05-17T15:00:00 format. It is in UTC.
    $datetime3 = new DateTime();
    $datetime3->setTimestamp($unixstarttime);
    $datetime3->setTimezone(new DateTimeZone('UTC'));
    $event_start_date = $datetime3->format('Y-m-d\TH:i:s');
//    if($eventinstance_id == '6313') {
//      ksm($event_start_date, "event_start_date in UTC");
//    }
    $registrant_count = _get_registrant_count($eventseries_id, null, null, $event_start_date);
//    if($eventinstance_id == '6313') {
//      ksm($registrant_count, "registrant_count");
//    }

    if($capacity != '') {
      if ($registrant_count >= $capacity) { // Already full.
        // Remove the row
        //unset($variables['rows'][$id]); // Remove a row

        // Registration closed
        $variables['capacity'][$id] = 'full';

        continue; // Go to next iteration.
      }
    }
    // --------------END OF Capacity----------------//

    // --------------Privacy------------------------//
    $privacy = trim(strip_tags($rows[$id]['columns']['field_privacy']['content'][0]['field_output']['#markup']->__toString()));
    if($privacy == 'Coming soon') {
      $variables['privacy'][$id] = 'coming_soon';
    } else if($privacy == 'Registration closed') {
      $variables['privacy'][$id] = 'registration_closed';
    }





  } // END OF foreach ($rows as $id => $row)
} // END OF function asuaec_visit_preprocess_views_view_table__new_sun_devil_days_v3(&$variables)







/**
 * @param $entity_id_eventseries
 * @param $entity_id_eventinstance
 * @return string
 * Returns 'open' or 'full'.
 *
 * This is for Barrett under Exp ASU.
 * Called from _check_barrett_event_is_happening().
 */
function _check_capacity($entity_id_eventseries, $entity_id_eventinstance) {
    $ret_value = 'open';

    //--------------Capacity for Visit event and top-level Barrett tour----------------//

    $entity_type_eventseries = 'eventseries';
    $entity_eventseries  = \Drupal::entityTypeManager()->getStorage($entity_type_eventseries)->load($entity_id_eventseries);

    // Load the instance entity
    $entity_type_eventinstance = 'eventinstance';
    $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);

    // Get capacity to use -- If capacity is overwriten use capacity from Event instance. Otherwise, use capacity from Event series.
    $capacity = _get_capacity_to_use($entity_eventseries, $entity_eventinstance);

    // Get start time in 2023-05-17T15:00:00 format -- If start time is overwriten use start time from Event instance. Otherwise, use start time from Event series.
    $starttime = _get_starttime_to_use($entity_eventinstance); // TODO: need to test!

    // Get how many people registered for the event here
    $registrant_count = _get_registrant_count($entity_id_eventseries, null, null, $starttime );
//    ksm($registrant_count, "registrant_count - _check_capacity");

    if($capacity != '') {
        if ($registrant_count >= $capacity) { // Already full.
            $ret_value = 'full';
        }
    }
    // --------------END OF Capacity----------------//

    // ret_value: open or full
    return $ret_value;
}


/**
 * @param $date // In yyyymmdd format
 * @param $event_series_id
 * @return mixed
 *
 * Returns Barrett event instance id from date and top-level Barret Event series id.
 * Called from VisitBevformHndler.php at line 829.
 */
function _get_barrett_eventinstanceid_from_date_and_eventseriesid($date, $event_series_id) {
    $barrett_instance_id = '';
    // Load View4: Barrett find Event instance id from entity id and date
    $view4 = \Drupal\views\Views::getView('barrett_find_event_instance_id_from_entity_id_and_date');
    $view4->setDisplay('default');
    $view4->setArguments([$date, $event_series_id]); // Date in yyyymmdd format
    $view4->execute();

    // Get the results of the Additional tours view.
    $view4_result = $view4->result;
//    ksm($view4_result, "view4_result");

    $barrett_instance_id_array = [];
//    $barrett_eventseries_ids_array = [];
//    $barrett_array = [];
    foreach ($view4_result as $row) {
        $theid = $row->_entity->id();
//        ksm($theid, "theid");
        array_push($barrett_instance_id_array, $theid);
//        ksm($barrett_instance_id_array, "barrett_instance_id_array inside foreach"); // 313
    }
//    ksm($barrett_instance_id_array, "barrett_instance_id_array"); // 313
    $barrett_instance_id = $barrett_instance_id_array[0];
    return $barrett_instance_id;
}


/**
 * @param string $date in yyyymmdd format
 *
 * @return boolean
 * Returns true if $barrett_entity_id is included in Barrett tours that is happening on the day AND capacity is not full.
 * Returns false if $barrett_entity_id is not happening on the day OR $barrett_entity_id is included in Barrett tours that is happening on the day, but capacity full.
 *
 * Called from _prepare_output_barrett().
 */
function _check_barrett_event_is_happening($date, $barrett_entity_id) { // $date is in yyyymmdd format
    $ret_value = false;
    // Load View3: Barrett tour check
    $view3 = \Drupal\views\Views::getView('barrett_tour_check');
//            $view2->setArguments($parent_id); // Parent id
    $view3->setArguments([$date]); // Date in yyyymmdd format
    $view3->setDisplay('default');
    $view3->execute();
    // Get the results of the Additional tours view.
    $view3_result = $view3->result;

//    $barrett_instance_id_array = [];
    $barrett_eventseries_ids_array = [];
    $barrett_array = [];
    foreach ($view3_result as $row) {
        $theid = $row->_entity->id();
//        array_push($barrett_instance_id_array, $theid);
        array_push($barrett_eventseries_ids_array, _get_eventseries_id($theid));
        $barrett_array += [_get_eventseries_id($theid) => $theid]; // This is to look up Instance ID from Series ID
    }
//    ksm($barrett_instance_id_array, "barrett_tour_instance_id_array"); // 334
//    ksm($barrett_eventseries_id_array, "barrett_eventseries_id_array"); // 18
//    ksm($barrett_array, "barrett_array");

    // $barrett_eventseries_ids_array contains the Barrett series ids that is happening on the day.
    // See if $barrett_entity_id is included in $barrett_eventseries_ids_array
    if(in_array($barrett_entity_id, $barrett_eventseries_ids_array)) {
        if(_check_capacity($barrett_entity_id, $barrett_array[$barrett_entity_id]) == 'open') { // $barrett_array[$barrett_entity_id] contains Instance ID.
            $ret_value = true;
        } else { // When _check_capacity() returns 'full'
            $ret_value = false;
        }
    } else {
        $ret_value = false;
    }
//    return $barrett_eventseries_ids_array; // 451 and 449 -- 449 is top level Barrett on 5/24. 451 ise the Barrett under Exp ASU.
    return $ret_value;
}


/**
 * @param array $barrett_entity_ids_array
 *
 * @param string $thedate_clicked
 *
 * @return string $output_barrett
 *
 * Helping function
 * Iterate view2's result and return html output for Barrett tour under Experience ASU.
 *
 * Calls function _check_barrett_event_is_happening(), and then, _check_barrett_event_is_happening function calls _check_capacity() function to check capacity.
 */
function _prepare_output_barrett($barrett_entity_ids_array, $thedate_clicked, $barrett_under_expasu = true) { // This is only for Barrett under Experience ASU. So, $barrett_under_expasu is always passed true.
    $output_barrett = '';
    // Load Barrett Event series entity to get title and time
    foreach($barrett_entity_ids_array as $barrett_entity_id) {

        // Compare and check if the Barrett event is happening. _check_barrett_event_is_happening() also checks capacity.
        if(_check_barrett_event_is_happening($thedate_clicked, $barrett_entity_id)) {

            $entity_type_barrett = 'eventseries';
            $entity_id_barrett = $barrett_entity_id;
            $entity_barrett = \Drupal::entityTypeManager()->getStorage($entity_type_barrett)->load($entity_id_barrett);
            $barrett_display_title = $entity_barrett->get('field_display_title')->getValue()[0]['value'];
            $barrett_display_title_html = '<div><strong>' . $entity_barrett->get('field_display_title')->getValue()[0]['value'] . '</strong>(optional)</div>';

            // Get type - Added on 9/28/2023.
            $barrett_evtype = $entity_barrett->get('field_evtype')->getValue()[0]['value'];
//            ksm($barrett_evtype, "barrett_evtype");

            // Get instance
            // Load the instance entity
            $entity_id_eventinstance = _get_barrett_eventinstanceid_from_date_and_eventseriesid($thedate_clicked, $entity_id_barrett);
            $entity_type_eventinstance = 'eventinstance';
            $entity_eventinstance = \Drupal::entityTypeManager()->getStorage($entity_type_eventinstance)->load($entity_id_eventinstance);

            //----------- Get Barrett actual start and end time ------------------//
            // Need to check if time was overwritten for the Barrett under Exp ASU. So, use date/time from Event instance.

            // Let's look at instance
            // Start time
            $start_time_string = $entity_eventinstance->get('date')->getValue()[0]['value']; // 2023-07-19T14:00:00
//            date_default_timezone_set('UTC'); //<--Don't use this!
            $date_obj = DateTime::createFromFormat("Y-m-d\TH:i:s", $start_time_string, new DateTimeZone('UTC'));
            $date_obj->setTimeZone(new DateTimeZone('America/Phoenix'));
//            ksm($date_obj, "date_obj");
            $date_formatted = $date_obj->format('g:i a');
//            ksm($date_formatted, "date_formatted"); // 7:00 am AZ time
            // Get actual Start timestamp
            $start_timestamp = $date_obj->getTimestamp();

            // End time
            $end_time_string = $entity_eventinstance->get('date')->getValue()[0]['end_value']; // 2023-07-19T15:30:00
            $date_obj2 = DateTime::createFromFormat("Y-m-d\TH:i:s", $end_time_string, new DateTimeZone('UTC'));
            $date_obj2->setTimeZone(new DateTimeZone('America/Phoenix'));
//            ksm($date_obj2, "date_obj2");
            $date_formatted2 = $date_obj2->format('g:i a');
//            ksm($date_formatted2, "date_formatted 2"); // 7:00 am AZ time
            // Get actual End timestamp
            $end_timestamp = $date_obj2->getTimestamp();

            //----------- Timestamp that we can use for event id which we calculate using the Time only field in Event series entity ---------------//
            // $start_timestamp is just for backup in case Original time is empty.
            $timestamp_for_eventid = _get_timestamp_for_eventid($entity_id_barrett, $thedate_clicked, $start_timestamp);
            //----------- END OF Timestamp that we can use for event id which we calculate using the Time only field in Event series entity ---------------//

            if($barrett_under_expasu == true) {
                $barrett_css_class = "barrett-tour-under-expasu mb-2";
                $barrett_input_name = "event-barrett-under-expasu";
            } else {
                $barrett_css_class = "barrett-tour";
                $barrett_input_name = "event-barrett";
            }

            // NOTES:
            // $start_timestamp -- Actual start timestamp for Barrett tour under Exp ASU
            // $timestamp_for_eventid -- Original start time that was calculated using Time only field and the date clicked.

            // Radio button version
//            $output_barrett .= '<div class="' . $barrett_css_class . '">' . $barrett_display_title_html  . '<input class="ml-1" type="radio" name="' . $barrett_input_name . '" value="' . $barrett_entity_id . '-' . $timestamp_for_eventid . "|" . $start_timestamp . "|" . $end_timestamp . "|" . $barrett_display_title . '" > ' . _format_time_webstandard($thedate_clicked, $date_formatted) . ' &mdash; ' . _format_time_webstandard($thedate_clicked, $date_formatted2) . '</div>';

            $barrett_info_tool_tip = '';
            if($barrett_evtype == "Barrett tour") {
                // Add tooltip for Barrett - Added on 9/27/2023.
                $barrett_tip_data = "<p>Established in 1988, Barrett has been recognized as the \"gold standard\" among honors colleges in the nation. An undergraduate student can be engaged in the Barrett experience at any of ASU’s four metropolitan Phoenix campuses.</p>";
                $barrett_info_tool_tip = '<div class="ml-1 custom-tooltip"><div class="custom-tooltip-container-acadsessions"><button tabindex="0" class="uds-tooltip uds-tooltip-button uds-tooltip-dark" aria-describedby="tooltip-desc-1"><span class="fa-stack"><svg class="campus-svg svg-inline--fa fa-circle fa-w-16 fa-stack-2x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="circle" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="#8c1d40" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg><svg class="svg-inline--fa fa-info fa-w-6 fa-stack-1x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="info" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 512" data-fa-i2svg=""><path fill="#ffffff" d="M20 424.229h20V279.771H20c-11.046 0-20-8.954-20-20V212c0-11.046 8.954-20 20-20h112c11.046 0 20 8.954 20 20v212.229h20c11.046 0 20 8.954 20 20V492c0 11.046-8.954 20-20 20H20c-11.046 0-20-8.954-20-20v-47.771c0-11.046 8.954-20 20-20zM96 0C56.235 0 24 32.235 24 72s32.235 72 72 72 72-32.235 72-72S135.764 0 96 0z"></path></svg></span></button><div role="tooltip" class="custom-tooltip-description" id="tooltip-desc-1"><button style="color:#fff;" type="button" class="btn btn-default popup-close-btn"><svg class="svg-inline--fa fa-window-close fa-w-16" aria-hidden="true" focusable="false" data-prefix="fa" data-icon="window-close" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="currentColor" d="M464 32H48C21.5 32 0 53.5 0 80v352c0 26.5 21.5 48 48 48h416c26.5 0 48-21.5 48-48V80c0-26.5-21.5-48-48-48zm-83.6 290.5c4.8 4.8 4.8 12.6 0 17.4l-40.5 40.5c-4.8 4.8-12.6 4.8-17.4 0L256 313.3l-66.5 67.1c-4.8 4.8-12.6 4.8-17.4 0l-40.5-40.5c-4.8-4.8-4.8-12.6 0-17.4l67.1-66.5-67.1-66.5c-4.8-4.8-4.8-12.6 0-17.4l40.5-40.5c4.8-4.8 12.6-4.8 17.4 0l66.5 67.1 66.5-67.1c4.8-4.8 12.6-4.8 17.4 0l40.5 40.5c4.8 4.8 4.8 12.6 0 17.4L313.3 256l67.1 66.5z"></path></svg></button><div class="formatted-text">' . $barrett_tip_data . '</div></div></div></div>';

            } else {
            }

            // Checkbox verson
//            $output_barrett .= '<div class="' . $barrett_css_class . '">' . $barrett_display_title_html  . '<input class="ml-1" type="checkbox" name="' . $barrett_input_name . '" value="' . $barrett_entity_id . '-' . $timestamp_for_eventid . "|" . $start_timestamp . "|" . $end_timestamp . "|" . $barrett_display_title . '" > ' . _format_time_webstandard($thedate_clicked, $date_formatted) . ' &mdash; ' . _format_time_webstandard($thedate_clicked, $date_formatted2) . '</div>';

            $output_barrett .= '<div class="' . $barrett_css_class . '">' . $barrett_display_title_html  . '<input class="ml-1" type="checkbox" name="' . $barrett_input_name . '" value="' . $barrett_entity_id . '-' . $timestamp_for_eventid . "|" . $start_timestamp . "|" . $end_timestamp . "|" . $barrett_display_title . '" > ' . _format_time_webstandard($thedate_clicked, $date_formatted) . ' &mdash; ' . _format_time_webstandard($thedate_clicked, $date_formatted2) . $barrett_info_tool_tip . '</div>';


            // TODO: Place it in array in order to sort chronologically


        } // END OF if(in_array($barrett_entity_id, $barrett_eventseries_ids_array))
    } // END OF foreach($barrett_entity_ids_array as $barrett_entity_id)

    return $output_barrett;
}


/**
 * @param $entity_paragraph
 * @param $thedate_clicked // In yyyymmdd format
 * @param $eventseries_entity_id
 * @param $addtour_paragraph_entity_id
 * @return string
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 *
 * Called from _prepare_output_addtours().
 * Returns "open" or "full".
 * When Start time for entity ID is missing, returns full.
 */
function _check_capacity_for_addtour($entity_paragraph, $thedate_clicked, $eventseries_entity_id, $addtour_paragraph_entity_id) {
    $retVavlue = 'open';

    // STEP 1: Get Additional tour top-level capacity
    $capacity = $entity_paragraph->get('field_capacity')->getValue() != null ? $entity_paragraph->get('field_capacity')->getValue()[0]['value'] : '';
//        ksm($capacity, "capacity addtour top level"); // <-- Additional tour top-level capacity

    // STEP 2: Get boolean value for capacity overwrite
    $capacity_overwrite_bool = $entity_paragraph->get('field_overwrite_capacity_addtour')->getValue() != null ? $entity_paragraph->get('field_overwrite_capacity_addtour')->getValue()[0]['value'] : '';
//        ksm($capacity_overwrite_bool, "capacity_overwrite_bool");

    // STEP 3: Get capacity to use
    // NOTES: Include code for overwrite
    // Check if the overwrite checkbox (field_overwrite_capacity_addtour) is checked.
    // If checked, iterate Capacity set (Date and capacity) and use the one with the correct date.

    $capacity_to_use = $capacity;
    if($capacity_overwrite_bool == '1') {
        $capacity_overwrite_para_ids = $entity_paragraph->get('field_capacity_overwrite_para')->getValue() != null ? $entity_paragraph->get('field_capacity_overwrite_para')->getValue() : ''; // 329
//        ksm($capacity_overwrite_para_ids, "capacity_overwrite_para test");

        foreach($capacity_overwrite_para_ids as $overwrite_para) {

            $overwrite_para_id = $overwrite_para['target_id'];
//            ksm($capacity_overwrite_para_id, "capacity_overwrite_para_id");

            // Load capacity overwrite paragraph using Paragraph ID
            $entity_type_overwrite = 'paragraph';
            $entity_id_overwrite = $overwrite_para_id;
            $entity_paragraph_overwrite = \Drupal::entityTypeManager()->getStorage($entity_type_overwrite)->load($entity_id_overwrite);
//            ksm($entity_paragraph_capoverwrite, "entity_paragraph_capoverwrite");

            // Get Capacity overwrite -> Date (Overwritten date)
            $date_overwrite = $entity_paragraph_overwrite->get('field_date_only')->getValue() != null ? $entity_paragraph_overwrite->get('field_date_only')->getValue()[0]['value'] : ''; // 2023-06-13
//            ksm($date_capoverwrite, "date_capoverwrite"); // 2023-06-13, 2023-06-02
            $date_overwrite_nodash_str = str_replace("-","",$date_overwrite);
//            ksm($date_capoverwrite_nodash_str, "date_capoverwrite_nodash string");

            // Get date clicked
//            ksm($thedate_clicked, "thedate_clicked"); // 20230613
            if($date_overwrite_nodash_str == $thedate_clicked) { // If date matches
                // Get Capacity overwrite -> Capacity (Overwritten capacity).
                $capacity_overwrite = $entity_paragraph_overwrite->get('field_capacity')->getValue() != null ? $entity_paragraph_overwrite->get('field_capacity')->getValue()[0]['value'] : '';
//                ksm($capacity_capoverwrite, "capacity_capoverwrite"); // 50
                $capacity_to_use = $capacity_overwrite;
            }

        } // END OF foreach
    } // END OF if($capacity_overwrite_bool == '1')
//    ksm($capacity_to_use, "capacity_to_use");


    // STEP 4: Get how many people registered for the Additional tour

    // Get timestamp for Additional tour ID
//            ksm($entity_paragraph, "entity_paragraph");
    // NOTES: Instead of $entity_paragraph->get('field_time_range')->getValue()[0]['from'], we need to use field_start_time_for_addtourid field value.
//    $time_range_from = $entity_paragraph->get('field_time_range')->getValue()[0]['from'];
    //        ksm($time_range_from, "time_range_from"); // 57600

    $start_time_for_addtourid = '';
    if($entity_paragraph->hasField('field_start_time_for_addtourid') == true && $entity_paragraph->get('field_start_time_for_addtourid')->getValue() != false) {
        $start_time_for_addtourid = $entity_paragraph->get('field_start_time_for_addtourid')->getValue()[0]['value'];
//        ksm($start_time_for_addtourid, "start_time_for_addtourid - _check_capacity_for_addtour()");
    }
    if($start_time_for_addtourid == '') {
        \Drupal::logger('visit')->notice("Start time for additional tour ID has to be entered for Event series ID:" . $eventseries_entity_id);
        return 'full';
    }
    $datenew = DateTime::createFromFormat("Ymd g:i a", $thedate_clicked . "00:00 am");
    $timestamp_ofthedateat0am = $datenew->getTimestamp(); // Timestamp of the date at 0:00am
//    $timestamp_datetime_start = $timestamp_ofthedateat0am + $time_range_from; // Add timestamp of the date at 0:00am and timestamp for the event time.
    $timestamp_for_addtourid = $timestamp_ofthedateat0am + intval($start_time_for_addtourid); // Add timestamp of the date at 0:00am and timestamp for the event time.

    // Get Additional tour ID ex. 1-1-1686672000 (Parent Event series id + Paragraph id + starttime)
//    $addtour_id = $eventseries_entity_id . '-' . $addtour_paragraph_entity_id . '-' . $timestamp_datetime_start;
    $addtour_id = $eventseries_entity_id . '-' . $addtour_paragraph_entity_id . '-' . $timestamp_for_addtourid;
//            ksm($addtour_id, "addtour_id"); // ex. 1-328-1686697200, 1-6-1686668400


    // Get how many people already registered for the Additional tour
    // Count Additional tour registrant node.
    // DB
    $nodeStorage = \Drupal::entityTypeManager()->getStorage('node');
    $ids = $nodeStorage->getQuery()
        ->accessCheck(FALSE)
        ->condition('type', 'additional_tour_registrant') // type = bundle id (machine name)
        ->condition('field_additional_tour_id', $addtour_id, '=')
        ->execute();

    $addtourreg_nodes = $nodeStorage->loadMultiple($ids);
    //    ksm($student_registered_nodes, "student_registered_nodes");
    // Registrant count
    $registrant_count = sizeof($addtourreg_nodes);
    //    ksm($registrant_count, "registrant_count new");

    // Guest count
    $guest_count = 0;
    foreach ($addtourreg_nodes as $nid => $node) {
        $field_student_guests_array = $node->get('field_student_guests')->getValue();
        //        ksm($field_student_guests_array, "field_student_guests");
        if(sizeof($field_student_guests_array) > 0) {
            $field_student_guests = $node->get('field_student_guests')->getValue()[0]['value'];
            $guest_count = $guest_count + $field_student_guests;
        }
    }
    // Put together registrant count and guest count
    $registrant_count = $registrant_count + $guest_count;
    //        ksm($registrant_count, "registrant_count"); // Correct!


    // STEP 5: Finally Compare registrant count with capacity to use
//    ksm($registrant_count, "registrant_count");
//    ksm($capacity_to_use, "capacity_to_use right before if");
    if($capacity_to_use != '') {
        if ($registrant_count >= $capacity_to_use) { // Already full.
            // Remove the row
//            continue; // Go to next iteration.
            $retVavlue = "full";
        }
    }
//    ksm($retVavlue, "retValue");
    return $retVavlue;
} // END OF function _check_capacity_for_addtour()


/**
 * @param $entity_paragraph
 * @param $thedate_clicked // In yyyymmdd format
 * @param $eventseries_entity_id
 * @param $addtour_paragraph_entity_id
 * @return mixed|string
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 *
 * Returns actual capacity to use.
 * Called from VisitWebformHandler.php at line 781.
 */
function _get_capacity_for_addtour($entity_paragraph, $thedate_clicked, $eventseries_entity_id, $addtour_paragraph_entity_id) {

    // STEP 1: Get Additional tour top-level capacity
    $capacity = $entity_paragraph->get('field_capacity')->getValue() != null ? $entity_paragraph->get('field_capacity')->getValue()[0]['value'] : '';
//        ksm($capacity, "capacity addtour top level"); // <-- Additional tour top-level capacity

    // STEP 2: Get boolean value for capacity overwrite
    $capacity_overwrite_bool = $entity_paragraph->get('field_overwrite_capacity_addtour')->getValue() != null ? $entity_paragraph->get('field_overwrite_capacity_addtour')->getValue()[0]['value'] : '';
//        ksm($capacity_overwrite_bool, "capacity_overwrite_bool");

    // STEP 3: Get capacity to use
    // NOTES: Include code for overwrite
    // Check if the overwrite checkbox (field_overwrite_capacity_addtour) is checked.
    // If checked, iterate Capacity set (Date and capacity) and use the one with the correct date.

    $capacity_to_use = $capacity;
    if($capacity_overwrite_bool == '1') {
        $capacity_overwrite_para_ids = $entity_paragraph->get('field_capacity_overwrite_para')->getValue() != null ? $entity_paragraph->get('field_capacity_overwrite_para')->getValue() : ''; // 329
//        ksm($capacity_overwrite_para_ids, "capacity_overwrite_para test");

        foreach($capacity_overwrite_para_ids as $overwrite_para) {

            $overwrite_para_id = $overwrite_para['target_id'];
//            ksm($capacity_overwrite_para_id, "capacity_overwrite_para_id");

            // Load capacity overwrite paragraph using Paragraph ID
            $entity_type_overwrite = 'paragraph';
            $entity_id_overwrite = $overwrite_para_id;
            $entity_paragraph_overwrite = \Drupal::entityTypeManager()->getStorage($entity_type_overwrite)->load($entity_id_overwrite);
//            ksm($entity_paragraph_capoverwrite, "entity_paragraph_capoverwrite");

            // Get Capacity overwrite -> Date (Overwritten date)
            $date_overwrite = $entity_paragraph_overwrite->get('field_date_only')->getValue() != null ? $entity_paragraph_overwrite->get('field_date_only')->getValue()[0]['value'] : ''; // 2023-06-13
//            ksm($date_capoverwrite, "date_capoverwrite"); // 2023-06-13, 2023-06-02
            $date_overwrite_nodash_str = str_replace("-","",$date_overwrite);
//            ksm($date_capoverwrite_nodash_str, "date_capoverwrite_nodash string");

            // Get date clicked
//            ksm($thedate_clicked, "thedate_clicked"); // 20230613
            if($date_overwrite_nodash_str == $thedate_clicked) { // If date matches
                // Get Capacity overwrite -> Capacity (Overwritten capacity).
                $capacity_overwrite = $entity_paragraph_overwrite->get('field_capacity')->getValue() != null ? $entity_paragraph_overwrite->get('field_capacity')->getValue()[0]['value'] : '';
//                ksm($capacity_capoverwrite, "capacity_capoverwrite"); // 50
                $capacity_to_use = $capacity_overwrite;
            }

        } // END OF foreach

    } // END OF if($capacity_overwrite_bool == '1')
//    ksm($capacity_to_use, "capacity_to_use");
    return $capacity_to_use;
} // END OF function _get_capacity_for_addtour()


/**
 * @param $entity_paragraph
 * @param $thedate_clicked
 * @param $eventseries_entity_id
 * @param $addtour_paragraph_entity_id
 * @return array
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 *
 * Returns array of ttimestamps:
 * - Actual start timestamp
 * - Actual end timestamp
 * - timestamp for addtour id
 *
 * Called from VisitWebformHandler.php at line 792.
 */
function _get_timestamps_for_addtour($entity_paragraph, $thedate_clicked, $eventseries_entity_id, $addtour_paragraph_entity_id) {

    // STEP 1: Get original Time range values in Event series
    $time_range_from = $entity_paragraph->get('field_time_range')->getValue()[0]['from']; // Added isset on 6/30/2023
    $time_range_to = $entity_paragraph->get('field_time_range')->getValue()[0]['to'];
//        $time_range_to = isset($entity_paragraph->get('field_time_range')->getValue()[0]['to']) ? $entity_paragraph->get('field_time_range')->getValue()[0]['to'] : ''; // Added isset on 6/30/2023
//        ksm($time_range_from, "time_range_from - original");
//        ksm($time_range_to, "time_range_to - original");

    // STEP 2: Get boolean value for Time range overwrite
    $timerange_overwrite_bool = $entity_paragraph->get('field_overwrite_time_addtour')->getValue() != null ? $entity_paragraph->get('field_overwrite_time_addtour')->getValue()[0]['value'] : '';
//        ksm($timerange_overwrite_bool, "timerange_overwrite_bool");

    // STEP 3: Get Time range to use
    $timerange_from_to_use = $time_range_from;
    $timerange_to_to_use = $time_range_to;
    if($timerange_overwrite_bool == '1') {
        $time_overwrite_para_ids = $entity_paragraph->get('field_time_overwrite_para')->getValue() != null ? $entity_paragraph->get('field_time_overwrite_para')->getValue() : ''; // 329
//            ksm($time_overwrite_para_ids, "time_overwrite_para_ids");

        foreach($time_overwrite_para_ids as $overwrite_para) {
            $overwrite_para_id = $overwrite_para['target_id'];
//                ksm($overwrite_para_id, "time_overwrite_para_id");

            // Load the time overwrite paragraph using Paragraph ID
            $entity_type_overwrite = 'paragraph';
            $entity_id_overwrite = $overwrite_para_id;
            $entity_paragraph_overwrite = \Drupal::entityTypeManager()->getStorage($entity_type_overwrite)->load($entity_id_overwrite);
//                ksm($entity_paragraph_overwrite, "entity_paragraph_overwrite");

            // Get Time range overwrite -> Date (Overwritten date) -- Which date when we need to overwrite
            $date_overwrite = $entity_paragraph_overwrite->get('field_date_only')->getValue() != null ? $entity_paragraph_overwrite->get('field_date_only')->getValue()[0]['value'] : ''; // 2023-06-13
//                ksm($date_overwrite, "date_timeoverwrite"); // 2023-06-13, 2023-06-02
            $date_overwrite_nodash_str = str_replace("-","",$date_overwrite);
//                ksm($date_overwrite_nodash_str, "date_overwrite_nodash_str");

            // Get date clicked
//                ksm($thedate_clicked, "thedate_clicked"); // 20230613
            if($date_overwrite_nodash_str == $thedate_clicked) { // If date matches
                // Get Time range overwrite -> Time range (Overwritten Time range).
                $timerange_overwrite_from = $entity_paragraph_overwrite->get('field_time_range')->getValue() != null ? $entity_paragraph_overwrite->get('field_time_range')->getValue()[0]['from'] : '';
                $timerange_overwrite_to = $entity_paragraph_overwrite->get('field_time_range')->getValue() != null ? $entity_paragraph_overwrite->get('field_time_range')->getValue()[0]['to'] : '';
//                    ksm($timerange_overwrite_from, "timerange_overwrite_from");
//                    ksm($timerange_overwrite_to, "timerange_overwrite_to");
                $timerange_from_to_use = $timerange_overwrite_from;
                $timerange_to_to_use = $timerange_overwrite_to;
            }
        } // END OF foreach
    } // END OF if($time_overwrite_bool == '1')

    //---------- END OF Additional tour Time range ------------//

    //---------- Prepare 3 timestamps: Actual start and end. Also, timestamp for addtour id ----------------------------------

    // NOTES: In addition to "Time range from", also grab Time field value. Need to use Time field value for Additional tour ID and for capacity counting.
    $time_for_addtourid = $entity_paragraph->get('field_start_time_for_addtourid')->getValue()[0]['value'];
//        ksm($time_for_addtourid, "time_for_addtourid");

    // Format time
    $datenew = DateTime::createFromFormat("Ymd g:i a", $thedate_clicked . "00:00 am", new DateTimeZone('America/Phoenix'));
    $timestamp_ofthedateat0am = $datenew->getTimestamp(); // Timestamp of the date at 0:00am
//                    ksm($datenew->format("Y/m/d g:i a"), "test"); // <--- GMT 12:00am
//                    ksm($timestamp_ofthedateat0am, "timestamp_ofthedateat0am");

    // Actual start time timestamp
    $timestamp_datetime_start = $timestamp_ofthedateat0am + $timerange_from_to_use; // Add timestamp of the date at 0:00am and timestamp for the event time.
    $timestamp_datetime_end = $timestamp_ofthedateat0am + $timerange_to_to_use;
    // Timestamp for Add tour ID
    $timestamp_for_addtourid = $timestamp_ofthedateat0am + $time_for_addtourid;

    $timestamp_array = array(
        'start' => $timestamp_datetime_start,
        'end' => $timestamp_datetime_end,
        'timestamp_for_addtourid' => $timestamp_for_addtourid,
    );

    return $timestamp_array;

} // END OF function _get_timestamps_for_addtour($entity_paragraph, $thedate_clicked, $eventseries_entity_id, $addtour_paragraph_entity_id)


/**
 * @param $addtour_paragraph_entity_ids_array
 * @param $collegesArrayBasedOnCat
 * @param $thedate_clicked
 * @param $eventseries_entity_id
 * @param $campus
 * @return array
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 *
 * Helping function
 * Iterate view2's result and return html output for additional tours (academic sessions)
 */
function _prepare_output_addtours($addtour_paragraph_entity_ids_array, $collegesArrayBasedOnCat, $thedate_clicked, $eventseries_entity_id,$campus) { //$campus added by Archana

    $addtour_array_collegesession = [];
    $addtour_array_housingtour = [];

    foreach($addtour_paragraph_entity_ids_array as $addtour_paragraph_entity_id) {

        $entity_type = 'paragraph';
        $entity_id = $addtour_paragraph_entity_id;
        $entity_paragraph = \Drupal::entityTypeManager()->getStorage($entity_type)->load($entity_id);
//        ksm($entity_paragraph, "entity_para");

        //--------------- Check Privacy ------------------//
        // NOTES: If it is Private, don't show it. Otherwise, show it.
        $privacy = $entity_paragraph->hasField('field_privacy') && sizeof($entity_paragraph->get('field_privacy')->getValue()) > 0 ? $entity_paragraph->get('field_privacy')->getValue()[0]['value'] : '';
        if($privacy == 'Private') {
            continue; // Go to next iteration.
        }
        //--------------- END OF Check Privacy ------------------//

        //----------Check Additional tour type -----------------

        // Get type of Additional tour
        $addtour_type = $entity_paragraph->get('field_addtour_type')->getValue() != null ? $entity_paragraph->get('field_addtour_type')->getValue()[0]['value'] : '';
        // NOTES:
        // For College session, we need to check College field in the paragraph (additional tour) and display only paragraph (additional tour) with college that is associated with the Visit bucket selected.
        // For Housing tour, always display the paragraph (additional tour).
		$college = ''; // Added on 5/6/2024
        if($addtour_type == "College session") {
            // Get college. We need to see if we can include this paragraph or not based on the Visit bucket.
            $college = $entity_paragraph->get('field_college')->getValue() != null ? $entity_paragraph->get('field_college')->getValue()[0]['value'] : '';
//            ksm($college, "college");
//            ksm($collegesArrayBasedOnCat, "collegesArrayBasedOnCat");

            // Remove Additional tour if it is not listed in $collegesArrayBasedOnCat for College session type.
            if (!in_array($college, $collegesArrayBasedOnCat)) {
                continue; // If not in $collegesArrayBasedOnCat, stop here and go to the next iteration.
            }
        }

        //----------END OF Check Additional tour type --------------

        //----------Check Additional tour capacity -----------------

        // NOTES: Capacity is checked only when there is radio button.

        // Get "Need radio button" value
        $need_radio_button = $entity_paragraph->get('field_need_radio_button')->getValue() != null ? $entity_paragraph->get('field_need_radio_button')->getValue()[0]['value'] : '';
//        ksm($need_radio_button, "need_radio_button");
        // Only when "Need radio button" is 1, count capacity.
        if($need_radio_button == '1') {
            $capacity_status = _check_capacity_for_addtour($entity_paragraph, $thedate_clicked, $eventseries_entity_id, $addtour_paragraph_entity_id); // Returns "open" or "full";
            if($capacity_status == "full") {
                continue;
            }
        } // END OF if($need_radio_button == 1)

        //-----------END OF Check Additional tour capacity -------------



        //---------- Additional tour Time range ------------//

        // NOTES: Make Time range over-writable on a specific day

        // STEP 1: Get original Time range values in Event series
        $time_range_from = (!is_null($entity_paragraph)) && $entity_paragraph->hasField('field_time_range') && sizeof($entity_paragraph->get('field_time_range')->getValue()) > 0 ? $entity_paragraph->get('field_time_range')->getValue()[0]['from'] : '';
        $time_range_to = (!is_null($entity_paragraph)) && $entity_paragraph->hasField('field_time_range') && sizeof($entity_paragraph->get('field_time_range')->getValue()) > 0 ? $entity_paragraph->get('field_time_range')->getValue()[0]['to'] : '';
//        $time_range_to = isset($entity_paragraph->get('field_time_range')->getValue()[0]['to']) ? $entity_paragraph->get('field_time_range')->getValue()[0]['to'] : ''; // Added isset on 6/30/2023
//        ksm($time_range_from, "time_range_from - original");
//        ksm($time_range_to, "time_range_to - original");

        // STEP 2: Get boolean value for Time range overwrite
        $timerange_overwrite_bool = $entity_paragraph->get('field_overwrite_time_addtour')->getValue() != null ? $entity_paragraph->get('field_overwrite_time_addtour')->getValue()[0]['value'] : '';
//        ksm($timerange_overwrite_bool, "timerange_overwrite_bool");

        // STEP 3: Get Time range to use
        $timerange_from_to_use = $time_range_from;
        $timerange_to_to_use = $time_range_to;
        if($timerange_overwrite_bool == '1') {
            $time_overwrite_para_ids = $entity_paragraph->get('field_time_overwrite_para')->getValue() != null ? $entity_paragraph->get('field_time_overwrite_para')->getValue() : ''; // 329
//            ksm($time_overwrite_para_ids, "time_overwrite_para_ids");

            foreach($time_overwrite_para_ids as $overwrite_para) {
                $overwrite_para_id = $overwrite_para['target_id'];
//                ksm($overwrite_para_id, "time_overwrite_para_id");

                // Load the time overwrite paragraph using Paragraph ID
                $entity_type_overwrite = 'paragraph';
                $entity_id_overwrite = $overwrite_para_id;
                $entity_paragraph_overwrite = \Drupal::entityTypeManager()->getStorage($entity_type_overwrite)->load($entity_id_overwrite);
//                ksm($entity_paragraph_overwrite, "entity_paragraph_overwrite");

                // Get Time range overwrite -> Date (Overwritten date) -- Which date when we need to overwrite
                $date_overwrite = $entity_paragraph_overwrite->get('field_date_only')->getValue() != null ? $entity_paragraph_overwrite->get('field_date_only')->getValue()[0]['value'] : ''; // 2023-06-13
//                ksm($date_overwrite, "date_timeoverwrite"); // 2023-06-13, 2023-06-02
                $date_overwrite_nodash_str = str_replace("-","",$date_overwrite);
//                ksm($date_overwrite_nodash_str, "date_overwrite_nodash_str");

                // Get date clicked
//                ksm($thedate_clicked, "thedate_clicked"); // 20230613
                if($date_overwrite_nodash_str == $thedate_clicked) { // If date matches
                    // Get Time range overwrite -> Time range (Overwritten Time range).
                    $timerange_overwrite_from = $entity_paragraph_overwrite->get('field_time_range')->getValue() != null ? $entity_paragraph_overwrite->get('field_time_range')->getValue()[0]['from'] : '';
                    $timerange_overwrite_to = $entity_paragraph_overwrite->get('field_time_range')->getValue() != null ? $entity_paragraph_overwrite->get('field_time_range')->getValue()[0]['to'] : '';
//                    ksm($timerange_overwrite_from, "timerange_overwrite_from");
//                    ksm($timerange_overwrite_to, "timerange_overwrite_to");
                    $timerange_from_to_use = $timerange_overwrite_from;
                    $timerange_to_to_use = $timerange_overwrite_to;
                }
            } // END OF foreach
        } // END OF if($time_overwrite_bool == '1')

        //---------- END OF Additional tour Time range ------------//


        //---------- Prepare output ----------------------------------

        $addtour_name = (!is_null($entity_paragraph)) && $entity_paragraph->hasField('field_addtour_name') && sizeof($entity_paragraph->get('field_addtour_name')->getValue()) > 0 ? $entity_paragraph->get('field_addtour_name')->getValue()[0]['value'] : '';
        if($addtour_name == '') {
            continue; // Go to the next iteration.
        }

        $need_radio_button = $entity_paragraph->get('field_need_radio_button')->getValue()[0]['value']; // 1 or 0 -- 1 is Yes. 0 is No.
//                    ksm($need_radio_button, "need_radio_button"); // 1 or 0
        // NOTES: In addition to "Time range from", also grab Time field value. Need to use Time field value for Additional tour ID and for capacity counting.
        $time_for_addtourid = '';
        if($entity_paragraph->hasField('field_start_time_for_addtourid') == true && $entity_paragraph->get('field_start_time_for_addtourid')->getValue() != false) {
            $time_for_addtourid = $entity_paragraph->get('field_start_time_for_addtourid')->getValue()[0]['value'];
//        ksm($time_for_addtourid, "time_for_addtourid");
        }

        // Format time
        $datenew = DateTime::createFromFormat("Ymd g:i a", $thedate_clicked . "00:00 am", new DateTimeZone('America/Phoenix'));
        $timestamp_ofthedateat0am = $datenew->getTimestamp(); // Timestamp of the date at 0:00am
//                    ksm($datenew->format("Y/m/d g:i a"), "test");
//                    ksm($timestamp_ofthedateat0am, "timestamp_ofthedateat0am");

        // Actual start time timestamp
        $timestamp_datetime_start = $timestamp_ofthedateat0am + $timerange_from_to_use; // Add timestamp of the date at 0:00am and timestamp for the event time.
        // Timestamp for Add tour ID
        $timestamp_for_addtourid = $timestamp_ofthedateat0am + intval($time_for_addtourid);

        // Create Date obj from timestamp
        // For America/Phoenix
        $date_obj_phx = DateTimePlus::createFromTimestamp($timestamp_datetime_start);
        $date_obj_phx->setTimeZone(new DateTimeZone('America/Phoenix'));
        $time_start_formatted = $date_obj_phx->format('g:i a');
//        ksm($time_start_formatted, "time_start_formatted - _prepare_output_addtours()");
//        $time_start_formatted = date( "g:i a", $timestamp_datetime_start);
        $time_start_formatted_webstandard = str_replace("am","a.m.",$time_start_formatted);
        $time_start_formatted_webstandard = str_replace("pm","p.m.",$time_start_formatted_webstandard);

        // Do the same for end time
        $timestamp_datetime_end = $timestamp_ofthedateat0am + $timerange_to_to_use;

        // Create Date obj from timestamp
        // For America/Phoenix
        $date_obj_phx = DateTimePlus::createFromTimestamp($timestamp_datetime_end);
        $date_obj_phx->setTimeZone(new DateTimeZone('America/Phoenix'));
        $time_end_formatted = $date_obj_phx->format('g:i a');
//        ksm($time_end_formatted, "time_end_formatted - _prepare_output_addtours()");
//        $time_end_formatted = date( "g:i a", $timestamp_datetime_end);
        $time_end_formatted_webstandard = str_replace("am","a.m.",$time_end_formatted);
        $time_end_formatted_webstandard = str_replace("pm","p.m.",$time_end_formatted_webstandard);

        if($addtour_type == "College session") {
            $addtour_array_collegesession[$entity_id] = ['para_id' => $entity_id, 'addtour_name' => $addtour_name, 'college_name' => $college, 'time_range' => $time_start_formatted_webstandard . ' &mdash; ' . $time_end_formatted_webstandard, 'need_radio_button' => $need_radio_button, 'addtour_timestamp_start' => $timestamp_datetime_start, 'addtour_timestamp_end' => $timestamp_datetime_end, 'addtour_type' => $addtour_type, 'timestamp_for_addtourid' => $timestamp_for_addtourid ];
        }
        if($addtour_type == "Housing tour") {
            $addtour_array_housingtour[$entity_id] = ['para_id' => $entity_id, 'addtour_name' => $addtour_name, 'college_name' => $college, 'time_range' => $time_start_formatted_webstandard . ' &mdash; ' . $time_end_formatted_webstandard, 'need_radio_button' => $need_radio_button, 'addtour_timestamp_start' => $timestamp_datetime_start, 'addtour_timestamp_end' => $timestamp_datetime_end, 'addtour_type' => $addtour_type, 'timestamp_for_addtourid' => $timestamp_for_addtourid ];
        }

    } // END OF foreach($addtour_paragraph_entity_ids_array as $addtour_paragraph_entity_id)


    //---------- Build actual output code for Additional tours -----------

//    ksm($addtour_array_collegesession, "addtour_array college session");
//    ksm($addtour_array_housingtour, "addtour_array housing tour");

    $output_addtours = '';
    $collegesession_included = false;
    if(sizeof($addtour_array_collegesession) > 0) {
        $output_addtours .= _get_html_output_for_addtour_array($addtour_array_collegesession, $eventseries_entity_id,$campus,$college); // Added $campus,$college by Archana
        $collegesession_included = true;
    }
    if(sizeof($addtour_array_housingtour) > 0) {
        $output_addtours .= _get_html_output_for_addtour_array($addtour_array_housingtour, $eventseries_entity_id,$campus,$college); // Added $campus,$college by Archana
    }
//    return $output_addtours;

    // Changed to include $collegesession_included on 7/21/2023
    $retArray['output'] = $output_addtours;
    $retArray['collegesession_included'] = $collegesession_included;

    return $retArray;
} // END OF function _prepare_output_addtours()


/**
 * @param $addtour_array
 * @param $eventseries_entity_id
 * @return string
 *
 * Helping function
 * Build HTML output for Addtour_array.
 * Called from _prepare_output_addtours().
 */
function _get_html_output_for_addtour_array($addtour_array, $eventseries_entity_id,$campus,$college) { //Added $campus,$college by Archana
    $i = 0;
    $output_addtours = '';

	/*** Archana's code to add description tooltip***/


		$database = \Drupal::database();
		$table = 'taxonomy_term_field_data';
		$field_array = array('tid');
		foreach ($addtour_array as $addtour) {
	//        ksm($addtour, "addtour");

			$tooltip = ''; // Added on 5/6/2024
			if ($addtour['addtour_type'] == "College session") { // Added if on 5/6/2024

				$campus_query = $database->select($table, 't');
				$campus_query->fields('t', $field_array);
				$campus_query->condition('name', $campus, '=');
				$result = $campus_query->distinct()->execute();
				foreach ($result as $record) {
						$value_of_campus = $record->tid;
				}

				$collegequery = $database->select($table, 't');
				$collegequery->fields('t', $field_array);
				$collegequery->condition('description__value', "%" . $collegequery->escapeLike($addtour['college_name']) . "%", 'LIKE');
				$collresult = $collegequery->distinct()->execute();
				foreach ($collresult as $collrecord) {
						$value_of_college = $collrecord->tid;
				}


				$aview = \Drupal\views\Views::getView('academic_description');
				$aview->setDisplay('page_1');
				$exposed_filters = ['field_asd_campus_target_id' => $value_of_campus, 'field_college_target_id' => $value_of_college];
				$aview->setExposedInput($exposed_filters);
				$aview->execute();
				//$view_render = $aview->render();
				//$result = \Drupal::service('renderer')->renderRoot($view_render);
				foreach ($aview->result as $arow) {
					 $node = $arow->_entity;
					 // Get the full description value.
					 $desc = $node->get('field_academic_session_descripti')->value;
				}
				if(!empty($desc)){
					//$begin_tag = '<div class="tour-desc"><p class="acad_tours">';
					//$end_tag = "</div>";
					$tooltip = '<div class="custom-tooltip"><div class="custom-tooltip-container-acadsessions"><button tabindex="0" class="uds-tooltip uds-tooltip-button uds-tooltip-dark" aria-describedby="tooltip-desc-1"><span class="fa-stack"><svg class="campus-svg svg-inline--fa fa-circle fa-w-16 fa-stack-2x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="circle" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="#8c1d40" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg><svg class="svg-inline--fa fa-info fa-w-6 fa-stack-1x" aria-hidden="true" focusable="false" data-prefix="fas" data-icon="info" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 512" data-fa-i2svg=""><path fill="#ffffff" d="M20 424.229h20V279.771H20c-11.046 0-20-8.954-20-20V212c0-11.046 8.954-20 20-20h112c11.046 0 20 8.954 20 20v212.229h20c11.046 0 20 8.954 20 20V492c0 11.046-8.954 20-20 20H20c-11.046 0-20-8.954-20-20v-47.771c0-11.046 8.954-20 20-20zM96 0C56.235 0 24 32.235 24 72s32.235 72 72 72 72-32.235 72-72S135.764 0 96 0z"></path></svg></span></button><div role="tooltip" class="custom-tooltip-description" id="tooltip-desc-1"><button style="color:#fff;" type="button" class="btn btn-default popup-close-btn"><svg class="svg-inline--fa fa-window-close fa-w-16" aria-hidden="true" focusable="false" data-prefix="fa" data-icon="window-close" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" data-fa-i2svg=""><path fill="currentColor" d="M464 32H48C21.5 32 0 53.5 0 80v352c0 26.5 21.5 48 48 48h416c26.5 0 48-21.5 48-48V80c0-26.5-21.5-48-48-48zm-83.6 290.5c4.8 4.8 4.8 12.6 0 17.4l-40.5 40.5c-4.8 4.8-12.6 4.8-17.4 0L256 313.3l-66.5 67.1c-4.8 4.8-12.6 4.8-17.4 0l-40.5-40.5c-4.8-4.8-4.8-12.6 0-17.4l67.1-66.5-67.1-66.5c-4.8-4.8-4.8-12.6 0-17.4l40.5-40.5c4.8-4.8 12.6-4.8 17.4 0l66.5 67.1 66.5-67.1c4.8-4.8 12.6-4.8 17.4 0l40.5 40.5c4.8 4.8 4.8 12.6 0 17.4L313.3 256l67.1 66.5z"></path></svg></button><div class="formatted-text">'.$desc.'</div></div></div></div>';
				}
				else{
					//$begin_tag = '';
					//$end_tag = '';
					$tooltip = '';
				}

			} // END OF if ($addtour['addtour_type'] == "College session")


	/*** End of Archana code ****/


//        ksm($addtour, "addtour");
        if ($i == 0) {
            if ($addtour['addtour_type'] == "College session") {
                $output_addtours .= '<div><strong>Additional tours/sessions</strong> (optional)</div>';
            }
            if ($addtour['addtour_type'] == "Housing tour") {
                $output_addtours .= '<div><strong>Residential Hall Open House</strong> (optional)</div>';
            }
        }
		$output_addtours .= '<div class="add_tours_div m-1">'; //added by Archana
        //$output_addtours .= '<p>';
        if ($addtour['need_radio_button'] == "1") {
            $addtour_entityid = $addtour['para_id']; //<-- This is the $target_id from line 273. Target_id is the paragraph's entity id.

//            $output_addtours .= '<div class="acad-session-div"><input type="radio" name="add-tour" value="' . $eventseries_entity_id . '-' . $addtour_entityid . '-' . $addtour['timestamp_for_addtourid'] . '" > '; <---Very original one before change. 8/4/2023

            $output_addtours .= '<div class="acad-session-div"><input type="radio" name="add-tour" value="' . $eventseries_entity_id . '-' . $addtour_entityid . '-' . $addtour['timestamp_for_addtourid'] . '|' . $addtour['addtour_timestamp_start'] . '|' . $addtour['addtour_timestamp_end'] . '|' . $addtour['addtour_name'] . '" > ';
            // This is for testing with checkbox:
//            $output_addtours .= '<div class="acad-session-div"><input type="checkbox" name="add-tour" value="' . $eventseries_entity_id . '-' . $addtour_entityid . '-' . $addtour['timestamp_for_addtourid'] . '|' . $addtour['addtour_timestamp_start'] . '|' . $addtour['addtour_timestamp_end'] . '|' . $addtour['addtour_name'] . '" > ';

        } else {
            $output_addtours .= '<div class="acad-session-div">';
        }
        $output_addtours .= $addtour['addtour_name'];
        $output_addtours .= ' ' . $addtour['time_range'] .'</div>' . $tooltip.'</div>'; //updated by Archana

        $i++;
    }
    return $output_addtours;

	/*$output_addtours_all = $output_addtours.$tooltip.$end_tag; // Archana's code
	return $output_addtours_all;*/
}


/**
 * @param string $barrett_instance_id
 *
 * @return string $eventseries_id
 */
function _get_eventseries_id($barrett_instance_id) {
    $database = \Drupal::database();
    $table = 'eventinstance_field_data';
    $field_array = array('eventseries_id');
    $query = $database->select($table, 't');
    $query->fields('t', $field_array);
    $query->condition('id', $barrett_instance_id, '=');
    $result = $query->distinct()->execute();
    $eventseries_id = '';
    foreach ($result as $record) {
        $eventseries_id = $record->eventseries_id;
    }
    return $eventseries_id;
}


/**
 * @param string $thedate_clicked
 *  date in Ymd format or Y-m-d format
 * @param string $time
 *   ex: 03:30 pm
 *
 * @return string $timestamp
 *
 * Helping function
 * Get timestamp from time.
 */
function _get_timestamp($thedate_clicked, $time) {
    if($time == '') {
        $time = '00:00 am';
    }
    // Get timestamp of start datetime
    if(strpos($thedate_clicked, '-') == false) {
        $datenew = DateTime::createFromFormat("Ymd g:i a", $thedate_clicked . " " . $time);
    } else {
        $datenew = DateTime::createFromFormat("Y-m-d g:i a", $thedate_clicked . " " . $time);
    }
    $timestamp = $datenew->getTimestamp(); // Timestamp of the date at start time
    return $timestamp;
}


/**
 * @param string $thedate_clicked
 *  date in Ymd format
 * @param string $start_time_barrett
 *   ex: 03:30 pm
 * @param string $duration_minutes
 *   ex: 2700
 *
 * @return string
 *   ex: 4:15 p.m.
 *
 * Helping function
 */
function _get_endtime_from_starttime_and_duration($thedate_clicked, $start_time_barrett, $duration_minutes) {

    // Get timestamp of start datetime
    $timestamp_startdatetime = _get_timestamp($thedate_clicked, $start_time_barrett);
    // Get timestamp of end datetime
    $timestamp_end = $timestamp_startdatetime + $duration_minutes; // Add timestamp of the date at 0:00am and timestamp for the event time.

    $time_end_formatted = date( "g:i a", $timestamp_end);
    $time_end_formatted_webstandard = _format_time_webstandard($thedate_clicked, $time_end_formatted);

    return $time_end_formatted_webstandard;
}


/**
 * @param string $thedate_clicked
 *  date in Ymd format
 * @param string $time
 *  time in g:i a format. ex: 3:00 pm
 * @return string
 *   ex: 4:15 p.m.
 *
 * Helping function
 * Format time in Webstarndard.
 */
function _format_time_webstandard($thedate_clicked, $time) {
    $timestamp = _get_timestamp($thedate_clicked, $time);
    $time_formatted = date( "g:i a", $timestamp);
    $time_formatted_webstandard = str_replace("am", "a.m.", $time_formatted);
    $time_formatted_webstandard = str_replace("pm", "p.m.", $time_formatted_webstandard);

    return $time_formatted_webstandard;
}


/**
 * @param $key
 * @param $message
 * @param $params
 *
 * Implements hook_mail().
 * For emailing, we need hook_mail. Works with sendConfEmail() in VisitWebformHander.php.
 */
function asuaec_visit_mail($key, &$message, $params) {
    $options = array(
        'langcode' => $message['langcode'],
    );
    switch ($key) {
        case 'visit_conf_email':
        case 'visit_conf_email_failure':
        case 'visit_post_failure':
            $message['from'] = \Drupal::config('system.site')->get('mail');
            $message['subject'] = t('@subject', ['@subject' => $params['subject']], $options);
            $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed'; // Needed this to display images.
            $message['body'][] = $params['message'];
            break;
    }
}


/**
 * @return array
 *   An array of colleges based on bucket.
 *
 * Helping function to get array of colleges based on Visit bucket/category ID
 */
function _get_collegearray_basedoncategory($category_id) {
    // Visit bucket code here
    $collegesArrayBasedOnBucket = [];
    // College code:
    // UGAS: New College
    // UGLS: College of Integrative Sciences and Arts
    // UGCS: Cronkite
    // UGNH: Collegge of Health Solutions
    // UGNU: Edson College of Nursing and Health Innovation
    // UGLA: The College of Liberal Arts and Sciences
    // UGPP: Watts College of Public Service and Community Solutions
    // UGGF: College of Global Futures
    // UGHI: Herberger
    // UGES: Engineering
    // UGBA: WP Carey Business
    // UGTB: Thunderbird
    // UGTE: Teachers College
    // UGUC: University College
    switch($category_id) {
        case '25': // 'Anthropology, Sociology and Cultural Studies'
            array_push($collegesArrayBasedOnBucket, 'UGLA', 'UGPP', 'UGGF', 'UGAS', 'UGHI');
            break;

        case '26': // 'Architecture, Construction and Design'
            array_push($collegesArrayBasedOnBucket, 'UGLA', 'UGHI', 'UGES');
            break;

        case '27': // 'Business'
            array_push($collegesArrayBasedOnBucket, 'UGBA', 'UGTB', 'UGES', 'UGLA', 'UGNH', 'UGPP', 'UGNU', 'UGCS');
            break;

        case '28': // 'Communication and Languages'
            array_push($collegesArrayBasedOnBucket, 'UGLA', 'UGBA', 'UGTB', 'UGAS', 'UGLS', 'UGCS', 'UGHI');
            break;

        case '29': // 'Computer Science, Software Engineering and Mathematics':
            array_push($collegesArrayBasedOnBucket, 'UGGF', 'UGNH', 'UGLS', 'UGES', 'UGAS', 'UGLA', 'UGBA');
            break;

        case '30': // 'Criminology and Forensics':
            array_push($collegesArrayBasedOnBucket, 'UGLA', 'UGPP', 'UGAS');
            break;

        case '31': // 'Earth, Space and Flight':
            array_push($collegesArrayBasedOnBucket, 'UGLA', 'UGES');
            break;

        case '32': // 'Education and Teaching':
            array_push($collegesArrayBasedOnBucket, 'UGTE', 'UGLA', 'UGAS');
            break;

        case '33': // 'Engineering':
            array_push($collegesArrayBasedOnBucket, 'UGES');
            break;

        case '34': // 'Exploratory':
            array_push($collegesArrayBasedOnBucket, 'UGUC', 'UGAS', 'UGBA', 'UGTE' );
            break;

        case '72': // 'Fashion':
            array_push($collegesArrayBasedOnBucket, 'UGHI');
            break;

        case '73': // 'Film and Media':
            array_push($collegesArrayBasedOnBucket, 'UGHI', 'UGCS', 'UGLA');
            break;

        case '35': // 'Fine Arts and Performance':
            array_push($collegesArrayBasedOnBucket, 'UGHI', 'UGAS');
            break;

        case '76': // Global Management and Leadership
            array_push($collegesArrayBasedOnBucket, 'UGTB');
            break;

        case '36': // 'Health and Wellness':
            array_push($collegesArrayBasedOnBucket, 'UGLS', 'UGNU', 'UGNH', 'UGES', 'UGPP', 'UGAS', 'UGLA');
            break;

        case '37': // 'History, Philosophy and Humanities':
                array_push($collegesArrayBasedOnBucket, 'UGLS', 'UGAS', 'UGLA', 'UGGF');
                break;

        case '38': // 'Journalism'
            array_push($collegesArrayBasedOnBucket, 'UGCS', 'UGNH', 'UGPP');
            break;

        case '39': // 'Nursing':
            array_push($collegesArrayBasedOnBucket, 'UGNU');
            break;

        case '40': // 'Pre-health':
            array_push($collegesArrayBasedOnBucket, 'UGBA', 'UGHI', 'UGTE', 'UGES', 'UGGF', 'UGNH', 'UGLS', 'UGAS', 'UGCS', 'UGLA', 'UGNU', 'UGPP', 'UGTB'); // Thunderbird School of Global Management
            break;

        case '41': // 'Pre-law':
            array_push($collegesArrayBasedOnBucket, 'UGHI', 'UGCS', 'UGLA');
            break;

        case '42': // 'Psychology':
            array_push($collegesArrayBasedOnBucket, 'UGAS', 'UGLA', 'UGPP', 'UGES');
            break;

        case '43': // 'Public Service and Political Science':
            array_push($collegesArrayBasedOnBucket, 'UGGF', 'UGLS', 'UGAS', 'UGLA', 'UGPP', 'UGBA');
            break;
        
        case '44': // 'Science'
            array_push($collegesArrayBasedOnBucket, 'UGLS', 'UGLA', 'UGES', 'UGNH', 'UGAS');
            break;
        
        case '45': // 'Sports, Tourism and Recreation':
            array_push($collegesArrayBasedOnBucket, 'UGBA', 'UGPP', 'UGCS', 'UGNH');
            break;

        case '46': // 'Sustainability and the Environment':
            array_push($collegesArrayBasedOnBucket, 'UGGF', 'UGBA', 'UGES', 'UGPP', 'UGAS', 'UGLS', 'UGLA'); // UGGF - College of Global Futures. Added on 4/27/2022.
            break;
    }
    return $collegesArrayBasedOnBucket;
}


/**
 * @param $a
 * @param $b
 * @return string
 *
 * Called from WebformConfiamtionPage.php at line 292:
 *     usort($merged_addtour_barrett_array, 'compare_timestamp');
 */
function compare_timestamp($a, $b) {
    //$a's timestamp value   // 1-477-1693843200|1693843200|1693846800|Aviation tour test
    $temp_array_a = explode('|', $a);
    $a_timestamp = $temp_array_a[1];

    //$b's timestamp value
    $temp_array_b = explode('|', $b);
    $b_timestamp = $temp_array_b[1];

    return $a_timestamp - $b_timestamp;
}
