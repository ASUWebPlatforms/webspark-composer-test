/**
 * @param array $page
 *
 * hook_page_attachments_alter
 * Attach JS/CSS to /schedule page, /scheduling-your-tour page and confirmation page (/see-you-soon)
 */
function asuaec_visit_page_attachments_alter(array &$page) {
    $current_path = \Drupal::service('path.current')->getPath();
    if ($current_path == '/node/1' ) { // Page - /scheduling-your-tour
        $page['#attached']['library'][] = 'asuaec_visit/asuaec-visit-library';
    }
//    if ($current_path == '/node/26') { // Landing page - /schedule
    if ($current_path == '/node/217421') { // Landing page - /schedule
        $page['#attached']['library'][] = 'asuaec_visit/asuaec-schedulepage-library';
    }
    if ($current_path == '/node/217235') { // Confirmation page (DEV:/node/217235 )
        $page['#attached']['library'][] = 'asuaec_visit/asuaec-confpage-library';
    }
}


/**
 * @param $form
 * @param $form_state
 * @param $form_id
 *
 * hook_form_alter
 */
function asuaec_visit_form_alter(&$form, &$form_state, $form_id)
{
    // Attach JS to Visit form and "Other" form
    if ($form_id == 'webform_submission_visit_form_node_24_add_form' ||
        $form_id == 'webform_submission_registration_form_node_217080_add_form' ||
        $form_id == 'webform_submission_sun_devil_send_off_node_217217_add_form' ||
        $form_id == 'webform_submission_beet_node_264061_add_form' || // Added for BEET form on 1/7/2025
        $form_id == 'webform_submission_sko_node_263413_add_form' // Added for SKO form on 1/3/2024
       ) { 
        $form['#attached']['library'] = [
            'asuaec_visit/asuaec-visitform-library',
            'core/drupal.form', // Prevent duplicate submission. Added on 1/19/2024.
        ];
        // Disable and say "Processing.." after click submit button. Added on 1/19/2024.
        $form['actions']['submit']['#attributes']  = array("onclick" => "jQuery(this).addClass('disabled'); jQuery(this).val('Processing..');");
    }
    // Event series add/edit page (Visit event and Barrett)
    if ($form_id == 'eventseries_visit_event_edit_form' ||
        $form_id == 'eventseries_barrett_edit_form' ||
        $form_id == 'eventseries_visit_event_add_form' ||
        $form_id == 'eventseries_barrett_add_form' ||
        $form_id == 'eventseries_visit_event_clone_form' ||
        $form_id == 'eventseries_barrett_clone_form'
    ) {
        $form['#attached']['library'] = [
            'asuaec_visit/asuaec-eventseries-editform-library'
        ];
    }
    // Turn on revision automatically for edit. Added on 1/19/2024.
    if($form_id == 'eventseries_visit_event_edit_form' || $form_id == 'eventseries_barrett_edit_form') {
        $form['revision']['#default_value'] = true;
    }
//    // Insert current user id automatically for cloning. Added on 1/19/2024.
//    if($form_id == 'eventseries_visit_event_clone_form' || $form_id == 'eventseries_barrett_clone_form') {
//        $username = User::load(\Drupal::currentUser()->id())->get('name')->value;
//        $userid = User::load(\Drupal::currentUser()->id())->get('uid')->value;
//        $form['uid']['widget'][0]['target_id']['#default_value']->set('uid', $userid);
//        $form['uid']['widget'][0]['target_id']['#default_value']->set('name', $username);
//    }
}

/**
 * @param $entity
 *
 * hook_entity_presave
 *
 * Insert current user id automatically for cloning. Added on 6/4/2024
 */
function asuaec_visit_entity_presave(EntityInterface $entity) {
	if ($entity->bundle() == 'visit_event' || $entity->bundle() == 'barrett'){
		$current_user_id = \Drupal::currentUser()->id();
		$entity->setOwnerId($current_user_id);
	}
}


