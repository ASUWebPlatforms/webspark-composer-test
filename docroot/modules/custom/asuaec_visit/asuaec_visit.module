            $register = "<a href='$link'><button name='$personType|$etype|$unixstarttime|$unixtotime|$display_title|$campus|$start_time_format|$end_time_format' class='btn btn-maroon sundevil-btn register-btn-{$event_id}{$persontype_no_space}'>Register</button></a>";
            //$register = "<button name='$personType|$etype|$unixstarttime|$unixtotime|$display_title' class='btn btn-maroon sundevil-btn register-btn-{$event_id}{$persontype_no_space}'>Register</button>";
          }
