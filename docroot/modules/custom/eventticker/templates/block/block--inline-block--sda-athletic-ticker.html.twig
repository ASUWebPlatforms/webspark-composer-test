<?php
{#
/**
 * @file
 * Template for an sda block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
] %}
?>
<div{{ attributes.addClass(classes) }}>
{{ title_prefix }}
  {% if label %}
    {% block label %}
<h2{{ title_attributes }}>{{ label }}</h2>
{% endblock %}
  {% endif %}
  {{ title_suffix }}
  {{ content.field_anchor_menu_settings }}
  {{ content.field_tooltip }}
  {% set unique_id = block.id.value %}

  <div class="tickerThemeWrapper {{ content['#block_content'].field_sda_theme.value }}">
    {{ drupal_view('sda_events', 'block_1') }}
  </div>
</div>
