/**
 * @param $attendee_conf_email_node
 * @param $email_code
 * @return void
 * @throws \Drupal\Core\Entity\EntityStorageException
 *
 * Save HTML email code into Attendee_conf_email node.
 */
function _asuaec_visit_revamp_save_email_code($attendee_conf_email_node, $email_code) {
  if (
    $attendee_conf_email_node instanceof \Drupal\node\NodeInterface &&
    $attendee_conf_email_node->bundle() === 'attendee_conf_email' &&
    $attendee_conf_email_node->hasField('field_email_content_html')
  ) {
    // Get existing values (if any)
    $existing_values = $attendee_conf_email_node->get('field_email_content_html')->getValue();

    // Append new item
    $existing_values[] = [
      'value' => $email_code,
      'format' => 'full_html', // Use the appropriate text format
    ];

    // Set the updated field values --- TODO: Need to test if original one is kept after create "Resend" functionality
    $attendee_conf_email_node->set('field_email_content_html', $existing_values);

    // Save the node
    $attendee_conf_email_node->save();
  }
  else {
    \Drupal::logger('asuaec_visit_revamp')->error('Invalid node or field in _asuaec_visit_revamp_save_email_code().');
  }
}



/**
 * @param $additional_emails_array
 * @param $student_email
 * @return string
 *
 * Remove duplicate email addresses and build comma separatted email string.
 * Also remove empty string.
 */
function _asuaec_visit_revamp_remove_duplicate_email_address_and_build_comma_separated_email_string($additional_emails_array, $student_email) {
  $rsvp_emails = '';
  // Clean $additional_emails_array. Remove duplicate email addresses if there are any.
  $additional_emails_array_cleaned = array_unique($additional_emails_array); // Duplicate removed.
  $i = 0;
  foreach($additional_emails_array_cleaned as $additional_email) {
    if($additional_email == $student_email) {
      unset($additional_emails_array_cleaned[$i]);
    }
    if($additional_email == '') {
      unset($additional_emails_array_cleaned[$i]);
    }
    $i++;
  }
  // Build comma-separated string
  $i = 0;
  foreach($additional_emails_array_cleaned as $addittional_email) {
    if($i == 0){
      $rsvp_emails .= $addittional_email;
    } else {
      $rsvp_emails .= ',' . $addittional_email;
    }
    $i++;
  }
  return $rsvp_emails;
}


/**
 * Remove an event (parent or child) from field_events_json on attendee_conf_email.
 * Mark "all cancelled" if none remain.
 * Append regenerated email HTML.
 *
 * @param \Drupal\node\NodeInterface $attendee_conf_node
 *   The attendee_conf_email node to update.
 * @param string $canceled_event_id
 *   The eventId string to remove (e.g. "356-1757948400" or child id like "346-1758303000").
 *
 * @throws \Drupal\Core\Entity\EntityStorageException
 */
function asuaec_visit_revamp_update_on_cancel(NodeInterface $attendee_conf_node, string $canceled_event_id): void {

  if ($attendee_conf_node->bundle() !== 'attendee_conf_email') {
    \Drupal::logger('asuaec_visit_revamp')->warning('Updater called on non-attendee_conf_email node @nid', ['@nid' => $attendee_conf_node->id()]);
    return;
  }

  // Read the *latest* stored item if the field is multi-value
  $json_items = $attendee_conf_node->get('field_events_json')->getValue(); // array of items or empty
  if (empty($json_items)) {
    \Drupal::logger('asuaec_visit_revamp')->notice('No JSON to update on attendee_conf_email @nid', ['@nid' => $attendee_conf_node->id()]);
    return;
  }
  $last_item = end($json_items);
  // If field is a *formatted text* type (text_long/text_with_summary), each item is ['value' => ..., 'format' => ...].
  // If it's a *string* type (string/string_long), items are plain strings.

  $json_raw = is_array($last_item) && array_key_exists('value', $last_item)
    ? ($last_item['value'] ?? '')
    : (is_string($last_item) ? $last_item : '');

  if ($json_raw === '') {
    \Drupal::logger('asuaec_visit_revamp')->notice('Latest field_events_json item is empty on attendee_conf_email @nid', ['@nid' => $attendee_conf_node->id()]);
    return;
  }

  $events = json_decode($json_raw, TRUE);
  if (!is_array($events)) {
    \Drupal::logger('asuaec_visit_revamp')->error('Invalid JSON in field_events_json on attendee_conf_email @nid', ['@nid' => $attendee_conf_node->id()]);
    return;
  }

  // --- Remove the canceled eventId (handles parent or child) ---
  $updated = [];
  foreach ($events as $evt) {
    // If this is the exact event being canceled at the parent level, skip it entirely.
    if (!empty($evt['eventId']) && $evt['eventId'] === $canceled_event_id) {
      continue;
    }

    // Otherwise, also remove a child match if present.
    if (!empty($evt['children']) && is_array($evt['children'])) {
      $evt['children'] = array_values(array_filter($evt['children'], function ($child) use ($canceled_event_id) {
        return empty($child['eventId']) || $child['eventId'] !== $canceled_event_id;
      }));
    }

    $updated[] = $evt;
  }

  // If nothing is left, mark as "all canceled".
  if (empty($updated)) {
    // if ($attendee_conf_node->hasField('field_all_events_canceled_text')) {
    //   $attendee_conf_node->set('field_all_events_canceled_text', 'All events canceled');
    // }
    if ($attendee_conf_node->hasField('field_user_cancelled_all_events')) {
      $attendee_conf_node->set('field_user_cancelled_all_events', 1);
    }

    // Store an empty array back into JSON field.
    // Append empty snapshot when possible instead of overwrite
    $field = $attendee_conf_node->get('field_events_json');
    $cardinality = $field->getFieldDefinition()->getFieldStorageDefinition()->getCardinality();
    $empty_json = json_encode([], JSON_UNESCAPED_SLASHES);

    // Append new item preserving field type.
    if (!empty($json_items) && is_array($json_items[0]) && array_key_exists('value', $json_items[0])) {
      $field->appendItem(['value' => $empty_json, 'format' => 'plain_text']);
    } else {
      $field->appendItem($empty_json);
    }

    $attendee_conf_node->save();

//    // Rebuild email HTML (will reflect no events + your closing/signature).
//    $parts = _asuaec_visit_revamp_buildConfEmailBody($attendee_conf_node);
//    _asuaec_visit_revamp_save_email_code($attendee_conf_node, $parts['body']);

    \Drupal::logger('asuaec_visit_revamp')->notice('All events cancelled for attendee_conf_email @nid. JSON cleared.', [
      '@nid' => $attendee_conf_node->id(),
    ]);
    return;
  }

  // There are remaining events; write back the updated JSON.
  $new_json = json_encode(array_values($updated), JSON_UNESCAPED_SLASHES);

  // Append-as-new-item
  $field = $attendee_conf_node->get('field_events_json');
  $cardinality = $field->getFieldDefinition()->getFieldStorageDefinition()->getCardinality();

  // Multi-value: append snapshot preserving field type.
  if (!empty($json_items) && is_array($json_items[0]) && array_key_exists('value', $json_items[0])) {
    // formatted text field
    $field->appendItem(['value' => $new_json, 'format' => 'plain_text']);
  } else {
    // string/string_long field
    $field->appendItem($new_json);
  }


  // --- Optional: Append-as-new-item strategy (if field is multi-value).
  // If you want to keep a history and your field allows multiple values:
  // $existing = $attendee_conf_node->get('field_events_json')->getValue();
  // $existing[] = ['value' => $new_json, 'format' => 'plain_text'];
  // $attendee_conf_node->set('field_events_json', $existing);
  // IMPORTANT: If you enable this, update all readers to use the LAST item.

  $attendee_conf_node->save();

  // Rebuild email HTML with remaining events and append to field_email_content_html.
  $parts = _asuaec_visit_revamp_buildConfEmailBody($attendee_conf_node);
  _asuaec_visit_revamp_save_email_code($attendee_conf_node, $parts['body']);

  \Drupal::logger('asuaec_visit_revamp')->notice('Removed eventId @eid from attendee_conf_email @nid.', [
    '@eid' => $canceled_event_id,
    '@nid' => $attendee_conf_node->id(),
  ]);
}


/**
 * Convenience wrapper: find attendee_conf_email by field_sid and update JSON for a canceled event.
 *
 * @param string|int $sid
 *   Webform Submission ID stored in attendee_conf_email.field_sid.
 * @param string $canceled_event_id
 *   The eventId to remove.
 */
function asuaec_visit_revamp_update_on_cancel_by_sid($sid, string $canceled_event_id): void {
  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'attendee_conf_email')
    ->condition('field_sid', $sid)
    ->range(0, 1);

  $nids = $query->execute();
  if (empty($nids)) {
    \Drupal::logger('asuaec_visit_revamp')->warning('No attendee_conf_email found for sid @sid', ['@sid' => $sid]);
    return;
  }
  /** @var \Drupal\node\NodeInterface $node */
  $node = Node::load(reset($nids));
  asuaec_visit_revamp_update_on_cancel($node, $canceled_event_id);
}

/**
 * Implements hook_node_delete().
 *
 * Fires once per node deleted (after storage delete).
 */
function asuaec_visit_revamp_node_delete(\Drupal\node\NodeInterface $node) {
  if ($node->bundle() !== 'student_registered_visits') {
    return;
  }

  // Read needed values from the node being deleted.
  $sid = $node->get('field_web_sub_id')->value ?? NULL;
  $canceled_event_id = $node->get('field_student_event_id')->value ?? NULL;

  \Drupal::logger('cstest')->notice('sid: @sid', [ '@sid' => $sid]);
  \Drupal::logger('cstest')->notice('canceled_event_id: @canceled_event_id', ['@canceled_event_id' => $canceled_event_id]);

  if (!$sid || !$canceled_event_id) {
    \Drupal::logger('asuaec_visit_revamp')->warning(
      'Missing sid or event id on deleted node @nid (sid: @sid, event: @event).',
      ['@nid' => $node->id(), '@sid' => $sid ?? 'NULL', '@event' => $canceled_event_id ?? 'NULL']
    );
    return;
  }

  \Drupal::logger('asuaec_visit_revamp')->notice(
    'Student Registered Visits node deleted: @nid (sid: @sid, event: @event).',
    ['@nid' => $node->id(), '@sid' => $sid, '@event' => $canceled_event_id]
  );

  // Update the attendee confirmation email node(s).
  asuaec_visit_revamp_update_on_cancel_by_sid($sid, $canceled_event_id);
}

/**
 * Campus name is passed and returns campus code
 * @param mixed $campus
 * @return $campus_code
 */
function get_campus_code($campus) {
  $campus_code = '';
  if ($campus !== '') {
    switch ($campus) {
      case 'Tempe':
        $campus_code = 'TEMPE';
        break;
      case 'Downtown Phoenix':
        $campus_code = 'DTPHX';
        break;
      case 'Polytechnic':
        $campus_code = 'POLY';
        break;
      case 'West':
        $campus_code = 'WEST';
        break;
      case 'ASU California Center in downtown LA':
        $campus_code = 'LOSAN';
        break;
      default:
        $campus_code = '';
    }
  }
  return $campus_code;
}
