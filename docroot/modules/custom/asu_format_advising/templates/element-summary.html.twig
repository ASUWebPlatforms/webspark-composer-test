{#
  Template for Element Summary.
  Variables:
    - data: The summary data to show at the end step.


[
  step: 1
  title: Perdonal data
  fields: [
    name: carlos
    degree: Doctor in Audiology
  ],
]
#}
<div class="element-summary">
  {% for card in data %}
    <div class="card">
      <div class="card-header bg-gold py-0">
       <h3>{{ card.title }}</h3>
      </div>
      <div class="card-body">
        <p class="card-text">
          <table class="table table-striped">
            <tbody>
            {% for key,value in card.fields %}
              <tr>
                <td>{{ key }}</td>
                <td>{{ value }}</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </p>
        <a data-step={{ card.step }} href="#" class="btn btn-primary">Review</a>
      </div>
    </div>
  {% endfor %}
</div>


