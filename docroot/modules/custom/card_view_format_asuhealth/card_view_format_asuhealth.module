/**
 * @file
 * Primary module hooks for Card View Format module.
 */


 /**
 * Prepares variables for card view format templates.
 *
 * Default template: views-view-card-view-format.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - view: A View object.
 */


/**
 * Implements hook_theme().
 */
