function asu_tuition_node_insert(NodeInterface $node) {
	//ksm($node->getType());
	$database = \Drupal::database();
	if($node->getType() == "asu_tuition_residency"){
		$nid = $node->id();
		//ksm($nid);
		$node_data =  Node::load($nid);
		//ksm($node_data);
		$description = $node_data->field_description->value;
		$residency = $node_data->field_residency->value;
		//ksm($residency);
		$display = $node_data->field_display->value;
		$weight = $node_data->field_weight->value;
		
		$check_data = $database->select('asu_tuition_residency','r')->fields('r',['id'])->condition('residency', $residency,'=')->execute()->fetchField();
		//ksm($check_data);
		if(empty($check_data)){
			$result = $database->insert('asu_tuition_residency')
			  ->fields([
				'residency' => $residency,
				'descr' => $description,
				'display' => $display,
				'weight' => $weight,  
			  ])
			  ->execute();
		}
		else{
			$messsage = "Could not insert node $nid into database base as the it was duplicate entry";
			//\Drupal::logger('asu_tuition_residency node message')->error($message);
			//\Drupal::logger('asu_tuition_residency node message')->notice(print_r($messsage, TRUE));
		}
	}
		
		//fee code
		//ksm($node->getType());
		if($node->getType() == "asu_tuition_fee_code_data"){
			$fnid = $node->id();
			//ksm($fnid);
			$f_node_data =  Node::load($fnid);
			//ksm($node_data);
			$acad_career = $f_node_data->field_acad_career->value;
			$fdescription = $f_node_data->field_code_description->value;
			$fresidency = $f_node_data->field_code_residency->value;
			$fee_code = $f_node_data->field_fee_code->value;	
			$fee_type = $f_node_data->field_fee_type->value;
			$institution = $f_node_data->field_institution->value;
			$field_notes = $f_node_data->field_notes->value;
			$campus = $f_node_data->field_campus->value;
			$acad_prog = $f_node_data->field_acad_prog->value;
			$base_term = $f_node_data->field_base_term->value;		
			//chck if node id already exists
			$check_fnid = $database->select('asu_tuition_fee_code','rfc')->fields('rfc',['id'])->condition('nodeid', $fnid,'=')->execute()->fetchField();
			//ksm($check_fnid);
			if(empty($check_fnid)){
				$result_fc = $database->insert('asu_tuition_fee_code')
					  ->fields([
						'institution' => $institution,
						'descr' => $fdescription,
						'fee_code' => $fee_code,
						'fee_type' => $fee_type,
						'campus' => $campus,
						'residency' => $fresidency,
						'acad_career' => $acad_career,
						'acad_prog' => $acad_prog,
						'base_term' => $base_term,
						'note' => $field_notes,
						'nodeid' => $fnid  
					  ])
					  ->execute();
			}
			else{
				$messsage_fnid = "Could not insert node $fnid into database base as the it was duplicate entry";
				//\Drupal::logger('asu_tuition_residency node message')->error($message);
				//\Drupal::logger('asu_tuition_fee_code node message')->notice(print_r($messsage_fnid, TRUE));
			}
		}
	
	
		//fee rate
		//ksm($node->getType());
		if($node->getType() == "asu_tuition_fee_rate_data"){
			$rnid = $node->id();
			//ksm($fnid);
			$r_node_data =  Node::load($rnid);
			//ksm($node_data);
			$r_institute = $r_node_data->field_rate_institution->value;
			$r_acad_year = $r_node_data->field_acad_year->value;
			$sterm = $r_node_data->field_sterm->value;
			$r_fee_code = $r_node_data->field_rate_fee_code->value;	
			$r_fee_type = $r_node_data->field_rate_fee_type->value;
			$enrolled_hrs = $r_node_data->field_enrolled_hrs->value;
			$fee_rate = $r_node_data->field_fee_rate->value;
			$check_rnid = $database->select('asu_tuition_fee_rate','fr')->fields('fr',['id'])->condition('nodeid', $rnid,'=')->execute()->fetchField();
			if(empty($check_rnid)){
			 $result_rate = $database->insert('asu_tuition_fee_rate')
				  ->fields([
					'institution' => $r_institute,
					'fee_code' => $r_fee_code,
					'fee_type' => $r_fee_type,
					'acad_year' => $r_acad_year,
					'strm' => $sterm,
					'enrlld_hrs' => $enrolled_hrs,  
					'fee_rate' => $fee_rate,
					'nodeid' => $rnid  
				  ])
				  ->execute();
			}
			else{
				$messsage_rnid = "Could not insert node $rnid into database base as the it was duplicate entry";
				//\Drupal::logger('asu_tuition_residency node message')->error($message);
				//\Drupal::logger('asu_tuition_fee_rate node message')->notice(print_r($messsag_rnid, TRUE));
			}
		}
			  
		
	
		
	//ksm($node);
}

//Code to redirect it to the default language if translation does not exist
function asu_tuition_preprocess_page(&$variables) {
  $node = \Drupal::routeMatch()->getParameter('node');

  if ($node instanceof \Drupal\node\NodeInterface) {
    $current_lang = \Drupal::languageManager()->getCurrentLanguage()->getId();
    if ($current_lang == 'es' && !$node->hasTranslation('es')) {
      $default_lang_url = Url::fromRoute('<current>', [], ['language' => \Drupal::languageManager()->getDefaultLanguage()])->toString();
      $response = new RedirectResponse($default_lang_url, 301);
      $response->send();
      exit;
    }
  }
}