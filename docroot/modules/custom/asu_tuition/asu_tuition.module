/**
 * Get this modules version number breakdown. This was taken from drupal_parse_dependency().
 */
function asu_tuition_get_module_version() {
  module_load_include('module', 'system');

  // Core version is always optional: 7.x-2.x and 2.x is treated the same.
  $p_core = '(?:' . preg_quote('DRUPAL_CORE_COMPATIBILITY') . '-)?';
  $p_major = '(?P<major>\\d+)';
  // By setting the minor version to x, branches can be matched.
  $p_minor = '(?P<minor>(?:\\d+|x)(?:-[A-Za-z]+\\d+)?)';

  //$info = system_get_info('module', 'asu_tuition');
  $info = \Drupal::service('extension.list.module')->getExtensionInfo('asu_tuition');	
  $version = $info['version'];
  $matches = array();

  preg_match("/^\\s*{$p_core}{$p_major}\\.{$p_minor}/", $version, $matches);
  $matches['core'] = 'DRUPAL_CORE_COMPATIBILITY';
  return array_intersect_key($matches, array('core' => '', 'major' => '', 'minor' => ''));
	
}


