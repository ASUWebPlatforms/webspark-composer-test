/**
 * Implements hook_form_alter().
 */
function sp_learningmod_form_alter(array &$form, FormStateInterface $form_state, $form_id)
{
  if (strpos($form_id, 'node_') === 0 && strpos($form_id, '_form') !== false) {
    $user = \Drupal::currentUser();
    $uid = $user->id();
    $username = $user->getDisplayName();

    $allowed_roles = ['sp_learningmod_user'];

    $allowed_content_types = [
      'sp_cq_clients_johns',
      'sp_cq_current_response',
      'sp_cq_drugs',
      'sp_cq_environment',
      'sp_cq_pimps',
      'sp_cq_police_community_members',
      'sp_cq_sexual_transactions',
      'sp_cq_street_prostitutes',
    ];

    if (preg_match('/^node_(.*?)_(edit_)?form$/', $form_id, $matches)) {
      $node_type = $matches[1];
    } else {
      return;
    }

    if (array_intersect($allowed_roles, $user->getRoles()) && in_array($node_type, $allowed_content_types)) {

      if (isset($form) && is_array($form)) {
        if (isset($form['title']['widget'][0]['value'])) {
          $auto_title = "{$username}: " . ucfirst(str_replace('_', ' ', $node_type));
          $form['title']['widget'][0]['value']['#value'] = $auto_title;
          $form['title']['widget'][0]['value']['#default_value'] = $auto_title;
          $form['title']['widget'][0]['value']['#type'] = 'hidden';
          $form['title']['widget'][0]['value']['#attributes']['class'][] = 'hidden-form-field';
        }

        foreach (['field_metatag', 'revision_information'] as $hidden_field) {
          if (isset($form[$hidden_field])) {
            unset($form[$hidden_field]);
          }
        }

        foreach ($form as $key => &$field) {
          if ($key === '#title') {
            continue;
          }

          if (isset($field['#type']) && is_array($field)) {
            if (!str_starts_with($key, 'field_') && $key !== 'title' && $key !== 'actions') {
              $field['#attributes']['class'][] = 'hidden-form-field';
            }
          }
        }

        if (isset($form['actions']['preview'])) {
          $form['actions']['preview']['#attributes']['class'][] = 'hidden-form-field';
        }

        if (isset($form['actions']['submit'])) {
          $form['actions']['submit']['#value'] = 'Submit';
        }
      }
      $form['actions']['submit']['#submit'][] = 'sp_learningmod_redirect_after_submit';
    }
  }
}

/**
 * Implements hook_preprocess_page().
 */
function sp_learningmod_preprocess_page(&$variables)
{
  $user = \Drupal::currentUser();
  $allowed_roles = ['sp_learningmod_user'];

  if (array_intersect($allowed_roles, $user->getRoles())) {
    $messages = \Drupal::messenger()->all();

    foreach ($messages as $type => $message_list) {
      if ($type === 'status') {
        \Drupal::messenger()->deleteAll($type);
      }
    }
  }

  if (\Drupal::routeMatch()->getRouteName() == 'sp_learningmod.council_meeting') {
    $variables['#attached']['library'][] = 'core/drupal.ajax';
  }
}

/**
 * Implements hook_entity_presave().
 */
function sp_learningmod_entity_presave(\Drupal\Core\Entity\EntityInterface $entity)
{
  if ($entity->getEntityTypeId() === 'user' && $entity->isNew()) {
    $entity->addRole('sp_learningmod_user');
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function sp_learningmod_form_user_register_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
  if (isset($form['field_metatag'])) {
    unset($form['field_metatag']);
  }
}

/**
 * Submit handler for redirect after CQ form submission.
 */
function sp_learningmod_redirect_after_submit($form, FormStateInterface $form_state)
{
  $redirect_path = '/learning/prostitution/critical-questions-worksheets';

  $node = $form_state->getFormObject()->getEntity();

  if ($node instanceof NodeInterface && !$form_state->hasAnyErrors()) {
    \Drupal::logger('sp_learningmod')->notice('Node saved by %user, redirecting to %url', [
      '%user' => \Drupal::currentUser()->getDisplayName(),
      '%url' => $redirect_path
    ]);

    $form_state->setRedirectUrl(Url::fromUserInput($redirect_path));
  }
}
