<?php

use Drupal\node\Entity\Node;
use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;
use Drupal\Core\Url;

/**
 * Implements hook_page_attachments().
 * 
 * Attach the AJAX library and pass node context to JavaScript.
 */
function sp_learningmod_page_attachments(array &$attachments)
{
  $attachments['#attached']['library'][] = 'sp_learningmod/ajax_state';

  $route_match = \Drupal::routeMatch();
  $node = $route_match->getParameter('node');

  if ($node instanceof Node && _sp_learningmod_is_trackable_node($node)) {
    $attachments['#attached']['drupalSettings']['sp_learningmod']['currentNodeId'] = $node->id();
  }
}

/**
 * Implements hook_preprocess_block().
 */
function sp_learningmod_preprocess_block(&$variables)
{
  $block_id = $variables['plugin_id'];

  if ($block_id == 'system_main_block') {

    $route_match = \Drupal::service('current_route_match');
    $node = $route_match->getParameter('node');

    if ($node instanceof Node && _sp_learningmod_should_show_banner($node)) {
      $already_added = TRUE;

      $track_nid = _sp_learningmod_is_trackable_node($node) ? $node->id() : '';
      $variables['content']['#prefix'] = _sp_learningmod_get_banner_html($track_nid) . ($variables['content']['#prefix'] ?? '');
      $variables['#cache']['contexts'][] = 'url.path';
    }
  }
}

/**
 * Helper: Check if a node INCREMENTS the budget when visited.
 */
function _sp_learningmod_is_trackable_node($node)
{
  if (!$node instanceof Node) {
    return FALSE;
  }

  $budget_types = ['sp_analyze_interview', 'sp_analyze_other_research', 'sp_analyze_report'];

  return in_array($node->bundle(), $budget_types);
}

function _sp_learningmod_is_analyze_path()
{
  $current_path = \Drupal::service('path.current')->getPath();
  $path_alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);

  $analyze_patterns = [
    '/learning/prostitution/analyze-problem',
    '/learning/prostitution/analyze/',
  ];

  foreach ($analyze_patterns as $pattern) {
    if ($path_alias === $pattern || strpos($path_alias, $pattern) === 0) {
      return TRUE;
    }
  }

  return FALSE;
}

function _sp_learningmod_is_analyze_article($node)
{
  if (!$node instanceof Node) {
    return FALSE;
  }

  if ($node->getType() === 'sp_article' && $node->hasField('field_type_of_sp_article')) {
    foreach ($node->get('field_type_of_sp_article')->referencedEntities() as $term) {
      if ($term->id() == 220) {
        return TRUE;
      }
    }
  }

  return FALSE;
}

function _sp_learningmod_should_show_banner($node = NULL)
{
  if ($node && _sp_learningmod_is_trackable_node($node)) {
    return TRUE;
  }

  if ($node && _sp_learningmod_is_analyze_article($node)) {
    return TRUE;
  }

  if (_sp_learningmod_is_analyze_path()) {
    return TRUE;
  }

  return FALSE;
}

function _sp_learningmod_get_banner_html($nid)
{
  return '
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-12">
                <div id="budget-banner" class="alert alert-info" data-sp-track-nid="' . $nid . '">
                    <div class="info-container">
                        <i class="fas fa-info-circle info-icon"></i>
                        <div class="text-container">
                            <div>Analyze the Problem</div>
                            <div><strong>Budget spent:</strong></div>
                            <div class="sp-progress-container">
                                <div class="sp-budget-bar" data-percentage="0">
                                    <span class="loading-indicator">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <span class="close-btn cerrar-boton" data-bs-dismiss="alert" role="button" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>';
}

/**
 * Implements hook_preprocess_html().
 */
function sp_learningmod_preprocess_html(&$variables)
{
  $user = \Drupal::currentUser();

  if (in_array('sp_learningmod_user', $user->getRoles())) {
    $variables['attributes']['class'][] = 'sp-learningmod-user-form';
  }

  $variables['#attached']['library'][] = 'sp_learningmod/ajax_state';
  $variables['#attached']['library'][] = 'sp_learningmod/budget_banner';
  $variables['#attached']['library'][] = 'sp_learningmod/cq_style';
  $variables['#attached']['library'][] = 'sp_learningmod/feedback_styles';
  $variables['#attached']['library'][] = 'sp_learningmod/map_navigation';
}

