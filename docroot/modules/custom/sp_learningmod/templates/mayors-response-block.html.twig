{% if submitted %}
	<div class="container bg-white p-4 rounded shadow" style="max-width:700px;">
		<div class="row align-items-center mb-3">
			<div class="col-md-6">
				<p class="text-muted mt-2">
					<strong>Mark L. Coleman</strong><br>
					<span>Office of the Mayor</span><br>
					<span>325 Scott Avenue</span><br>
					<span>Central City</span>
				</p>
			</div>
			<div class="col-md-6 text-end">
				<img src="/sites/default/files/cc-logo.gif" alt="Central City logo" width="108" height="76" loading="lazy">
			</div>
		</div>
		<h3 class="fw-bold">Memorandum</h3>
		<div class="mayor-message">
			{{ budget_message|raw }}
		</div>
		<p>As I mentioned earlier, I (and the council) would prefer solutions that are long term, and that get at the underlying causes of the problem.</p>
		<p>You recommended the following responses:</p>
		{% if responses_titles %}
			<ul>
				{% for title in responses_titles %}
					<li>{{ title }}</li>
				{% endfor %}
			</ul>
		{% endif %}
		<p>Here are my reactions to your plan:</p>
		<div class="mayor-message">
			{{ risk_message|raw }}
			{{ crimeprevent_message|raw }}
			{{ lawenforce_message|raw }}
			{{ final_message|raw }}
		</div>
		<div class="mt-4">
			<img class="img-fluid" src="/sites/default/files/inline-images/memo_r3_c1_0.png" width="152" height="48" loading="lazy">
			<p>
				<strong>M.L. Coleman</strong>
			</p>
		</div>
		<p class="mt-3">
			<a class="btn btn-maroon" href="/learning/prostitution/feedback/year-later" role="button">
				<span class="text">Continue</span>
			</a>
		</p>
	</div>
{% else %}
	<p>You have not submitted a plan yet.</p>
	<p>Please return to
		<a href='/learning/prostitution/plan/reviewmyplan'>Review My Plan</a>
		and submit it first.</p>
{% endif %}
