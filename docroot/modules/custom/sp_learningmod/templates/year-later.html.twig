{% if submitted %}
	<div class="container bg-white p-4 rounded shadow" style="max-width: 800px;">
		<h2 class="fw-bold">{{ title }}</h2>
		<p>{{ description }}</p>

		<div class="uds-table">
			<table>
				<thead>
					<tr>
						{% for header in table_header %}
							<th>{{ header }}</th>
						{% endfor %}
					</tr>
				</thead>
				<tbody>
					{% for row in table_rows %}
						<tr>
							<td>{{ row.metric }}</td>
							<td>{{ row.initval }}</td>
							<td>{{ row.onemo }}</td>
							<td>{{ row.sixmo }}</td>
							<td>{{ row.year }}</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

		<p class="mt-3">
			<a class="btn btn-maroon" href="/learning/prostitution/feedback/response-analysis" role="button">
				<span class="text">Continue</span>
			</a>
		</p>
	</div>
{% else %}
	<p>You have not submitted a plan yet.</p>
	<p>Please return to
		<a href='/learning/prostitution/plan/reviewmyplan'>Review My Plan</a>
		and submit it first.</p>
{% endif %}
