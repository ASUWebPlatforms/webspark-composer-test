        'uid' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'The user ID.',
        ],
        'current_question' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Current question number in the quiz.',
        ],
        'completed' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Whether quiz is completed.',
        ],
        'passed' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Whether user passed the quiz.',
        ],
        'feedback_shown' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Whether feedback has been shown for current question.',
        ],
        'updated' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Timestamp of last update.',
        ],
      ],
      'primary key' => ['uid'],
    ];

    $schema->createTable('sp_learningmod_council_progress', $table);
    $messages[] = 'Created sp_learningmod_council_progress table with correct schema.';
  }

  if (
    $schema->tableExists('sp_learningmod_council_progress') &&
    !$schema->fieldExists('sp_learningmod_council_progress', 'feedback_shown')
  ) {
    $schema->addField('sp_learningmod_council_progress', 'feedback_shown', [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Whether feedback has been shown for current question.',
    ]);
    $messages[] = 'Added feedback_shown field.';
  }

  if (
    $schema->tableExists('sp_learningmod_council_progress') &&
    !$schema->fieldExists('sp_learningmod_council_progress', 'updated')
  ) {
    $schema->addField('sp_learningmod_council_progress', 'updated', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp of last update.',
    ]);
    $messages[] = 'Added updated field.';
  }

  return empty($messages) ? t('No changes needed.') : t(implode(' ', $messages));
}

