/**
 * Add submitted_at field to sp_learningmod_submitted_plans table.
 */
function sp_learningmod_update_9008()
{
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('sp_learningmod_submitted_plans')) {
    // Si la tabla no existe por alguna razón, créala completa.
    $schema->createTable('sp_learningmod_submitted_plans', [
      'description' => 'Tracks submitted plans.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'uid' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'The user ID.',
        ],
        'submitted_at' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Timestamp when plan was submitted.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'uid' => ['uid'],
      ],
    ]);

    return t('Created sp_learningmod_submitted_plans table.');
  }

  if (!$schema->fieldExists('sp_learningmod_submitted_plans', 'submitted_at')) {
    $schema->addField('sp_learningmod_submitted_plans', 'submitted_at', [
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Timestamp when plan was submitted.',
    ]);

    return t('Added submitted_at field to sp_learningmod_submitted_plans.');
  }

  return t('submitted_at already exists.');
}
