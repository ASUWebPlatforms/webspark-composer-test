{#
/**
 * @file
 * Default template for feed displays that use the RSS style.
 *
 * Available variables:
 * - link: The link to the feed (the view path).
 * - namespaces: The XML namespaces (added automatically).
 * - title: The title of the feed (as set in the view).
 * - description: The feed description (from feed settings).
 * - langcode: The language encoding.
 * - channel_elements: The formatted channel elements.
 * - items: The feed items themselves.
 *
 * @see template_preprocess_views_view_rss()
 *
 * @ingroup themeable
 */
#}
<box version="1.0">
  <tabs>
    
   {% if grouped_rows|length > 0 %}
     {% for skey,srows in sorted_tabs %}
       
        {% for sinnerkey, srowvalue in srows %}
             
        <tabitem title="{{ sinnerkey }}">
                <![CDATA[
                <div {{ attributes.addClass('myasu-cb-wrapper') }}>
                   {% for key, rows in grouped_rows %}
                     {% if key == srowvalue %}
                       {% for innerkey, rowvalue in rows %}
                          {{ rowvalue | raw }}
                       {% endfor %}
                     {% endif %}
                    {% endfor %}
                    {% if tabrows.field_myasu_cb_tab_footer.value  %}
                     {{ tab_footer_div_begin | raw }}
                     {{ tabrows.field_myasu_cb_tab_footer.value | raw }}
                     {{ tab_footer_div_end | raw }}
                    {% else %}
                     {{ myasu_cb_footer | raw }}
                    {% endif %} 
               </div>
                ]]>
        </tabitem>
      {% endfor %}
      {% endfor %}
    
    {% else %}
    <tabitem title="Welcome">
        <![CDATA[
          {{ myasu_cb_default_message | raw }}
        ]]>
    </tabitem>
    {% endif %}
  </tabs>
</box>
