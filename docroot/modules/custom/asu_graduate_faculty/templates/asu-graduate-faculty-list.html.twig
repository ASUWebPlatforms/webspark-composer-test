{{ attach_library('asu_graduate_faculty/vanilla-sort') }}
{{ attach_library('asu_graduate_faculty/ajax-endorsement') }}

<div class="container">
  <div class="row">
    <div class="col-lg-12">
      <h1 class="p-2">{{ title }}</h1>
    </div>
    <div class="col-lg-12">
      <p class="px-2 pb-1">{{ searchSummary|raw }}</p>
    </div>
    <div class="col-lg-12">
      <ul>
        {% for row in rows %}
          <li><a href="/graduate-faculty/degree/{{ row.plancode }}">{{ row.plan_descr }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>