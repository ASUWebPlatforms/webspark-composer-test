
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
] %}

<div{{ attributes.addClass(classes) }}>
  {{ title_suffix }}
    {% block content %}
    <div class="container">

        <div class="card-slideup--group d-flex flex-wrap align-items-stretch justify-content-stretch {{ content.field_card_arrangement_display|render|striptags|trim }}">
            {{ content.field_card_group|render }} 
        </div>

    </div>
    {% endblock %}
</div>