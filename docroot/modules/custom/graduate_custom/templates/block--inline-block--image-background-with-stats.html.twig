
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
] %}
{% set hero_background = file_url(content.field_media[0]['#media'].field_media_image.entity.uri.value) %}

<div{{ attributes.addClass(classes) }}>
  {{ title_suffix }}
    <div class="background-with-stats" style="background: url('{{ hero_background }}')">
        <div class="container">
            {% block content %}
            <div class="card-statistic--group d-flex align-items-center justify-content-stretch {{ content.field_card_arrangement_display|render|striptags|trim }}">
                {{ content.field_card_group|render }} 
            </div>
            {% endblock %}
        </div>
    </div>
</div>