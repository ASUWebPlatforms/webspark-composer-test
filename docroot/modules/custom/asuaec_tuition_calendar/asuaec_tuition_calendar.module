/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Tuition and Billing previous semester calendar
 *   Change dropdown options (exposed filter) for semesters
 */
function asuaec_tuition_calendar_form_views_exposed_form_alter(&$form, FormStateInterface $form_state, $form_id) {
    if ( $form_state->get('view')->id() == 'tuition_and_billing_previous_semester_calendar') {
        $options = $form['field_academic_term_target_id']['#options'];
        $form['field_academic_term_target_id']['#options'] = processAndSort($options);
    }
}

/**
 * Remove future semesters and sort.
 *
 * @param $options
 * @return array
 */
function processAndSort($options) {
    // Sort ascending first
    uasort($options, 'sortEntryTermAscending');

    $current_year_semester = getCurrentYearSemesterCombo(); // Get current "year semester" combo such as "2022 Spring"
    $options_processed = [];
    $temp_array = [];
    // Remove future years from array
    foreach ($options as $key => $value) {
        // if it is Any, remove it
        if($value == "- Any -") {
            $temp_array[$key] = "Please select a semester.";

        } else if($value == $current_year_semester) {
            // Stop there
            break;
        } else {
            $options_processed[$key] = $value;
        }
    }
    // Reverse array to decending
    uasort($options_processed, 'sortEntryTermDecending');
    // Add "Please select" at the top of the array
    $options_processed = $temp_array + $options_processed;
    return $options_processed;
}

/**
 * Used for sort decending by "year semester" combo such as "2022 Spring"
 *
 * @param $a
 * @param $b
 * @return mixed
 */
function sortEntryTermDecending($a, $b) {
    $a_exploded_array = explode(' ', $a);
    $b_exploded_array = explode(' ', $b);
    if($a_exploded_array[0] != $b_exploded_array[0]) { // $a_exploded_array[0] contains year such as 2022.
        return $b_exploded_array[0] - $a_exploded_array[0];
    } else {
        // Get term number: 1, 4, 7
        $a_term_num = getTermNumber($a_exploded_array[1]); // $a_exploded_array[1] contains semester such as "Spring"
        $b_term_num = getTermNumber($b_exploded_array[1]);
        return $b_term_num - $a_term_num;
    }
}

/**
 * Used for sort ascending by "year semester" combo such as "2022 Spring"
 *
 * @param $a
 * @param $b
 * @return mixed
 */
function sortEntryTermAscending($a, $b) {
    $a_exploded_array = explode(' ', $a);
    $b_exploded_array = explode(' ', $b);
    if($a_exploded_array[0] != $b_exploded_array[0]) { // $a_exploded_array[0] contains year such as 2022.
        return intval($a_exploded_array[0]) - intval($b_exploded_array[0]);

    } else {
        // Get term number: 1, 4, 7
        $a_term_num = getTermNumber($a_exploded_array[1]); // $a_exploded_array[1] contains semester such as "Spring"
        $b_term_num = getTermNumber($b_exploded_array[1]);
        return $a_term_num - $b_term_num;
    }
}

/**
 * Helping function
 * Return Entry term number: 1, 4 or 7
 *
 * @param $semester
 * @return int|void
 */
function getTermNumber($semester) {
    if($semester == "Spring") {
        return 1;
    } else if ($semester == "Summer") {
        return 4;
    } else if ($semester == "Fall") {
        return 7;
    }
}

/**
 * Helping function
 * Return current year and semester combo such as "2022 Spring"
 *
 * @return string
 */
function getCurrentYearSemesterCombo()
{
    $semester = '';
    // Today's date
    $current_year = date('Y'); // 2022
    $current_month = date('n'); // 1 through 12
    $current_date = date('j'); // 1 to 31

    if ($current_month >= 1 && $current_month <= 4) { // Jan - April
        $semester = "Spring";
    } else if ($current_month == 5) { // May
        if($current_date <= 15) {
            $semester = "Spring";
        } else {
            $semester = "Summer";
        }
    } else if (($current_month >= 6 && $current_month <= 7)) { // June - July
        $semester = "Summer";
    } else if ($current_month == 8) { // August
        if($current_date <= 6) {
            $semester = "Summer";
        } else {
            $semester = "Fall";
        }
    } else if (($current_month >= 9 && $current_month <= 12)) { // September - December
        $semester = "Fall";
    }
    return $current_year . " " . $semester;
}

