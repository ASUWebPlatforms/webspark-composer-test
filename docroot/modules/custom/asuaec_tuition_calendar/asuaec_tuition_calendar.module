/**
 * Implements hook_views_pre_view
 *
 * Set default value for when page loaded
 *
 * @param ViewExecutable $view
 * @param $display_id
 * @param array $args
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 */
function asuaec_tuition_calendar_views_pre_view(ViewExecutable $view, $display_id, array &$args)
{
    // Tuition and Billing
    if (($view->id() == 'tuition_and_billing_calendar' && $display_id == "block_1") || ($view->id() == 'tuition_and_billing_calendar' && $display_id == "attachment_2")) {
        // Set default value for when page loaded
        $filters = $view->getDisplay()->getOption('filters');
        $filters["field_ps_value_value"]["value"] = getDefaultPsTermValue();
        $view->display_handler->overrideOption('filters', $filters);

    }

    // Term buttons - Set filter programaticaly. We want to show current semester and future semesters based on today's date. - Tuition and Billing
    if ($view->id() == 'tuition_and_billing_calendar' && $display_id == "block_3") {
        // Set default value for when page loaded
        $filters = $view->getDisplay()->getOption('filters');
        $filters["field_peoplesoft_value_numeric_value"]["operator"] = '>=';
//        ksm(getDefaultPsTermValue(), "getdefault");
        $filters["field_peoplesoft_value_numeric_value"]["value"]["value"] = getDefaultPsTermValue();
        $view->display_handler->overrideOption('filters', $filters);
    }

    // Financial aid
    // Set default value when page loaded.
    if (($view->id() == 'financial_aid_calendar' && $display_id == "block_1") || ($view->id() == 'financial_aid_calendar' && $display_id == "attachment_5")) {
        $filters = $view->getDisplay()->getOption('filters');
        unset($filters["field_academic_year_target_id"]["value"]);
        $filters["field_academic_year_target_id"]["value"][0] = getDefaultAcademicYearTid();
        $view->display_handler->overrideOption('filters', $filters);
    }

}

/**
 * Figure out what we should use for default value (ps_value) based on today's date (current time).
 *
 * @return mixed
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 */
function getDefaultPsTermValue () {

    // Get academic_term taxonomy term data.
    $vid = 'academic_term';
    $terms = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadTree($vid);
    foreach ($terms as $term) {
        $term_obj = Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($term->tid);
//        ksm($term_obj->get('field_date_range2')->end_value, "end date");
        $term_data[] = [
            'tid' => $term->tid,
//    'tname' => $term->name,
            'ps_value' => $term_obj->get('field_ps_value')->value,
            'date_end' => $term_obj->get('field_date_range2')->end_value,
        ];
    }

    // Sorted by ps_value. Future ones first.
    usort($term_data, 'sortByPSValue');
    // Get timestamp of today's date (current time).
    $today_timestamp = time();
    //ksm($today_timestamp, "today_timestamp");
    //$today_timestamp = 1672531200; // For testing 1/1/2023

    // Finally, find out what we should use for default value.
    $i = 0;
    foreach($term_data as $data) {
        foreach($data as $key => $value) {
            if($key == "date_end") {
                if(getTimestamp($value) < $today_timestamp) {
                    // Stop there
                    break 2;
                }
            }
        }
        $i++;
    }
//    ksm($i, "i");
//    ksm($term_data[$i-1]['ps_value'], "ret val");
    return $term_data[$i-1]['ps_value'];
} // END OF function getDefaultPsTermValue ()

/**
 * Returns tid for the default year based on today's date (current time) - Financial aid
 *
 * @return mixed
 * @throws \Drupal\Component\Plugin\Exception\InvalidPluginDefinitionException
 * @throws \Drupal\Component\Plugin\Exception\PluginNotFoundException
 */
function getDefaultAcademicYearTid () {

    // Get academic_term taxonomy term data.
    $vid = 'academic_year';
    $years = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->loadTree($vid);
    foreach ($years as $year) {
        $year_obj = Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($year->tid);
        $year_data[] = [
            'tid' => $year->tid,
            'name' => $year->name,
            'ps_value' => $year_obj->get('field_ps_value')->value,
            'date_end' => $year_obj->get('field_date_range2')->end_value, // <-- End date of the date range
        ];
    }
    // Sorted by date_range. Future ones first.
    usort($year_data, 'sortByPSValue');

    // Get timestamp of today's date (current time).
    $today_timestamp = time();
//    //$today_timestamp = 1672531200; // For testing 1/1/2023

    // Finally, find out what we should use for default value
    $i = 0;
    foreach($year_data as $data) {
        foreach($data as $key => $value) {
            if($key == "date_end") {
                if(getTimestamp($value) < $today_timestamp) {
                    // Stop there
                    break 2;
                }
            }
        }
        $i++;
    }
    return $year_data[$i-1]['tid'];
} // END OF function getDefaultAcademicYearTid ()

/**
 * Helping funciton - Get timestamp from '2022-5-17'.
 *
 * @param $date
 * @return int|void
 */
function getTimestamp($date) {
    $d = DateTime::createFromFormat('Y-m-d', $date);
    $timestamp = '';
    if ($d === false) {
        die("Incorrect date string");
    } else {
        $timestamp = $d->getTimestamp();
    }
    return $timestamp;
}

/**
 * Helping funciton - Used for sort by ps_value
 *
 * @param $a
 * @param $b
 * @return mixed
 */
function sortByPSValue($a, $b) {
//    return $a['ps_value'] - $b['ps_value']; // accending
    return $b['ps_value'] - $a['ps_value'];  // descending
}

