/**
 * Implements hook_views_pre_render()
 *
 * Add JS/CSS.
 *
 * @param ViewExecutable $view
 */
function asuaec_tuition_calendar_views_pre_render(ViewExecutable $view) {
    if ((isset($view) && ($view->storage->id() == 'important_dates')) ||
        (isset($view) && ($view->storage->id() == 'tuition_and_billing_calendar')) ||
        (isset($view) && ($view->storage->id() == 'financial_aid_calendar')) ||
        (isset($view) && ($view->storage->id() == 'tuition_and_billing_previous_semester_calendar'))
    ) {
        $view->element['#attached']['library'][] = 'asuaec_tuition_calendar/tuition-calendar-library';
    }
}

