function _asu_allowed_values_custom_edit_callback_group($form, FormStateInterface $form_state) {
    $nid = $form_state->getValue('nid');
    $node = Node::load($nid);
   //ksm($nid);
    // Index-Array for wanted groups ( gid => gid )
    $gids = $form_state->getValue('field_select_group_list');


    $gids_wanted = [];
    foreach ($gids as $gid) {
        $gids_wanted[$gid['value']] = $gid['value'];
    }
	//ksm($gids_wanted);
	$plugin_id = 'group_node:' . $node->bundle();


	// Get a database connection.
	$connection = Database::getConnection();
	// Build the query.

	$query = $connection->select('group_relationship_field_data', 'gr')
		->fields('gr') // Select all fields.
		->condition('entity_id', $nid,'=')
		->condition('plugin_id', $plugin_id,'=');

	// Execute the query and fetch the results.
	$result = $query->execute()->fetchAll(); // Fetch all results indexed by group ID (gid).
	//ksm($result);
	$groupIds = [];
	foreach ($result as $record) {
		//ksm($record);
    	$gids_existing[] = $record->gid;
  	}
	//ksm($gids_existing);
	// Index-Array gnodes to create
	// Union for existing and wanted groups
	if(!empty($gids_existing)){
		$gids_union = $gids_existing + $gids_wanted;
	}
	else{
		$gids_union = $gids_wanted;
	}

	//code to delete relationship if group removed

	// = (Union for existing and wanted) minus existing
	 $gids_delete = array_diff($gids_union, $gids_wanted);
	// ksm($gids_delete);
     foreach ($gids_delete as $del_gid) {
         $delgroup = Group::load($del_gid);
		 if ($delgroup) {
            // Check if the relationship exists.
			 $del_existing_relationships = $delgroup->getRelationshipsByEntity($node, $plugin_id);
			 if (!empty($del_existing_relationships)) {
				 // Delete the relationship.
				 foreach ($del_existing_relationships as $del_relationship) {
					 $del_relationship->delete();
				 }
				 \Drupal::messenger()->addMessage('The relationship has been deleted successfully.');

            } else {
				 \Drupal::messenger()->addMessage('No relationship found to delete.');

            }
		}


    }

	// Code to add node to a group
	foreach ($gids_wanted as $gid_val) {

		$group = Group::load($gid_val);

		//$relation = $group->getRelationshipsByEntity($node, $pluginId);
		$existing_relationships = $group->getRelationshipsByEntity($node, $plugin_id);
		//ksm($existing_relationships);
        if (empty($existing_relationships)) {
			$group->addRelationship($node, $plugin_id);
			 \Drupal::messenger()->addMessage('Node relationship added successfully.');
        }

	}

}



//function _group_module_add_user_to_group(User $user ) {
function _group_module_add_user_to_group($form, FormStateInterface $form_state){
		//ksm($user->id());
	//ksm($form_state->getValue('field_user_avail_group'));
	//ksm($form_state);
	    $uid = $form_state->getValue('uid');
	    $user = User::load($uid);

		if(!empty($form_state->getValue('field_user_avail_group'))){
			$group_fields = $form_state->getValue('field_user_avail_group');
		}
		else{
			$group_fields = '';
		}
		//$group_fields = isset($user->get('field_user_avail_group'))?$user->get('field_user_avail_group')->getValue():'';
		//ksm($group_fields);
	    if(!empty($group_fields)){
			foreach ($group_fields as $gid) {
				$gids_wanted[$gid['target_id']] = $gid['target_id'];
			}
		//ksm($gids_wanted);


			// code to remove user from a group
			$connection = Database::getConnection();
			$query = $connection->select('group_relationship_field_data', 'gr')
			->fields('gr') // Select all fields.
			->condition('entity_id', $uid,'=')
			->condition('plugin_id', 'group_membership','=');
			$result = $query->execute()->fetchAll(); // Fetch all results indexed by group ID (gid).

			foreach ($result as $record) {
				$gids_existing[] = $record->gid;
			}
			//ksm($gids_existing);
			// Index-Array gnodes to create
			// Union for existing and wanted groups
			$gids_union = !empty($gids_existing)? $gids_existing + $gids_wanted: $gids_wanted;
			//ksm($gids_union);
			// = (Union for existing and wanted) minus existing
			$gids_create = !empty($gids_existing)?array_diff($gids_union, $gids_existing):$gids_union;
			//ksm($gids_create);

			 foreach ($gids_create as $gid) {
				$group = Group::load($gid);
				if ($group && !$group->getMember($user)) {
				  $group->addMember($user);
				  $group->save();
				  \Drupal::messenger()->addMessage(t('User @uid added to group @gid.', ['@uid' => $uid, '@gid' => $gid]));
				}
			  }

			// = (Union for existing and wanted) minus existing
			 $gids_delete = array_diff($gids_union, $gids_wanted);
			 //ksm($gids_delete);
			 foreach ($gids_delete as $del_gid) {
				$delgroup = Group::load($del_gid);
				if ($delgroup) {
				// Check if the relationship exists.

				$del_existing_relationships = $delgroup->getRelationshipsByEntity($user, 'group_membership');
			  //  ksm($del_existing_relationships);
				if (!empty($del_existing_relationships)) {

					// Delete the relationship.

					foreach ($del_existing_relationships as $del_relationship) {
						// ksm($del_relationship);
						$del_relationship->delete();

					}
				} else {

				   // drupal_set_message('No relationship found to delete.');

				}
			}


			}
	 	}

}
