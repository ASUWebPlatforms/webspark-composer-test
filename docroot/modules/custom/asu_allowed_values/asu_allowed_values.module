 /**
 * Update user page groups dropdown list dropdown list to current users' group list on node creation page
 */
function asu_allowed_values_account_group_list(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
		  $connection = Database::getConnection();
		  $query = $connection->select('groups_field_data', 'gfd')
			->fields('gfd');

		  $result = $query->execute()->fetchAll(); // Fetch all results indexed by group ID (gid).
			//ksm($result);
			$groupIds = [];
			foreach ($result as $record) {
				//ksm($record);
				$gid_options[$record->id] = $record->label;
			}
		 asort($gid_options);
		 return $gid_options;

 }



//** hook_form_views_exposed_form_alter implementation to change parent group text field to drop down in "All content in my groups" view **/
function asu_allowed_values_form_views_exposed_form_alter(&$form, FormStateInterface $form_state, $form_id) {

    if($form['#id'] == "views-exposed-form-nodes-based-on-logged-in-user-groups-page-1"){
        //dpm($form);
        $user = \Drupal\user\Entity\User::load(\Drupal::currentUser()->id());
        $uid= $user->get('uid')->value;
        $database = \Drupal::database();
		//code to get GID of current user

		$query = $database->select('group_relationship_field_data', 'nfv');
		$query->fields('nfv'); // Select all fields from group_relationship_field_data
		$query->join('groups_field_data', 'gfd', 'nfv.gid = gfd.id');

		// Ensure fields() is called on the query object
		$query->addField('gfd', 'id');
		$query->addField('gfd', 'label');
		$query->condition('nfv.uid', $uid, '=');
		$query->condition('nfv.plugin_id', 'group_membership', '!=');
		$query_gid = $query->execute()->fetchAll();

		//code to get group name

		foreach($query_gid as $groups){
            $group_title[$groups->id] = $groups->label;

        }

		if(!empty($group_title)){
			$form['gid_1']['#type'] = 'select';
			$form['gid_1']['#multiple'] = FALSE;

			// Specify the empty option for our select list
			$form['gid_1']['#empty_option'] = t('All groups');

			// Add the $options from above to our select list
			$form['gid_1']['#options'] = $group_title;
			unset($form['gid_1']['#size']);
		}

    }

}


