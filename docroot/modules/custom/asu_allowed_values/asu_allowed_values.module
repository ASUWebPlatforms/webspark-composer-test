/* Get acad plans */
function asu_allowed_values_plan(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
	$database = \Drupal::database();
    $query = $database->select('asu_academic_plans', 'nfv')->fields('nfv', array('acad_plan_code','acad_plan_value'));
    //$query = db_query('select * from {asu_academic_plans}');
	$resultData = $query->execute()->fetchAll();
    foreach($resultData as $results){
        $plan_code = $results->acad_plan_code;
        $plan_value = $results->acad_plan_value;
        $all_plans[$plan_code] = $plan_value;
    }

    $all_plans = array_merge(array('All' => '- Any -'), $all_plans);
    return $all_plans;
}

/* Get weights */
function asu_allowed_values_weights(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable){
    $items = array();
    $i = -10;
    for($i = -10; $i <= 10; $i++) {
      $items[$i] = $i;

    }

    return $items;
}

/* Get terms */
function asu_allowed_values_terms(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable){
	  $database = \Drupal::database();
      $terms = array();
       $query = $database->select('asu_terms', 'nfv')->fields('nfv', array('term_code','term_value'));
       $query_terms = $query->execute()->fetchAll();
      //$query = db_query('select * from {asu_terms} order by term_code DESC');
        foreach($query_terms as $results){
            $term_code = $results->term_code;
            $term_value = $results->term_value;
            $terms[$term_code] = $term_value;
        }

       $defaults = array(
        'All' => ' - Any - ',
        'NotEnrolled' => '- Not Enrolled -',
      );
	  $all_terms = array_merge($defaults, $terms);
      return $all_terms;
     // return $defaults + $terms;
}



/**
 * Get all campuses as an array
 */
function asu_allowed_values_campus(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
    $campuses = array();
	$database = \Drupal::database();
    $query = $database->select('asu_campus', 'nfv')->fields('nfv', array('campus_code','campus_value'));
    $query_campus = $query->execute()->fetchAll();
    //$query = db_query('select * from {asu_campus}');
    foreach($query_campus as $results){
        $campus_code = $results->campus_code;
        $campus_value = $results->campus_value;
        $all_campuses[$campus_code] = $campus_value;
    }

    $all_campuses = array_merge(array('All' => '- Any -'), $all_campuses);
	asort($all_campuses);
    return $all_campuses;
}

/**
 * Update groups dropdown list to current users' group list
 */
function asu_allowed_values_group_list(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
    $group_ids = array();
	$database = \Drupal::database();
    $current_user_groups = [];
    $user = \Drupal\user\Entity\User::load(\Drupal::currentUser()->id());
    $groups = array();
    $uid= $user->get('uid')->value;
    $roles = $user->getRoles();

    //dpm($roles);
    if(in_array('administrator', $roles)){
		$query = $database->select('groups_field_data', 'nfv')->fields('nfv', array('id','label'));
    	$query_gid = $query->execute()->fetchAll();
        //$query_gid = db_query('select * from {groups_field_data}');
        foreach($query_gid as $result_groups){
            $current_user_groups[$result_groups->id] = $result_groups->label;
            asort($current_user_groups);
        }
    }
    else{
        $grp_membership_service = \Drupal::service('group.membership_loader');
        $grps = $grp_membership_service->loadByUser($user);
        foreach ($grps as $grp) {
                $groups[] = $grp->getGroup();
        }
        foreach($groups as $user_group){
            $current_user_groups[$user_group->get('id')->value] = $user_group->get('label')->value;

        }
    }

    //ksm($current_user_groups);
    return $current_user_groups;

}

