/**
 * Alter webform elements.
 *
 * @param array $element
 *   The webform element.
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 *   The current state of the form.
 * @param array $context
 *   An associative array containing the following key-value pairs:
 *   - form: The form structure to which elements is being attached.
 */


/** Implementation of hook_webform_options_alter to alter predefined webform options **/
function asu_contact_webform_custom_options_webform_options_alter(array &$options, array &$element, $id)
{
	//ksm($id,'id');
	/** Code to alter Freshman states dropdown options **/
	if($id == "freshman_states"){
		$query = \Drupal::database();
		$hasData = $query->select('node__field_specialist_state_freshman', 'n')
			->fields('n',['field_specialist_state_freshman_value'])
			->fields('n',['entity_id'])
			->execute()
			->fetchAll();
		
		foreach($hasData as $data){
			$state[$data->field_specialist_state_freshman_value] = $data->field_specialist_state_freshman_value;
		}
		ksort($state);
		
		//unset states that are not needed
		unset($state[1]);
		unset($state[2]);
		unset($state['Canada']);
		unset($state['Canadian Provinces and Territories']);
		unset($state['Canadian Provinces/Territories']);
		//ksm($options);
		$options = $state;
		
	}
	
	
}


    	
	
/*** hook_form_alter for gradudate form to update college and program of interest fields dynamically based on degree level field selection ***/

function asu_contact_webform_custom_options_form_alter(&$form, FormStateInterface $form_state, $form_id){
    //ksm($form_id);
	$confact_form_config = \Drupal::config('asu_contact_webform_custom_options.contact_form_formnid_settings');
	$undergrad_nid = $confact_form_config->get('undergrad_contact_form_nid');
	$grad_nid = $confact_form_config->get('grad_contact_form_nid');

	/** International advisors content type form **/
	if(($form_id == "node_international_advisors_form") || ($form_id == "node_international_advisors_edit_form")){
		$form['field_select_country']['#prefix'] = '<div id="ajax-intl-countries-list">';
		$form['field_select_country']['#suffix'] = "</div>";
		//ksm($form['field_select_country']['widget']['#options']);
		$form['field_intl_region']['widget']['#ajax'] = [
		    'callback' => 'updateCckInternationalCountry',
		    'wrapper' => 'ajax-intl-countries-list',
			'event' => 'change',
		];
		
	}
	
	/** undergrad form form alter **/
	if(($form_id == "webform_submission_graduate_contact_form_add_form") || ($form_id == "webform_submission_graduate_contact_form_node_".$grad_nid."_add_form")){
		//attach library
		$form['#attached']['library'][] = 'asu_contact_webform_custom_options/gardContactFormLib';
		$form['#validate'][] = 'asu_contact_webform_custom_options_custom_validation';
		
		/** add wrappers to fields **/
		$form['elements']['graduate_form']['degree_details']['select_area_of_interest']['#prefix'] = '<div class="req-field"><span class="interest-text"><strong>Please select one option: *</strong></span><br /><div class="uds-card-arrangement"><div class="uds-card-arrangement-card-container auto-arrangement two-columns grad-progams">';
		$form['elements']['graduate_form']['degree_details']['select_a_school_or_college']['#prefix'] = '<div id="grad-college-wrapper">';
		$form['elements']['graduate_form']['degree_details']['select_a_school_or_college']['#suffix'] = '</div></div></div></div>';
		$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#prefix'] = '<div id="ajax-programs-list">';
		$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#suffix'] = '</div>';
		$form['elements']['graduate_form']['degree_details']['start_term']['#prefix'] = '<div id="grad-start-date-wrapper"><div id="term-error-message"></div>';
		$form['elements']['graduate_form']['degree_details']['start_term']['#suffix'] = '</div>';
		
		$form['elements']['graduate_form']['degree_details']['select_a_school_or_college']['#validated'] = TRUE; //add this line to override validation 
		$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#validated'] = TRUE; //add this line to override validation 
		$form['elements']['graduate_form']['degree_details']['start_term']['#validated'] = TRUE; //add this line to override validation 
		
		
		/** add ajax functionality to dynamically update college drop down options when degree level field is changed **/
	    $form['elements']['graduate_form']['degree_details']['degree_level']['#ajax'] = [
		    'callback' => 'updateGradCollege',
		    'wrapper' => 'grad-college-wrapper',
			'event' => 'change',
		    
	    ];
		
	    $form['elements']['graduate_form']['degree_details']['select_area_of_interest']['#ajax'] = [
		    'callback' => 'updateGradInterestProgram',
		    'wrapper' => 'ajax-programs-list',
			'event' => 'change',
		];
		
	    $form['elements']['graduate_form']['degree_details']['select_a_school_or_college']['#ajax'] = [
		    'callback' => 'updateGradCollegeProgram',
		    'wrapper' => 'ajax-programs-list',
			'event' => 'change',
		    
	    ];
		
		$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#ajax'] = [
		    'callback' => 'updateStartTerm',
		    'wrapper' => 'grad-start-date-wrapper',
			'event' => 'change',
		    
	    ];
	}
	
	
   /** hook_form_alter for undergrad form to update freshman state field dropdown values and update autocomplete field options **/	
   if(($form_id == "webform_submission_contact_undergrad_form_add_form") || ($form_id == "webform_submission_contact_undergrad_form_node_".$undergrad_nid."_add_form")){
	  
	   
	   //add wrapper to highs school
	   $form['elements']['high_school_names']['#prefix'] = '<div id="hs-wrapper">';
	   $form['elements']['high_school_names']['#suffix'] = '</div>';
	   $form['elements']['high_school_names']['#validated'] = TRUE;
	
	   $form['elements']['domestic_hs_rep_info']['#prefix'] = '<div id="domestic-hs-rep-wrapper">';
	   $form['elements']['domestic_hs_rep_info']['#suffix'] = '</div>';
	   $form['elements']['domestic_hs_rep_info']['#attributes']['class'] = array('class' => array("show-rep-info-div pl-5"));
	   
	
	   $form['#attached']['library'][] = 'asu_contact_webform_custom_options/undergardContactFormLib';
		
	   /** add ajax functionality to freshman state field so that high school reps info is updated based on state and/or school selection **/
	   $form['elements']['freshman_state']['#ajax'] = [
		    'callback' => 'updateHighSchool',
		    'wrapper' => 'hs-wrapper',
		    'event' => 'change',
	   ];
	   
	   /** add ajax functionality to international advisors region field **/
	   $form['elements']['international_section']['international_select_your_region']['#ajax'] = [
		    'callback' => 'updateInternationalCountry',
		    'wrapper' => 'intl-country-wrapper',
		    'event' => 'change',
	   ];
	   
	   $form['elements']['international_section']['select_custom_international_country']['#prefix'] = '<div id="intl-country-wrapper">';
	   $form['elements']['international_section']['select_custom_international_country']['#suffix'] = '</div>';
	   $form['elements']['international_section']['select_custom_international_country']['#validated'] = TRUE;
	   
	   
	   /** Add custom autocomplete route to high schools field **/
	   $form['elements']['high_school_autocomplete']['#autocomplete_route_name'] = 'asu_contact_webform_custom_options.highSchoolAutocomplete';
	   $form['elements']['high_school_autocomplete']['#attributes']['placeholder'] = t('Enter high school');
	   
	   /** Add custom autocomplete route to Transfer Arizona institutions field **/
	   $form['elements']['transfer_fields']['select_arizona_college_or_university']['#autocomplete_route_name'] = 'asu_contact_webform_custom_options.transferArizonaInstitutes';
	   $form['elements']['transfer_fields']['select_arizona_college_or_university']['#attributes']['placeholder'] = t('Select Arizona college or univeristy');
	   
	   /** Add custom autocomplete route to Transfer California institutions **/
	   $form['elements']['transfer_fields']['enter_california_college_or_university']['#autocomplete_route_name'] = 'asu_contact_webform_custom_options.transferCaliforniaInstitutes';
	   $form['elements']['transfer_fields']['enter_california_college_or_university']['#attributes']['placeholder'] = t('Select California college or univeristy');
	 
	   return $form;
	 
   }
	
}


/**
 * Custom validation handler.
 */
function asu_contact_webform_custom_options_custom_validation($form, FormStateInterface $form_state) {
 
  $selected_prog_value = $form_state->getValue('select_program_of_interest');
  $selected_term = $form_state->getValue('start_term');
  
  if (empty($selected_prog_value)) {
    $form_state->setErrorByName('select_program_of_interest', t('Please enter select a program of interest.'));
  }
  if (empty($selected_term)) {
    $form_state->setErrorByName('start_term', t('Please enter start term.'));
  }
}

/*Ajax function update international countries list when creating international advisors content type **/
function updateCckInternationalCountry(array $form, FormStateInterface $form_state){
	$form_state->setRebuild(true);
	$intl_region = $form_state->getValue('field_intl_region');
	//ksm($intl_region);
	if(sizeof($intl_region > 1)){
		foreach($intl_region as $all_regions){
			$each_region[$all_regions['value']] = $all_regions['value'];
		}
	}
	else{
		$each_region = $intl_region[0]['value'];
	}
	//ksm($each_region);
	$region = $intl_region[0]['value'];
	$database = \Drupal::database();
	$intl_data = $database->select('taxonomy_term_field_data','atp')
				->fields('atp',['name','tid'])
				//->condition('atp.vid','international_countries')
				->condition('atp.description__value',$each_region,IN)
				->execute()
				->fetchAll();
		
		
		foreach($intl_data as $intl_values){
			
				$intl_countries[$intl_values->tid] = $intl_values->name;
			
		}
	
	
	$form['field_select_country']['widget']['#options'] = $intl_countries;
	return $form['field_select_country'];
}


