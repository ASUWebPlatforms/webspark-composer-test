/* function to update start term field dropdown options dynamically */
function updateStartTerm(array $form, FormStateInterface $form_state){
		$form_state->setRebuild(true);
		$program_code = $form_state->getValue('select_program_of_interest');
	
		$database = \Drupal::database();
		$term_options_array = array();
		$term_options = array();
	    $term_array = array('0'=>'Select a start date');
		$hasTerm = $database->select('asu_grad_interest_category_degrees', 'agd')
			->fields('agd',['categorygraduateAllApplyDates'])
			->condition('agd.categorymajorcode',$program_code)
			->execute()
			->fetchAll();
		
		foreach($hasTerm as $result){
			if($result->categorygraduateAllApplyDates != ''){
			  $term_options_array = explode(',', $result->categorygraduateAllApplyDates);
			}
		}
		foreach($term_options_array as $each_term) {
			$each_term_array = explode(':', $each_term );
			if(!array_key_exists(trim($each_term_array[2]), $term_options)) {
				if(trim($each_term_array[0]) != 'ONLNE') { // Exclude Online.
					$term_array[trim($each_term_array[2])] = getHumanReadableTerm(trim($each_term_array[2]));
				}
			}
		}		
	    
	   
		ksort($term_array);
	   /* show error message if the selected program is not accepting new students at this time based on the term years array size */
	
	   if(sizeof($term_array) == 1){
			$form['elements']['graduate_form']['degree_details']['start_term']['#prefix'] = '<div id="grad-start-date-wrapper"><div id="term-error-message"><p style="color: red;">The program you are interested in is not accepting new students at this time. Please select a different program of interest, and then select the semester you would like to start.</p></div>';
			
		}
		else{
			$form['elements']['graduate_form']['degree_details']['start_term']['#prefix'] = '<div id="grad-start-date-wrapper"><div id="term-error-message"></div>';
		}
		
		$form['elements']['graduate_form']['degree_details']['start_term']['#options'] = $term_array;
	    return $form['elements']['graduate_form']['degree_details']['start_term'];
	
}

/* helper function for start term field */
function getHumanReadableTerm($term_code) {
	$threedigit_year = substr($term_code, 0, 3);
	$year = substr($threedigit_year, 0, 1) . '0' . substr($threedigit_year, 1);
	
	$semester_code = substr($term_code, 3);
	$semester = '';
	switch ($semester_code) {
		case 1:
			$semester = 'Spring';
			break;
		case 4:
			$semester = 'Summer';
			break;
		case 7:
			$semester = 'Fall';
			break;
	}
	return $year . ' ' . $semester;	
}


function updateGradInterestProgram(array $form, FormStateInterface $form_state){	
	$form_state->setRebuild(true);
	$degree_value = $form_state->getValue('degree_level');
	$interest_grad_query = \Drupal::database();
	$acad_interest = $form_state->getValue('select_area_of_interest');
	//ksm($acad_interest);
	$prog_array = array('0'=>'Select program of interest');
	
	if(!empty($degree_value)){
		
		if($degree_value == 21) { // 15 is also Doctoral.
			$grad_prog_Data = $interest_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categorygradtype',[15,21], 'IN')
				->condition("agi.categoryname",$acad_interest)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		elseif($degree_value == "cert"){
			$grad_prog_Data = $interest_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categoryDegreeDescShort','Certificate')
				->condition("agi.categoryname",$acad_interest)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		elseif($degree_value == 17) { 
			$grad_prog_Data = $interest_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categorygradtype',17)
				->condition("agi.categoryname",$acad_interest)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		else{

		}
		foreach($grad_prog_Data as $grad_prog_values){
			
			$prog_values[$grad_prog_values->categorymajorcode] = $grad_prog_values->categorymajorname;
			$prog_array[$grad_prog_values->categorymajorcode] = $grad_prog_values->categorymajorname;
		}
		
	}
	    
	//ksm($prog_array);	
	//array_push($empty_option, $prog_values );
	$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#options'] = $prog_array;
	return $form['elements']['graduate_form']['degree_details']['select_program_of_interest'];
	
}

function updateGradCollegeProgram(array $form, FormStateInterface $form_state){	
	$form_state->setRebuild(true);
	$degree_value = $form_state->getValue('degree_level');
	$college_grad_query = \Drupal::database();
	$college_value = $form_state->getValue('select_a_school_or_college');
	$college_prog_options = array('0'=>'Select program of interest');
	if(!empty($degree_value)){
		
		if($degree_value == 21) { // 15 is also Doctoral.
			$grad_prog_Data = $college_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categorygradtype',[15,21], 'IN')
				->condition("agi.categoryprogramAcadOrg",$college_value)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		elseif($degree_value == "cert"){
			$grad_prog_Data = $college_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categoryDegreeDescShort','Certificate')
				->condition("agi.categoryprogramAcadOrg",$college_value)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		elseif($degree_value == 17) { 
			$grad_prog_Data = $college_grad_query->select('asu_grad_interest_category_degrees', 'agi')
				->fields('agi',['categorymajorcode','categorymajorname'])
				->condition('agi.categorygradtype',17)
				->condition("agi.categoryprogramAcadOrg",$college_value)
				->orderBy('agi.categorymajorname')
				->execute()
				->fetchAll();
		}
		else{

		}
		foreach($grad_prog_Data as $grad_prog_values){
			$college_prog_values[$grad_prog_values->categorymajorcode] = $grad_prog_values->categorymajorname;
			$college_prog_options[$grad_prog_values->categorymajorcode] = $grad_prog_values->categorymajorname;
		}
		
	}
		//ksm($college_prog_values);
		//Append empt option to the array
		

		//array_unshift($prog_values, $empty_option);
		$form['elements']['graduate_form']['degree_details']['select_program_of_interest']['#options'] = $college_prog_options;
		return $form['elements']['graduate_form']['degree_details']['select_program_of_interest'];
	
}


function updateGradCollege(array $form, FormStateInterface $form_state)
{	
	$form_state->setRebuild(true);
	$degree_value = $form_state->getValue('degree_level');
	$grad_query = \Drupal::database();
	$grad_college_values = array('0'=>'Select school or college');
	//$grad_college_array = array('0'=>'Select school or college');
	if($degree_value == 21) { // 15 is also Doctoral.
		$grad_college_Data = $grad_query->select('asu_grad_interest_category_degrees', 'agi')
			->fields('agi',['categoryprogramacadorg','categoryprogramDesrc100'])
			->condition('agi.categorygradtype',[15,21], 'IN')
			->orderBy('agi.categoryprogramDesrc100')
			->execute()
			->fetchAll();
	}
	elseif($degree_value == "cert"){
		$grad_college_Data = $grad_query->select('asu_grad_interest_category_degrees', 'agi')
			->fields('agi',['categoryprogramacadorg','categoryprogramDesrc100'])
			->condition('agi.categoryDegreeDescShort','Certificate')
			->orderBy('agi.categoryprogramDesrc100')
			->execute()
			->fetchAll();
	}
	else{
		$grad_college_Data = $grad_query->select('asu_grad_interest_category_degrees', 'agi')
			->fields('agi',['categoryprogramacadorg','categoryprogramDesrc100'])
			->condition('agi.categorygradtype',$degree_value)
			->orderBy('agi.categoryprogramDesrc100')
			->execute()
			->fetchAll();
	}
	
	foreach($grad_college_Data as $grad_colleges){
		//$grad_colleges[$grad_colleges->categoryprogramacadorg] = $grad_colleges->categoryprogramDesrc100;
		$grad_college_values[$grad_colleges->categoryprogramacadorg] = $grad_colleges->categoryprogramDesrc100;
	}
	//Append empt option to the array
	
	if($degree_value == "nd"){
		$grad_nd_college_values[0] = 'Select school or college';
		$grad_nd_college_values['CAS'] = 'New College of Interdisciplinary Arts and Sciences';
		$grad_nd_college_values['CBA'] = 'W. P. Carey School of Business';
		$grad_nd_college_values['CCS'] = 'Cronkite School of Journalism and Mass Comm';
		$grad_nd_college_values['CES'] = 'Ira A. Fulton School of Engineering';
		$grad_nd_college_values['CGF'] = 'School for the Future of Innovation in Society';
		//$grad_nd_college_values['GRNONDEG'] = 'Graduate College';
		$grad_nd_college_values['CHI'] = 'Herberger Institute';
		$grad_nd_college_values['CLA'] = 'College of Liberal Arts & Sciences';
		//$grad_nd_college_values['LSGRNONDGR'] = 'Letters & Sciences';
		$grad_nd_college_values['CHL'] = 'College of Health Solutions';
		$grad_nd_college_values['CNU'] = 'College of Nursing';
		$grad_nd_college_values['CPP'] = 'College of Public Programs';
		$grad_nd_college_values['CTB'] = 'Thunderbird School of Global Management';
		$grad_nd_college_values['CTE'] = 'Mary Lou Fulton Teachers College';
		asort($grad_nd_college_values);
		$grad_college_array = $grad_nd_college_values;
	}
	else{
		$grad_college_array = $grad_college_values;
	}
	//array_unshift($grad_college_values, $empty_option);
	$form['elements']['graduate_form']['degree_details']['select_a_school_or_college']['#options'] = $grad_college_array;
	return $form['elements']['graduate_form']['degree_details']['select_a_school_or_college'];
}



function updateHighSchool(array $form, FormStateInterface $form_state){
	$form_state->setRebuild(true);
	//ksm($form_state->getValue('freshman_state'));
	$state_value = $form_state->getValue('freshman_state');
	
	if (!empty($state_value)) {
		if($state_value == "Arizona"){
			$form['elements']['high_school_names']['#options'] = getSelect2Options($state_value);
		}
		
	} else {
		$form['elements']['high_school_names']['#options'] = getAllSelect2Options();
	}
	
	
	return $form['elements']['high_school_names'];
	
	
}


function getSelect2Options($state_value){
		$hs_query = \Drupal::database();
		$hashsData = $hs_query->select('node__field_specialist_hs_names', 'fs')
			->fields('fs',['field_specialist_hs_names_value'])
			->execute()
			->fetchAll();
		
		foreach($hashsData as $hsdata){
			$hs_name[$hsdata->field_specialist_hs_names_value] = $hsdata->field_specialist_hs_names_value;
		}
		ksort($hs_name);
		$any = array(' Any ' => 'Enter school name');
		array_unshift($hs_name, $any);
		return $hs_name;
}


function getAllSelect2Options(){
		$hs_nostate_query = \Drupal::database();
		$hsnostateData = $hs_nostate_query->select('asu_webform_highschool_data', 'fs')
			->fields('fs',['hs_id','hs_name'])
			->execute()
			->fetchAll();
		
		foreach($hsnostateData as $hsnostatevalue){
			$hs_nostate_name[$hsnostatevalue->hs_id] = $hsnostatevalue->hs_name;
		}
		return $hs_nostate_name;
}


function getRepInfo($state_selected,$hs_selected){
	$rep_query = \Drupal::database();
	if($state_selected == "Arizona") {
		$hs_value = $hs_selected;
		$rep_fields = $rep_query->select('node_field_data', 'nfv')->fields('nfv', array('nid'));
		$rep_fields->innerJoin('node__field_specialist_state_freshman', 'fstate', 'fstate.entity_id = nfv.nid');
		$rep_fields->innerJoin('node__field_specialist_category', 'fsc','fsc.entity_id = nfv.nid' );
		$rep_fields->leftJoin("node__field_specialist_hs_names",'fshs', 'fshs.entity_id = nfv.nid');
		$rep_fields->condition('fstate.field_specialist_state_freshman_value', $state_selected);
		$rep_fields->condition('fshs.field_specialist_hs_names_value', '%' . $rep_query->escapeLike($hs_value) . '%', 'LIKE');
		$rep_fields->condition('fsc.field_specialist_category_target_id',1);
		$results = $rep_fields->execute()->fetchAll();
	}
	else {
		$hs_value = '';
		$rep_fields = $rep_query->select('node_field_data', 'nfv')->fields('nfv', array('nid'));
		$rep_fields->innerJoin('node__field_specialist_state_freshman', 'fstate', 'fstate.entity_id = nfv.nid');
		$rep_fields->innerJoin('node__field_specialist_category', 'fsc','fsc.entity_id = nfv.nid' );
		$rep_fields->leftJoin("node__field_specialist_hs_names",'fshs', 'fshs.entity_id = nfv.nid');
		$rep_fields->condition('fstate.field_specialist_state_freshman_value', $state_selected);
		$rep_fields->condition('fsc.field_specialist_category_target_id',1);
		$results = $rep_fields->execute()->fetchAll();
	}
	
	$results = $rep_fields->execute()->fetchAll();
	
	foreach($results as $rep_id){
			$node_id[] = $rep_id->nid;
	}
	foreach($node_id as $nid){
		$node = Node::load($nid);
		//ksm($node);
		$fname = $node->field_first_name[0]->value;
		$last_name = $node->field_last_name[0]->value;
		$image_id = $node->field_specialist_image[0]->target_id;
		$phone = $node->field_phone[0]->value;
		$email = $node->field_specialist_email[0]->value;
		$appointment_link = $node->field_phone_or_video_appointment[0]->value;
		$image_uri = File::load($image_id)->getFileUri();
		$rep_image = ImageStyle::load('medium')->buildUri($image_uri);
		$image_path = explode('//', $rep_image);
		
		$new_explode = explode('/',$image_path[1]);
		
		$image_parts = sizeof($new_explode);
		$image_name = $new_explode[$image_parts - 1];
		$rfi_image_path = "/sites/default/files/$image_name";
		$content = "<div>$fname-$last_name<br /><img src='$rfi_image_path' /></div>";
		
		$content = '<div class="col-xs-12 col-sm-6 col-md-12 col-rep-12 col_flex" data-aos="fade-up" data-aos-delay="300" data-aos-once="true">
    <div class="right-col"> <strong>'.$fname.' is your contact</strong><br> <span class="smalltext"> Please contact '.$fname.' for information about admissions, requirements or any other questions you may have.<br>	<br> <i class="fa fa-envelope" aria-hidden="true"> </i><a href="mailto:' . $email . '">' . $email . '</a>&nbsp;&nbsp;  <i class="fa fa-phone" aria-hidden="true"> </i> &nbsp;'.$phone.' </span><br><p>Schedule a time to connect with me: <a href="'.$appointment_link.'">'.$appointment_link.'</a></p><a href="#" id="CounselRepLink"><p class="btn btn-maroon counsel-rep-button">contact '.$fname.'</p></a> </div></div>';
		
		return $content;
	}
	
}

