

{{ attach_library('leadership/resources') }}
{% if logged_in %}
<ul class="nav nav-tabs nav-fill resource-tabs" id="resourceTab" role="tablist">
  <li class="nav-item" role="presentation">
    <a class="nav-link active" id="filter-tab" data-bs-toggle="tab" href="#resource-filters--panel" role="tab" aria-controls="filter" aria-selected="true">Filter</a>
  </li>
  <li class="nav-item" role="presentation">
    <a class="nav-link" id="search-tab" data-bs-toggle="tab" href="#resourse-search--panel" role="tab" aria-controls="search" aria-selected="false">Search</a>
  </li>
</ul>

<div class="tab-content" id="resourceTabContent">
  <div class="tab-pane fade show active" id="resource-filters--panel" role="tabpanel" aria-labelledby="filter-tab">
  {{ drupal_view('content_displays_resources', 'resources_list') }}
  </div>
  <div class="tab-pane fade" id="resourse-search--panel" role="tabpanel" aria-labelledby="search-tab">
  {{ drupal_view('content_displays_resources', 'resources_list_search') }}
  </div>
</div>

{% endif %}