/**
 * Implements hook_page_attachments_alter
 *
 * Include JS if it meets the URL pattern of:
 *   ex:
 */
function asuaec_transferoption_page_attachments_alter(array &$page) {

  $config = \Drupal::config('asuaec_transferoption.settings');
  $degreelistingpage_nid = $config->get('asuaec_transferoption_degreelistingpage_nid');
//    \Drupal::logger('asuaec_transferoption')->notice("degreelistingpage_nid from attachment alter:<pre>" . $degreelistingpage_nid . "</pre>");

  // Get the current path alias.
  $current_path = \Drupal::service('path.current')->getPath();
  $alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
//  \Drupal::logger('asuaec_transferoption')->notice("test from degree detail page - alias:<pre>" . $alias . "</pre>");

  if (preg_match('/(\/bachelors-degrees\/majorinfo\/)(\w+)(\/undergrad\/false\/' . $degreelistingpage_nid . ')/', $alias, $matches) == 1) {
//    \Drupal::logger('asuaec_transferoption')->notice("test from preg_match page :<pre>" . $matches[1] . "</pre>");

    $page['#attached']['library'][] = 'asuaec_transferoption/transferoption-library';

  }
}


/**
 * Implements hook_form_alter().
 *
 * Change the following exposed filters' type from text field to dropdown list:
 *   Campus, Interest, and School/College
 */
function asuaec_transferoption_form_views_exposed_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $view = $form_state->getStorage('view');
  if ((($view['view']->id() == 'transfer_option_search') && ($view['view']->current_display == 'block_1')) ||
    (($view['view']->id() == 'transfer_option_search') && ($view['view']->current_display == 'block_3'))) {

    // Campus dropdown

    //Get all options from DB
    $campusOptions = array();
    $interestOptions = array();
    $commcollegeOptions = array();

    try {
      $database = \Drupal::database();
      $query = $database->select('asu_transferoption_agreement', 'a');
      $query->fields('a', ['CampusStringArray', 'planCatDescr']);
      $result = $query->execute();

      foreach ($result as $record) {

        // Campus dropdown
        $campusStringArray = $record->CampusStringArray;
        $campusTempArray = explode(", ", $campusStringArray);

        foreach($campusTempArray as $campusCode) {
          $campusName = getCampusName($campusCode);
          if (!array_key_exists('$campusCode', $campusOptions)) {
            $campusOptions[$campusCode] = $campusName;
          }
        } // END OF foreach($campusTempArray as $campusCode)

        // Interest dropdown
        $planCatDescr = $record->planCatDescr;
        $interestTempArray = explode('|', $planCatDescr);
        if(sizeof($interestTempArray) > 0) {
          foreach ($interestTempArray as $interestName) {
            if (!in_array(trim($interestName), $interestOptions)) {
              $interestOptions[trim($interestName)] = trim($interestName);
            }
          }
        }

      } // END OF foreach ($result as $record)

      // Include 'Any' option to Campus dropdown
      $campusOptions = asuCampusSort($campusOptions);
      $campusOptions = array('' => 'Any') + $campusOptions;
      // Include 'Any' option to Interest dropdown
      asort($interestOptions);
      $interestOptions = array('' => 'Any') + $interestOptions;

      // School/College dropdown

      $query2 = $database->select('asu_transferoption_agreement', 'a');
      $query2->fields('a', ['DiplomaDescr']);
      $result2 = $query2->distinct()->execute();
      $schoolcollegeOptions = array();
      foreach ($result2 as $record2) {
        $schoolcollegeName = $record2->DiplomaDescr;
        $schoolcollegeOptions[$schoolcollegeName] = $schoolcollegeName;
      }
      asort($schoolcollegeOptions);
      $schoolcollegeOptions = array('' => 'Any') + $schoolcollegeOptions;

      // Comm college dropdown

      if($view['view']->current_display == 'block_3') {
        $query3 = $database->select('asu_transferoption_agreement', 'a');
        $query3->fields('a', ['tACommunityCollege']);
        $result3 = $query3->distinct()->execute();
        $commcollegeOptions = [];
        foreach ($result3 as $record3) {
          $tACommunityCollege = $record3->tACommunityCollege;
          $commcollegeOptions[$tACommunityCollege] = $tACommunityCollege;
        }
        asort($commcollegeOptions);
//        $commcollegeOptions = array('Select' => 'Select') + $commcollegeOptions;
      }

    } catch (Exception $e) {
      \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
    }

    // Hard code it to make the page load faster?
//    $options = array (
//      '' => 'Any',
//      'DTPHX' => 'Downtown Phoenix campus',
//      'POLY' => 'Poly',
//      'TEMPE' => 'Tempe',
//      'WEST' => 'West',
//      'CALHC' => 'Lake Havasu City',
//      'COCHS' => 'ASU@Cochise',
//      'PIMA' => 'ASU@Pima',
//      'CAC' => 'ASU@Pinal',
//      'EAC' => 'ASU@TheGilaValley',
//      'TUCSN' => 'ASU@Tucson',
//      'YAVAP' => 'ASU@Yavapai',
//      'AWC' => 'ASU@Yuma',
//      'ONLNE' => 'ASU Online'
//    );

    // Change the exposed filters' type from text field to dropdown list

    if (isset($form['CampusStringArray'])) {
      $form['CampusStringArray']['#type'] = 'select';
      $form['CampusStringArray']['#options'] = $campusOptions;
      $form['CampusStringArray']['#size'] = 1;
      $form['CampusStringArray']['#default_value'] = '';
    }
    if (isset($form['planCatDescr'])) {
      $form['planCatDescr']['#type'] = 'select';
      $form['planCatDescr']['#options'] = $interestOptions;
      $form['planCatDescr']['#size'] = 1;
      $form['planCatDescr']['#default_value'] = '';
    }
    if (isset($form['DiplomaDescr'])) {
      $form['DiplomaDescr']['#type'] = 'select';
      $form['DiplomaDescr']['#options'] = $schoolcollegeOptions;
      $form['DiplomaDescr']['#size'] = 1;
      $form['DiplomaDescr']['#default_value'] = '';
    }
    if($view['view']->current_display == 'block_3') {
      if (isset($form['tACommunityCollege'])) {
        $form['tACommunityCollege']['#type'] = 'select';
        $form['tACommunityCollege']['#options'] = $commcollegeOptions;
        $form['tACommunityCollege']['#size'] = 1;
        $form['tACommunityCollege']['#default_value'] = "Arizona Western College";
        $form['tACommunityCollege']['#empty_option'] = 'Select';
        unset($form['tACommunityCollege']['#description']);
        unset($form['tACommunityCollege']['#context']);
        unset($form['tACommunityCollege']['#process']);
        unset($form['tACommunityCollege']['#pre_render']);
//        $form['tACommunityCollege']['#validate'] = 'my_custom_validation_callback';
      }
        \Drupal::logger('asuaec_transferoption')->notice("test:<pre>" . print_r($form['tACommunityCollege'], true) . "</pre>");
    }

    // Keywords - Auto complete

    // MAPP and TAG -- Calling a different routing based on a different Views display:
    //   asuaec_transferoption.autocomplete.keywords.mapp
    //   asuaec_transferoption.autocomplete.keywords.tag
    if($view['view']->current_display == 'block_1') { // MAPP
      // Make Auto complete use the following JSON page: ex: /admin/asuaec_transferoption/autocomplete/keywords/mapp?q=bio
      if (isset($form['keywordsCombined'])) {
        $form['keywordsCombined']['#type'] = 'textfield';
        $form['keywordsCombined']['#title'] = t('Keyword Autocomplete');
        $form['keywordsCombined']['#autocomplete_route_name'] = 'asuaec_transferoption.autocomplete.keywords.mapp';
      }

    } else if($view['view']->current_display == 'block_3') { // TAG
      // Make Auto complete use the following JSON page: ex: /admin/asuaec_transferoption/autocomplete/keywords/tag?q=bio
      if (isset($form['keywordsCombined'])) {
        $form['keywordsCombined']['#type'] = 'textfield';
        $form['keywordsCombined']['#title'] = t('Keyword Autocomplete');
        $form['keywordsCombined']['#autocomplete_route_name'] = 'asuaec_transferoption.autocomplete.keywords.tag';
      }
    }

  } // END OF if ((($view['view']->id() == 'transfer_option_search') && ($view['view']->current_display == 'block_1')) || (($view['view']->id() == 'transfer_option_search') && ($view['view']->current_display == 'block_3')))

//  \Drupal::logger('asuaec_transferoption')->notice("test:<pre>" . $form['#id'] . "</pre>");
  if ($form['#id'] == 'views-exposed-form-transfer-option-search-block-3') {
    \Drupal::logger('asuaec_transferoption')->notice("field_tACommunityCollege_value :<pre>" . print_r($form_state->getUserInput(), true) . "</pre>");

//    array_unshift($form['#validate'], 'my_custom_validation_callback');

    // PROBLEM:
    // Validation runs when page loaded before pressing "Apply" button

     if($form_state->getUserInput()['tACommunityCollege'] != '') {
       $form['#validate'][] = 'custom_forms_views_exposed_form_validate';
     }

  }


} // END OF asuaec_transferoption_form_views_exposed_form_alter

function custom_forms_views_exposed_form_validate($form, &$form_state) {
  \Drupal::logger('asuaec_transferoption')->notice("test from preg_match page :<pre>" . "test" . "</pre>");
  \Drupal::logger('asuaec_transferoption')->notice("test from preg_match page :<pre>" . print_r($form_state->getUserInput(), true) . "</pre>");
  if($form_state->getUserInput()['tACommunityCollege'] == '') {
    \Drupal::logger('asuaec_transferoption')->notice("test from preg_match page :<pre>" . "test2" . "</pre>");

    $form_state->setErrorByName('tACommunityCollege', t('You must select comm college.'));

  }
}


