/**
 * Implements hook_theme().
 *
 * Override Views template twig from this module.
 *   /templates/views-view-grouping--transfer-option-search.html.twig
 */
function asuaec_transferoption_theme($existing, $type, $theme, $path){
    return [
      'views_view_grouping__transfer_option_search' => [
          'render element' => 'elements',
          'base hook' => 'views'
      ]
    ];
}

/**
 * Implements hook_preprocess_views_view_field().
 *
 * Convert Campus from code to user-friendly name.
 */
function asuaec_transferoption_preprocess_views_view_field(&$variables) {
  $view = $variables['view'];
  $field = $variables['field'];
  if (
    ($view->storage->id() == 'transfer_option_search' &&
      $view->current_display == 'block_1' &&
      $field->options["id"] == 'CampusStringArray') ||
    ($view->storage->id() == 'transfer_option_search' &&
      $view->current_display == 'block_3' &&
      $field->options["id"] == 'CampusStringArray')
  ) {

      $campusCodeArray = explode(',', (string)$variables['output']);
      $output = '<ul class="list-unstyled">';
      foreach($campusCodeArray as $campusCode) {
        $output .= '<li>' . getCampusName($campusCode) . '</li>';
      }
      $output .= '</ul>';
//      \Drupal::logger('asuaec_transferoption')->notice("testArray: <pre>" . print_r($campusCodeArray, true) . "</pre>");
      $variables['output'] =  [
        '#markup' => $output,
      ];
  } // END OF if
}

/**
 * Helping function
 */
function getCampusName ($campusCode) {
  $campusName = '';
  switch (trim($campusCode)) {
    case 'AWC':
      $campusName = 'ASU@Yuma';
      break;
    case 'CALHC':
      $campusName = 'Lake Havasu City';
      break;
    case 'DTPHX':
      $campusName = 'Downtown Phoenix campus';
      break;
    case 'EAC':
      $campusName = 'ASU@TheGilaValley';
      break;
    case 'ONLNE':
      $campusName = 'ASU Online';
      break;
    case 'POLY':
      $campusName = 'Polytechnic campus';
      break;
    case 'TEMPE':
      $campusName = 'Tempe campus';
      break;
    case 'TUCSN':
      $campusName = 'ASU@Tucson';
      break;
    case 'WEST':
      $campusName = 'West campus';
      break;
    case 'CAC':
      $campusName = 'ASU@Pinal';
      break;
    case 'COCHS':  //Added by Archana 06/18
      $campusName = 'ASU@Cochise';
      break;
    case 'YAVAP':
      $campusName = 'ASU@Yavapai';
      break;
    case 'PIMA':
      $campusName = 'ASU@Pima';
      break;
    case 'WASHD':
      $campusName = 'ASU@Washington, D.C.';
      break;
    case 'MXCTY':
      $campusName = 'ASU@MexicoCity';
      break;
    case 'NEAZ':
      $campusName = 'ASU@NortheasternArizona';
      break;
    case 'LOSAN':
      $campusName = 'ASU Local@Los Angeles';
      break;
  } // END OF switch
  return $campusName;
}

/**
 * Helping function
 *
 * Sort campus in campus dropdown.
 */
function asuCampusSort ($campusoptions) {
  asort($campusoptions);

  // Bring ASU@XXX at the bottom
  // Also, move Lake Havasu City and ASU Online to the bottom
  if(array_key_exists('CALHC', $campusoptions) ) { // Lake Havasu City
    $v = $campusoptions['CALHC'];
    unset($campusoptions['CALHC']);
    $campusoptions['CALHC'] = $v;
  }
  if(array_key_exists('LOSAN', $campusoptions) ) { // ASU Local@Los Angeles
    $v = $campusoptions['LOSAN'];
    unset($campusoptions['LOSAN']);
    $campusoptions['LOSAN'] = $v;
  }
  if(array_key_exists('COCHS', $campusoptions) ) { // ASU@Cochise
    $v = $campusoptions['COCHS'];
    unset($campusoptions['COCHS']);
    $campusoptions['COCHS'] = $v;
  }
  if(array_key_exists('MXCTY', $campusoptions) ) { // ASU@MexicoCity
    $v = $campusoptions['MXCTY'];
    unset($campusoptions['MXCTY']);
    $campusoptions['MXCTY'] = $v;
  }
  if(array_key_exists('NEAZ', $campusoptions) ) { // ASU@Northeastern Arizona
    $v = $campusoptions['NEAZ'];
    unset($campusoptions['NEAZ']);
    $campusoptions['NEAZ'] = $v;
  }
  if(array_key_exists('PIMA', $campusoptions) ) {
    $v = $campusoptions['PIMA'];
    unset($campusoptions['PIMA']);
    $campusoptions['PIMA'] = $v;
  }
  if(array_key_exists('CAC', $campusoptions) ) { // ASU@Pinal
    $v = $campusoptions['CAC'];
    unset($campusoptions['CAC']);
    $campusoptions['CAC'] = $v;
  }
  if(array_key_exists('EAC', $campusoptions) ) { // ASU@TheGilaValley
    $v = $campusoptions['EAC'];
    unset($campusoptions['EAC']);
    $campusoptions['EAC'] = $v;
  }
  if(array_key_exists('TUCSN', $campusoptions) ) {
    $v = $campusoptions['TUCSN'];
    unset($campusoptions['TUCSN']);
    $campusoptions['TUCSN'] = $v;
  }
  if(array_key_exists('WASHD', $campusoptions) ) { // ASU@Washington, D.C.
    $v = $campusoptions['WASHD'];
    unset($campusoptions['WASHD']);
    $campusoptions['WASHD'] = $v;
  }
  if(array_key_exists('YAVAP', $campusoptions) ) { // ASU@Yavapai
    $v = $campusoptions['YAVAP'];
    unset($campusoptions['YAVAP']);
    $campusoptions['YAVAP'] = $v;
  }
  if(array_key_exists('AWC', $campusoptions) ) { // ASU@Yuma
    $v = $campusoptions['AWC'];
    unset($campusoptions['AWC']);
    $campusoptions['AWC'] = $v;
  }
  return $campusoptions;
}

