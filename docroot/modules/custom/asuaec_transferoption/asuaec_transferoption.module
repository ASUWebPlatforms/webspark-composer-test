/**
 * Section 1. Insert the Transfer Option degrees into 3 tables:
 * - asu_transferoption_main
 * - asu_transferoption_agreement
 * - asu_transferoption_keyword <-- Used for Keyword autocomplete
 *
 * Section 2. Delete Degree detail page nodes that were generated with URL of /bachelors-degrees/majorinfo/LAENGNBA/undergrad/false/2095.
 *      Nid 2095 is the Degree listing page node that was created for generating nodes for Transfer Option detail page.
 *
 * @param $context
 */
function asuaec_transferoption_data_insert(&$context) {
  $degree_errored_array = array();
  $file_contents = _asuaec_transferoption_get_degrees_from_webservice();

  // ---------------------------Section 1---------------------------------------
  // DB inserts

  // Truncate table before inserting data
  $database = \Drupal::database(); //<--- This worked!!!
  $database->truncate('asu_transferoption_main')->execute(); //Empty the table content before refreshing the table with new data
  $database->truncate('asu_transferoption_agreement')->execute(); //Empty the table content before refreshing the table with new data
  $database->truncate('asu_transferoption_keyword')->execute(); //Empty the table content before refreshing the table with new data

  foreach($file_contents as $programs => $thearray) {
    foreach($thearray as $key2 => $theobj) {

      $data = array();

      // Campuses
      $campuses_array = $theobj->CampusStringArray;
      if (sizeof($campuses_array) > 1) {
        $campuses_string = implode(", ", $campuses_array);
      } else if (sizeof($campuses_array) == 1) {
        $campuses_string = $campuses_array[0];
      } else {
        $campuses_string = '';
      }

      // Categories
      $categories_array = $theobj->planCatDescr;
      if (sizeof($categories_array) > 1) {
        $categories_string = implode("| ", $categories_array);
      } else if (sizeof($categories_array) == 1) {
        $categories_string = $categories_array[0];
      } else {
        $categories_string = '';
      }

      // keywords
      $keywords_array = $theobj->keywords;
      if (sizeof($keywords_array) > 1) {
        $keywords_string = implode("| ", $keywords_array);
      } else if (sizeof($keywords_array) == 1) {
        $keywords_string = $keywords_array[0];
      } else {
        $keywords_string = '';
      }

      // directMatchKeywords
      $directMatchKeywords_array = $theobj->directMatchKeywords;
      if (sizeof($directMatchKeywords_array) > 1) {
        $directMatchKeywords_string = implode("| ", $directMatchKeywords_array);
      } else if (sizeof($directMatchKeywords_array) == 1) {
        $directMatchKeywords_string = $directMatchKeywords_array[0];
      } else {
        $directMatchKeywords_string = '';
      }

      // keyword combined
      $keywordsCombined = '';
      if ($keywords_string != '' && $directMatchKeywords_string != '') {
        $keywordsCombined = $keywords_string . '| ' . $directMatchKeywords_string;
      } else if ($keywords_string == '' && $directMatchKeywords_string != '') {
        $keywordsCombined = $directMatchKeywords_string;
      } else if ($keywords_string != '' && $directMatchKeywords_string == '') {
        $keywordsCombined = $keywords_string;
      }

      $data['AcadPlan'] = $theobj->AcadPlan;

      // Transfer Agreement -- It is nested arrays.

      $transferAgreementInfo_array = $theobj->transferAgreementInfo; //<--- This is array.
//          \Drupal::logger('asuaec_transferoption')->notice("transferAgreementInfo_array:<pre>" . print_r($transferAgreementInfo_array, true) . "</pre>");

      if (sizeof($transferAgreementInfo_array) >= 1) {
//            \Drupal::logger('asuaec_transferoption')->notice("size of array:<pre>" . sizeof($transferAgreementInfo_array) . "</pre>");
//            \Drupal::logger('asuaec_transferoption')->notice("transferAgreementInfo_array:<pre>" . print_r($transferAgreementInfo_array, true) . "</pre>");

        $i = 0;
        foreach ($transferAgreementInfo_array as $key => $obj) {
//              \Drupal::logger('asuaec_transferoption')->notice("key:<pre>" . $key . "</pre>");
//              \Drupal::logger('asuaec_transferoption')->notice("obj:<pre>" . print_r($obj, true) . "</pre>");
          foreach ($obj as $key2 => $val) {
//                \Drupal::logger('asuaec_transferoption')->notice("key2:<pre>" . $key2 . "</pre>");
//                \Drupal::logger('asuaec_transferoption')->notice("val:<pre>" . print_r($val, true) . "</pre>");

            if($key2 == "tACommunityCollege") {
              $data['transferAgreementInfo'][$i]['tACommunityCollege'] = $val;
            }

            if($key2 == "transferAgreementType") {
              $data['transferAgreementInfo'][$i]['transferAgreementType'] = $val;
            }


            if($key2 == "transferAgreementYearsUrls") {
              $transferAgreementYearsUrls_array = $val; //<---This is array.
              foreach ($transferAgreementYearsUrls_array as $theArray) {
                $data['transferAgreementInfo'][$i]['transferAgreementYearsUrls'][$theArray[0]] = $theArray[1];
              }
            }
//                \Drupal::logger('asuaec_transferoption')->notice("Checking transferAgreementInfo:<pre>" . print_r($data['transferAgreementInfo'], true) . "</pre>");
          } // END OF  foreach ($obj as $key2 => $val)

          $i++;
        } // END OF foreach ($transferAgreementInfo_array as $key => $val)
      } // END OF if (sizeof($transferAgreementInfo_array) >= 1)

      // The rest
      $data['Descr100'] = isset($theobj->Descr100) ? $theobj->Descr100 : ''; // Degree name
      $data['Degree'] = isset($theobj->Degree) ? $theobj->Degree : '';
      $data['CollegeDescr100'] = isset($theobj->CollegeDescr100) ? $theobj->CollegeDescr100 : ''; // ex. Business, W. P. Carey School of
      $data['DiplomaDescr'] = isset($theobj->DiplomaDescr) ? $theobj->DiplomaDescr : ''; // ex. W. P. Carey School of Business
      $data['CollegeUrl'] = isset($theobj->CollegeUrl) ? $theobj->CollegeUrl : '';
      // Not used:
//          $data['AsuCareerOpp'] = isset($theobj->AsuCareerOpp) ? $theobj->AsuCareerOpp : '';
//          $data['DegreeDescrlong'] = isset($theobj->DegreeDescrlong) ? $theobj->DegreeDescrlong : '';
//          $data['AsuCritTrackUrl'] = isset($theobj->AsuCritTrackUrl) ? $theobj->AsuCritTrackUrl : '';
//          $data['majorMapDefaultYear'] = isset($theobj->majorMapDefaultYear) ? $theobj->majorMapDefaultYear : '';
//          $data['CollegeAcadOrg'] = isset($theobj->CollegeAcadOrg) ? $theobj->CollegeAcadOrg : ''; // CHI
//          $data['AcadProg'] = isset($theobj->AcadProg) ? $theobj->AcadProg : ''; // UGHI
//          $data['DepartmentCode'] = isset($theobj->DepartmentCode) ? $theobj->DepartmentCode : ''; // CPUBAFF
//          $data['accelerateDegrees'] = isset($theobj->accelerateDegrees) ? 1 : ''; // If the $theobj->accelerateDegrees object is not empty, return 1.
//          $data['concurrentDegrees'] = isset($theobj->concurrentDegrees) ? 1 : ''; // If the $theobj->concurrentDegrees object is not empty, return 1.
//          $data['CampusWueInfo'] = isset($theobj->CampusWueInfo) ? 1 : ''; // If the $theobj->CampusWueInfo object is not empty, return 1.
//          $data['AsuCustomText'] = isset($theobj->AsuCustomText) ? $theobj->AsuCustomText : '';
//          $data['AsuNactvAppOvrd'] = isset($theobj->AsuNactvAppOvrd) ? $theobj->AsuNactvAppOvrd : '';


      // Insert to database

      // Main table - asu_transferoption_main
      $dbentry_main = array(
        'AcadPlan' => $data['AcadPlan'],
        'Descr100' => $data['Descr100'],
        'Degree' => $data['Degree'],
        'CollegeDescr100' => $data['CollegeDescr100'],
        'DiplomaDescr' => $data['DiplomaDescr'],
        'CampusStringArray' => $campuses_string,
        'planCatDescr' => $categories_string,
        'keywords' => $keywords_string,
        'directMatchKeywords' => $directMatchKeywords_string,
        // Not used:
//            'AsuCareerOpp' => $data['AsuCareerOpp'],
//            'DegreeDescrlong' => $data['DegreeDescrlong'],
//            'AsuCritTrackUrl' => $data['AsuCritTrackUrl'],
//            'majorMapDefaultYear' => $data['majorMapDefaultYear'],
//            'CollegeAcadOrg' => $data['CollegeAcadOrg'], // CHI
//            'AcadProg' => $data['AcadProg'], // UGHI
//            'DepartmentCode' => $data['DepartmentCode'], // CPUBAFF
      );

      // Transfer agreement table - asu_transferoption_agreement
      $dbentry_agreement = array();
      if(isset($data['transferAgreementInfo'])) {
        foreach ($data['transferAgreementInfo'] as $transferAgreementInfo) {
          foreach ($transferAgreementInfo['transferAgreementYearsUrls'] as $year => $url) {
            $dbentry_agreement = array(
              'AcadPlan' => $data['AcadPlan'],
              'tACommunityCollege' => $transferAgreementInfo['tACommunityCollege'],
              'transferAgreementType' => $transferAgreementInfo['transferAgreementType'],
              'transferAgreementYearsUrlsYear' => $year,
              'transferAgreementYearsUrlsURL' => $url,
              'Descr100' => $data['Descr100'],
              'Degree' => $data['Degree'],
              'CollegeDescr100' => $data['CollegeDescr100'],
              'DiplomaDescr' => $data['DiplomaDescr'],
              'CollegeUrl' => $data['CollegeUrl'],
              'CampusStringArray' => $campuses_string,
              'planCatDescr' => $categories_string,
              'keywords' => $keywords_string,
              'directMatchKeywords' => $directMatchKeywords_string,
              'keywordsCombined' => $keywordsCombined,
            );

              // Insert to database
              try {
                $query2 = $database->insert('asu_transferoption_agreement')->fields($dbentry_agreement)->execute();
              } catch (Exception $e) {
                array_push($degree_errored_array, $data['AcadPlan']);
                \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
                continue;
              }


          } // END OF foreach ($transferAgreementInfo['transferAgreementYearsUrls'] as $year => $url)
//              \Drupal::logger('asuaec_transferoption')->notice("dbentry_agreement:<pre>" . print_r($dbentry_agreement, true) . "</pre>");


        } // END OF foreach ($data['transferAgreementInfo'] as $transferAgreementInfo)
      } // END OF if(isset($data['transferAgreementInfo']))

        // \Drupal::logger('asuaec_transferoption')->notice("dbentry:<pre>" . print_r($dbentry, true) . "</pre>");
      try {
          $query = $database->insert('asu_transferoption_main')->fields($dbentry_main)->execute();
      } catch (Exception $e) {
          array_push($degree_errored_array, $data['AcadPlan']);
          \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
          continue;
      }

      // Keyword table - asu_transferoption_keyword

      if (sizeof($keywords_array) > 1) {
        foreach($keywords_array as $keyword) {
          $dbentry_keyword = array();
          $dbentry_keyword = array(
            'keyword' => $keyword,
            'transferAgreementType' => $transferAgreementInfo['transferAgreementType'],
          );
          try {
            $query = $database->insert('asu_transferoption_keyword')->fields($dbentry_keyword)->execute();
          } catch (Exception $e) {
            array_push($degree_errored_array, $data['AcadPlan']);
            \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
            continue;
          }
        } // END OF foreach($keywords_array as $keyword)
      } // END OF if (sizeof($keywords_array) > 1)

      if (sizeof($directMatchKeywords_array) > 1) {
        foreach($directMatchKeywords_array as $keyword) {
          $dbentry_keyword = array();
          $dbentry_keyword = array(
            'keyword' => $keyword,
            'transferAgreementType' => $transferAgreementInfo['transferAgreementType'],
          );
          try {
            $query = $database->insert('asu_transferoption_keyword')->fields($dbentry_keyword)->execute();
          } catch (Exception $e) {
            array_push($degree_errored_array, $data['AcadPlan']);
            \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
            continue;
          }
        } // END OF if (sizeof($directMatchKeywords_array) > 1)
      } // END OF if (sizeof($directMatchKeywords_array) > 1)

    } // END OF foreach($thearray as $key2 => $theobj)
  } // END OF foreach($file_contents as $programs => $thearray)

  // ---------------------------END OF Section 1------------------------------------

  // ---------------------------Section 2------------------------------------
  // Delete Degree detail page nodes that were generated with URL of /bachelors-degrees/majorinfo/LAENGNBA/undergrad/false/2095.
  // Nid 2095 is the Degree listing page node that was created for generating nodes for Transfer Option detail page.

  // Get all nodes with degree_detail_page content type.
  //$nids = \Drupal::entityQuery('node')->condition('type','degree_detail_page')->execute();
  $nids = \Drupal::entityQuery('node')->accessCheck(FALSE)->condition('type','degree_detail_page')->execute();
  
  //  $nodes =  \Drupal\node\Entity\Node::loadMultiple($nids);

    // Why this is not working?
    $config = \Drupal::config('asuaec_transferoption.settings');
    $degreelistingpage_nid = $config->get('asuaec_transferoption_degreelistingpage_nid');
//    \Drupal::logger('asuaec_transferoption')->notice("degreelistingpage_nid3:<pre>" . $degreelistingpage_nid . "</pre>");
//  $degreelistingpage_nid = '2095';
  
  // Iterate degree_detail_page content type nodes.
  foreach ($nids as $nid) {
    $alias = \Drupal::service('path_alias.manager')->getAliasByPath('/node/' . $nid);

    // If node has alias with 2095 at the end, delete the node.
    if (preg_match('/(\/bachelors-degrees\/majorinfo\/)(\w+)(\/undergrad\/false\/' . $degreelistingpage_nid . ')/', $alias, $matches) == 1) {

      // Delete the node
      try {
        $node = \Drupal::entityTypeManager()->getStorage('node')->load($nid);  //$node = Node::load($nid); <---This is fine instead also.

        // Check if node exists with the given nid.
        if ($node) {
          $node->delete();
        }
      } catch (Exception $e) {
        \Drupal::logger('asuaec_transferoption')->error("Transferoption - Error while deleting Degree detail page nodes: " . $e->getMessage());
        continue;
      }

    } // END OF if (preg_match('/(\/bachelors-degrees\/majorinfo\/)(\w+)(\/undergrad\/false\/' . $degreelistingpage_nid . ')/', $alias, $matches) == 1)

  } // END OF foreach ($nids as $nid)

  // ---------------------------END OF Section 2------------------------------------

  $context['results']['degrees_errored_out'] = $degree_errored_array;

} // END OF function asuaec_transferoption_data_insert()

/**
 * Get degrees from web service using new method that returns Json.
 *
 * @return mixed|string
 *  Returns Json decoded object
 */
function _asuaec_transferoption_get_degrees_from_webservice() {
    $client = \Drupal::httpClient();
    $filter = '';
    $file_contents = '';
    try {
        $config = \Drupal::config('asuaec_transferoption.settings');
        $webservice_url = $config->get('asuaec_transferoption_url');
        // \Drupal::logger('asuaec_transferoption')->notice("webservice_url: <pre>" . $webservice_url . "</pre>");
        $url = $webservice_url . $filter;
        // \Drupal::logger('asuaec_transferoption2')->notice("url: <pre>" . $url . "</pre>");
        $request = $client->get($url);
        $code = $request->getStatusCode();
        if ($code == 200) {
            $content = $request->getBody()->getContents();
            if ($content != null) {
                $file_contents = json_decode($content);
            } else {
                throw new Exception("Web service didn't return anything.");
            }
        } else {
            throw new Exception("Error occured. Error code: " . $code);
        }
    }
    catch (Exception $e) {
        $messenger = \Drupal::messenger();
        $messenger->addMessage(t($e->getMessage(), []));
        \Drupal::logger('asuaec_transferoption')->error($e->getMessage());
    }
    return $file_contents;
}

/**
 * Batch 'finished' callback used by both batch 1, batch 2 and batch 3.
 */
function asuaec_transferoption_finished($success, $results, $operations) {
  $messenger = \Drupal::messenger();
    if ($success) {
      $errored_degrees = '';
      if((isset($results['degrees_errored_out']) && sizeof($results['degrees_errored_out']) > 0)) {
        $errored_degrees .= print_r($results['degrees_errored_out'], true);
        \Drupal::logger('asuaec_transferoption')->notice("degrees_errored_out:<pre>" . $errored_degrees . "</pre>");
        $messenger->addMessage(t('Degrees that had errored out during import: @degrees', ['@degrees' => $errored_degrees]), MessengerInterface::TYPE_ERROR);
      }
      else {
        $messenger->addMessage(t('All degrees were imported.', []));


      }
    }
    else {
        // An error occurred.
        // $operations contains the operations that remained unprocessed.
        $error_operation = reset($operations);
        $messenger->addMessage(
            t('An error occurred while processing @operation with arguments : @args',
                [
                    '@operation' => $error_operation[0],
                    '@args' => print_r($error_operation[0], TRUE),
                ]
            ),
          MessengerInterface::TYPE_ERROR
        );
    }
}



