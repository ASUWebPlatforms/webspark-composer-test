<?php

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\devel\Plugin\Devel\Dumper\Kint;

/**
 * Implements hook_theme().
 */
function custom_book_block_theme() {
    return array(
     'ws_custom_block' => array(
              'variables' => array('books' => array(), 'child' => array()),
          ),
    );
  }




/**
 * Implements hook_help().
 */
function custom_book_block_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.custom_book_block':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Custom views contextual filter Plugin') . '</p>';
      return $output;

    default:
  }
}

