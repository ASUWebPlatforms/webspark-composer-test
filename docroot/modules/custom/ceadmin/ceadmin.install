//CE_CrossLists
function ceadmin_crosslists_table(): array {
  return [
    'description' => 'Cross listed section information',
    'fields' => [
        'Xlist_Code' => ['type' => 'varchar', 'length' => 10, 'not null' => TRUE, 'default' => ''],
        'Orig_SLN' => ['type' => 'varchar', 'length' => 10, 'not null' => TRUE, 'default' => ''],
        'Crse_Dept' => ['type' => 'varchar', 'length' => 20, 'not null' => FALSE, 'default' => NULL],
        'section_Id' => ['type' => 'varchar', 'length' => 20, 'not null' => TRUE, 'default' => ''],
        'period' => ['type' => 'varchar', 'length' => 50, 'not null' => TRUE, 'default' => ''],
    ],
    'primary key' => ['section_Id'],
    'indexes' => [
      'period' => ['period'],
      'Crse_Dept' => ['Crse_Dept'],
      'page_path' => ['page_path'],
    ]
  ];
}

