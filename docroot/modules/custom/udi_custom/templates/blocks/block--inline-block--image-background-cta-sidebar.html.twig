{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'image-background-cta-sidebar--block',
] %}

{% set image = file_url(content.field_media[0]['#media'].field_media_image.entity.uri.value) %}
<section class="image-background-cta-sidebar" style="background-size: cover; background-image: linear-gradient(rgba(25,25,25, .75), rgba(25,25,25, .75)), url('{{ image }}');">
  <div{{ attributes.addClass(classes) }}>
    {{ title_prefix }}
    {% if label %}
      {% block label %}
        <h2{{ title_attributes }}>{{ label }}</h2>
      {% endblock %}
    {% endif %}
    {{ title_suffix }}
    {% block content %}

        <div class="image-background-cta-sidebar--block--container d-flex flex-column flex-md-row align-items-center justify-content-between">
          <div class="cta-primary-content col col-sm-12 col-md-6">    
            <div class="cta-headline">{{ content.field_heading_alt_lg }}</div>
            <div class="cta-body">{{ content.field_body }}</div>
            <div class="cta-action">{{ content.field_cta }}</div>
          </div>
          <div class="cta-sidebar-content col col-sm-12 col-md-4 justify-content-center">  
            <div class="cta-body">{{ content.field_side_content }}</div>
          </div>
        </div>

    {% endblock %}
  </div>
</section>
