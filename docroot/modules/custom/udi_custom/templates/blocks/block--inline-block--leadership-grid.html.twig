{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'block-leadership-grid',
  'mb-4',
  'pb-2',
] %}

<section{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    {% if content.field_body %}<div class="block-leadership-grid--intro">{{ content.field_body }}</div>{% endif %}
    <div class="block-leadership-grid--items d-flex flex-wrap flex-column flex-sm-row align-items-start my-5">
      {{ content.field_team_member }}
    </div>
  {% endblock %}
</section>

