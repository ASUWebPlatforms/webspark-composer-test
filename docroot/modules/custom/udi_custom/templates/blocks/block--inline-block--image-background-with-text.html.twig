{#
/**
 * @file
 * Template for a block.
 */
#}

{% set visibility = content.field_display_status|render|trim|striptags %}

{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'image-background-with-text',
] %}

{% set image = file_url(content.field_media[0]['#media'].field_media_image.entity.uri.value) %}

  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}

{% block content %}
<div class="{{ visibility }}">
  <section{{ attributes.addClass(classes) }} style="background-size: cover; background-image: linear-gradient(rgba(25,25,25, .75), rgba(25,25,25, .75)), url('{{ image }}');">
      
  
    <div class="image-background-with-text--container uds-content-align d-flex flex-column">
      {% if content.field_heading %}
      <div class="item-headline">
        <h3 class="h2">{{ content.field_heading|render|striptags|trim }}</h3>
      </div>
      {% endif %}
      <div class="item-body">{{ content.field_body_format }}</div>
    </div>


  </section>
    </div>
    {% endblock %}