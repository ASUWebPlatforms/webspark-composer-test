{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'block-tabbed-content-icon',
] %}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}
  {# Desktop Render #}
  <div class="d-none d-sm-flex flex-row">

    {# Generate tab headings #}
    <nav class="udi-tabbed-panels col col-xs-12 col-sm-6" aria-label="tabbed panels">

      <div class="nav nav-tabs flex-column flex-sm-row justify-content-between" id="nav-tab" role="tablist"  data-scroll-position="0">
        {% for tab in uditabs %}
        {% set icon = file_url(tab.icon.field_media_svg_1.entity.uri.value) %}
          {% if loop.first %}
          <div class="nav-item col col-xs-12 col-sm-6 d-flex flex-column active" 
              id="nav-{{ tab.heading|replace({' ' : '-'})|lower }}-tab"
              data-bs-toggle="tab"
              href="#nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              data-bs-target="#nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              role="tab"
              aria-controls="nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              aria-selected="true"
              data-ga-event="link"
              data-ga-action="click"
              data-ga-name="onclick"
              data-ga-type="internal link"
              data-ga-section="{{ label }}"
              data-ga-region="main content"
              data-ga-text="{{ tab.heading }}">
              <div class="nav-item--content d-flex flex-row flex-sm-column mt-auto">
                <div class="item-icon"> {{ tab.icon }}</div>
                <div class="item-heading"> {{ tab.heading }}</div>
              </div>
              <a class="nav-item--link stretched-link"></a>
            </div>
          {% else %}
          <div class="nav-item d-flex flex-column col col-xs-12 col-sm-6"
              id="nav-{{ tab.heading|replace({' ' : '-'})|lower }}-tab"
              data-bs-toggle="tab"
              href="#nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              data-bs-target="#nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              role="tab"
              aria-controls="nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              aria-selected="false"
              data-ga-event="link"
              data-ga-action="click"
              data-ga-name="onclick"
              data-ga-type="internal link"
              data-ga-section="{{ label }}"
              data-ga-region="main content"
              data-ga-text="{{ tab.heading }}">
              <div class="nav-item--content d-flex flex-row flex-sm-column mt-auto">
                <div class="item-icon"> {{ tab.icon }}</div>
                <div class="item-heading"> {{ tab.heading }}</div>
              </div>
              <a class="nav-item--link stretched-link"></a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </nav>

    {# Generate tab content #}
    <div class="tab-content col col-xs-12 col-sm-6" id="nav-tabContent">
      {% for tab in uditabs %}

        {% if loop.first %}

          <div class="tab-pane fade{% if is_dark %} text-white{% endif %} show active"
              id="nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              role="tabpanel"
              aria-labelledby="nav-{{ tab.heading|replace({' ' : '-'})|lower }}-tab">
            <div class="tab-content--wrapper">
              <div class="tab--background">
                {{ tab.background }}
              </div>
              <div class="tab-pane--content d-flex flex-column">
                <div class="item-icon">
                  {{ tab.icon }}
                </div>
                <h3 class="item-heading">{{ tab.heading }}</h3>
                <div class="item-body">
                  {{ tab.copy}}
                </div>
              </div>
            </div>

          </div>
        {% else %}

          <div class="tab-pane fade{% if is_dark %} text-white{% endif %}"
              id="nav-{{ tab.heading|replace({' ' : '-'})|lower }}"
              role="tabpanel"
              aria-labelledby="nav-{{ tab.heading|replace({' ' : '-'})|lower }}-tab">
            <div class="tab-content--wrapper">
              <div class="tab--background">
                {{ tab.background }}
              </div>
              <div class="tab-pane--content d-flex flex-column ">
                <div class="item-icon">{{ tab.icon }}</div>
                <h3 class="item-heading">{{ tab.heading }}</h3>
                <div class="item-body">{{ tab.copy}}</div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {# Mobile Render #}

  <div class="d-flex flex-column d-sm-none accordion udi-accordion-panels col col-xs-12" id="accordionContent">

    {% for tab in uditabs %}
    {% set icon = file_url(tab.icon.field_media_svg_1.entity.uri.value) %}
    {% if loop.first %}
    <div class="accordion--item accordion-content flex-column flex-sm-row justify-content-between">
      <div class="collapse-item col col-xs-12 d-flex flex-column active" 
        id="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}-accordion"
        data-toggle="collapse"
        data-target="#collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        aria-controls="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        aria-expanded="true">
        <div class="collapse-item--content d-flex flex-row">
          <div class="item-icon">
            {{ tab.icon }}
          </div>
          <div class="item-heading">
            {{ tab.heading }}
          </div>
        </div>
        <a class="collapse-item--link stretched-link"></a>
      </div>

      <div class="collapse accordion-pane fade{% if is_dark %} text-white{% endif %} show"
        id="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        role="tabpanel"
        aria-labelledby="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}-accordion"
        data-parent="#accordionContent">
        
        <div class="tab-content--wrapper">
          <div class="tab--background">
            {{ tab.background }}
          </div>
          <div class="tab-pane--content d-flex flex-column">
            <!--<div class="item-icon">
              {{ tab.icon }}
            </div>-->
            <!--<h3 class="item-heading">{{ tab.heading }}</h3>-->
            <div class="item-body">
              {{ tab.copy}}
            </div>
          </div>
        </div>
      </div>
    </div>
    {% else %}
    <div class="accordion--item accordion-content flex-column flex-sm-row justify-content-between">
      <div class="collapse-item col col-xs-12 d-flex flex-column" 
        id="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}-accordion"
        data-toggle="collapse"
        data-target="#collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        aria-controls="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        aria-expanded="true">
        <div class="collapse-item--content d-flex flex-row">
          <div class="item-icon">
            {{ tab.icon }}
          </div>
          <div class="item-heading">
            {{ tab.heading }}
          </div>
        </div>
        <a class="collapse-item--link stretched-link"></a>
      </div>

      <div class="collapse accordion-pane fade{% if is_dark %} text-white{% endif %}"
        id="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}"
        role="tabpanel"
        aria-labelledby="collapse-{{ tab.heading|replace({' ' : '-'})|lower }}-accordion"
        data-parent="#accordionContent">
        
        <div class="tab-content--wrapper">
          <div class="tab--background">
            {{ tab.background }}
          </div>
          <div class="tab-pane--content d-flex flex-column">
            <!--<div class="item-icon">
              {{ tab.icon }}
            </div>-->
            <!--<h3 class="item-heading">{{ tab.heading }}</h3>-->
            <div class="item-body">
              {{ tab.copy}}
            </div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
    {% endfor %}
  </div>    

</div>

 {{ attach_library('renovation/tabbed-panels') }} 


  