{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
] %}

{% set accented = 'image-style--' ~ content.field_udi_image_accent|render|striptags|trim %}
{% set heading = content.field_heading|render|striptags|trim %}
{% set sub_heading = content.field_sub_heading|render|striptags|trim %}
{% set positionimage = content.field_content_position|render|striptags|trim %}
{% set image = content.field_media %}
{% set first_cta = content.field_two_cta[0] %}
{% set second_cta = content.field_two_cta[1] %}
{% set background_color = content.field_bg_color_content_sections[0]['#markup'] %}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}
  {{ content.field_anchor_menu_settings }}
  {{ content.field_tooltip }}
  {% block content %}
    {% if positionimage == 'left' %}

      <div class="uds-image-text-block-container udi-align--left">
        <div class="uds-image-text-block-image-container {{ accented }}">
          {{ image }}
        </div>
        <div class="uds-image-text-block-text-container {{ background_colors }}">
          <div class="uds-image-text-block-text-container--wrapper">
            <h3 class="h2">{{ heading }}</h3>
            <h4>{{ sub_heading }}</h4>
            {{ content.field_formatted_text }}
            <div class="row">
              <div class="col-12 col-md-6 py-1">
                {{ first_ctas }}
              </div>
              <div class="col-12 col-md-6 py-1">
                {{ second_ctas }}
              </div>
            </div>
          </div>
        </div> 
      </div>
    {% else %}
    <div class="uds-image-text-block-container udi-align--right">
      <div class="uds-image-text-block-text-container {{ background_colors }}">
        <div class="uds-image-text-block-text-container--wrapper">
          <h3 class="h2">{{ heading }}</h3>
          <h4>{{ sub_heading }}</h4>
          {{ content.field_formatted_text }}
          <div class="row">
            <div class="col-12 col-md-6 py-1">
              {{ first_cta }}
            </div>
            <div class="col-12 col-md-6 py-1">
              {{ second_cta }}
            </div>
          </div>
        </div>
      </div>

      <div class="uds-image-text-block-image-container {{ accented }}">
        {{ image }}
      </div>
    </div>
    {% endif %}
  {% endblock %}
</div>
