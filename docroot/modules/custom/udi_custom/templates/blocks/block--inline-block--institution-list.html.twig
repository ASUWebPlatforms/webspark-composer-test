{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'block-institution-list',
] %}

<section{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    <h3 class="text-center">{{ content.field_sub_heading }}</h3>
    <div class="block-institution-list--items d-flex flex-column flex-lg-row align-items-start mt-5">
      {{ content.field_institution }}
    </div>
  {% endblock %}
</section>

