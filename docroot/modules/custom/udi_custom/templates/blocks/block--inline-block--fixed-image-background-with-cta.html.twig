{#
/**
 * @file
 * Template for a block.
 */
#}
{% set classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'fixed-image-background-with-cta',
] %}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    {% block label %}
      <h2{{ title_attributes }}>{{ label }}</h2>
    {% endblock %}
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    <section class="container">
      <div class="fixed-image-background-with-cta--container uds-content-align d-flex flex-column flex-sm-row align-items-start align-items-sm-center">
        <div class="cta-headline">{{ content.field_heading_alt }}</div>
        <div class="cta-action">{{ content.field_cta }}</div>
      </div>
    </section>
  {% endblock %}
</div>

