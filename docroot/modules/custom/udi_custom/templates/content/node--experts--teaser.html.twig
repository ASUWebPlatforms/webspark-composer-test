{#
/**
 * @file
 * Template for a Node.
 */
#}
{%
  set classes = [
  'node',
  node.isPromoted() ? 'node--promoted',
  node.isSticky() ? 'node--sticky',
  not node.isPublished() ? 'node--unpublished',
  node.bundle|clean_class,
  node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
  'experts--teaser',
  'col',
  'col-xs-12',
  'col-sm-4',
]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_suffix }}
  {% block content %}

    <div class="experts--teaser--profile mx-1">
      {{ content.field_profile }}
    </div>
    {% if content.field_bio is not empty %}
    <div class="experts--teaser--bio mx-1 mt-1 mb-5">
        <p>{{ content.field_bio|render }}</p>
    </div>
    {% endif %}

    {% endblock %}
</article>