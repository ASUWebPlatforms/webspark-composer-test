{#
/**
 * @file
 * Template for a Node.
 */
#}
{%
  set classes = [
  'node',
  node.isPromoted() ? 'node--promoted',
  node.isSticky() ? 'node--sticky',
  not node.isPublished() ? 'node--unpublished',
  node.bundle|clean_class,
  node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
  'impact-story--featured',
  'd-flex',
  'flex-column',
  'flex-sm-row',
  'align-items-center',
]
%}

{% set image = file_url(content.field_image[0]['#media'].field_media_image.entity.uri.value) %}

<article{{ attributes.addClass(classes) }}>
  {{ title_suffix }}
  {% block content %}
    <div class="impact-story--featured--image col col-xs-12 col-sm-6">
      <img src="{{ image }}">
    </div>
    <div class="impact-story--featured--body col col-xs-12 col-sm-6">
      <h3>{{ label|render|striptags|trim }}</h3>
      <p>{{ content.body|render|striptags|trim }}</p>
    <div>
  {% endblock %}
</article>