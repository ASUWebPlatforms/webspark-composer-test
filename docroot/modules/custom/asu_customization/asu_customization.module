/**
 * Alter webform elements.
 *
 * @param array $element
 *   The webform element.
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 *   The current state of the form.
 * @param array $context
 *   An associative array containing the following key-value pairs:
 *   - form: The form structure to which elements is being attached.
 */


/** Implementation of hook_webform_options_alter to alter predefined webform options **/
function asu_customization_form_alter(&$form, FormStateInterface $form_state, $form_id){
	//$connection = \Drupal::database();
	$database = \Drupal::database();
	
	//code to validate user email after account creation
	if ($form_id === 'user_register_form') {
    	// Add custom validation
    	$form['#validate'][] = 'custom_user_email_validate';
  	}
	
	//code to change high school drop down list values in search views
	if($form_id == "views_exposed_form"){
		$nids = array();
		$view = $form_state->get('view');
		if ($view->id() == 'courses') {
			\Drupal::service('page_cache_kill_switch')->trigger();
			if($view->getDisplay()->display['id'] != "data_export_1"){
			
			//ksm($nids);
				$nid_query = $database->select("node", "n")
						->fields("n",['nid'])
						->condition("type","course_competency_new","=")
						->execute()
						->fetchAll();
				$field_name = 'field_high_school_value';
				$multiple = TRUE;
				foreach($nid_query as $nid_result){
						$nids[$nid_result->nid] = $nid_result->nid;
				}		

				foreach($nids as $key => $nid){

					$intnid = intval($nid);
					$query1 = $database->select('node__field_high_school', 'nfs')
						->fields('nfs',['field_high_school_value'])
						->condition('entity_id', $intnid, '=')
						->execute()
						->fetchAll();	


					foreach($query1 as $hsresults1){
						$nh1 = $hsresults1->field_high_school_value;
						//ksm($nh1);
						$hschoollist[$nh1] =  $nh1;

					}
				 }
				 $hs_view_list = array();
				 $hs_view_list = array_unique($hschoollist);
				 asort($hs_view_list);

				$form[$field_name] = array(
					'#type' => 'select2', // Converting to select list
					//'#options' => array(0 => t('<any>'), 20 => '*', 40 => '**', 60 => '***', 80 => '****', 100 => '*****'), // your options/array
					'#options' => $hs_view_list,	
					'#default_value' => 0,
					'#title' => t('High school'),
					'#multiple' => $multiple,
				  );
					return $form;
			}
		
		}
		
	} /*** End of exposed view form ***/
	
	//code to adjust high school drop in content type edit page based on state field value
	if($form_id == "node_course_competency_new_edit_form"){
		
		$node_state = $form['field_school_state']['widget']['#default_value'][0];
		$hs_names = array();
		if(!empty($node_state)){
			
			$query = $database->select('node__field_school_state', 'fss')
			->fields('fss',['entity_id'])
			->condition('field_school_state_value',$node_state,'=')
			->execute()
			->fetchAll();
			foreach($query as $results){
				$state_nids[] = $results->entity_id;

			}
			//ksm($state_nids);
			$hs_query = $database->select('node__field_high_school', 'fhs')
			->fields('fhs',['field_high_school_value'])
			->condition('entity_id',$state_nids,'IN')
			->execute()
			->fetchAll();
			foreach($hs_query as $hs_results){
				$hs_node_names[$hs_results->field_high_school_value] = $hs_results->field_high_school_value;

			}
			
			$query4 = $database->select('asu_course_hs_data','afs')
				->fields('afs',['hs_name'])
				->condition('hs_state_code',$node_state,'=')
				->execute()
				->fetchAll();
			foreach($query4 as $query_results4){
				$hs_table_names[$query_results4->hs_name] = $query_results4->hs_name;

			}
			$hs_all_names = $hs_node_names + $hs_table_names;
			$hs_names = array_unique($hs_all_names);
		}
		else{
			$hs_nid_query = $database->select("node", "n")
					->fields("n",['nid'])
					->condition("type","course_competency_new","=")
					->execute()
					->fetchAll();
			foreach($hs_nid_query as $hs_nid_result){
					$hsnids[$hs_nid_result->nid] = $hs_nid_result->nid;
			}
			foreach($hsnids as $hskey => $hsnid){
					
				$hsintnid = intval($hsnid);
				$hsquery1 = $database->select('node__field_high_school', 'nfs')
					->fields('nfs',['field_high_school_value'])
					->condition('entity_id', $hsintnid, '=')
					->execute()
					->fetchAll();	
			

				foreach($hsquery1 as $hs_results1){
					$hsnh1 = $hs_results1->field_high_school_value;
					//ksm($nh1);
					$hs_schoollist[$hsnh1] =  $hsnh1;

				}
			 }
			 $hs_names = array_unique($hs_schoollist);
		}
		
		
		if(!empty($hs_names)){
				asort($hs_names);
				//$hs_names = array('Hamilton' => 'hamilton');
				$form['field_high_school']['widget']['#options'] = $hs_names;
		}
		
	}
	
	//update dropdowns of HS, Distrcit from cntent type
	if($form_id == "webform_submission_course_competency_form_node_16_add_form"){
		//ksm($form);
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['#prefix'] = '<div id="course-us-hs-district">';
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['#suffix'] = '</div>';
		
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['district']['#validated'] = TRUE;
		
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['high_school_1']['#validated'] = TRUE;
		
		
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['us_high_school']['#validated'] = TRUE;
		
		
		/** add ajax functionality to dynamically update district drop down options based on selected state **/
	    $form['elements']['school_information']['please_enter_your_district_information']['state']['#ajax'] = [
		      'event' => 'change',
			  'callback' => 'updateDistrictDropDown',
			  'wrapper' => 'course-us-hs-district',
			  'disable-refocus' => true
			
	    ];
		
		return $form;
	}
}

/**
 * Custom validation callback.
 */
function custom_user_email_validate($form, FormStateInterface $form_state) {
  $email = $form_state->getValue('mail'); // Get the email input
  
  if (preg_match('/\.site$/i', $email)) {
    $form_state->setErrorByName('mail', t('Please enter valid email address'));
  }
}

/** funtion to fill up district dropdown **/
function updateDistrictDropDown(array $form, FormStateInterface $form_state){	
		$form_state->setRebuild(true);
		//ksm($form_state);
		$state_value = $form_state->getValue('state');
		//$hs_name = array('Hamilton high school'=>'Hamilton high school','Basis chandler'=>'Basis chandler');
		$dis_query = \Drupal::database();
		$dis_name = array();
		$hs_name = array();
		$hs_name_list = array();
		$dis_name_list = array();

		$st_query = $dis_query->select('node__field_school_state','fss')
			->fields('fss',['entity_id'])
			->condition('field_school_state_value',$state_value,'=')
			->execute()
			->fetchAll();

		foreach($st_query as $st_result){
			$st_nids[$st_result->entity_id] = $st_result->entity_id;
		}

		$query = $dis_query->select('node__field_district', 'achs')
			->fields('achs',['field_district_value'])
			->condition('entity_id',$st_nids,'IN')
			->execute()
			->fetchAll();

		foreach($query as $results){
			$dis_name[$results->field_district_value] = $results->field_district_value;
		}

		$hs_query = $dis_query->select('node__field_high_school', 'fhs')
			->fields('fhs',['field_high_school_value','entity_id'])
			->condition('entity_id',$st_nids,'IN')
			->execute()
			->fetchAll();
	
		foreach($hs_query as $hs_results){
			$hs_name_list[$hs_results->field_high_school_value] = $hs_results->field_high_school_value;
		}
		$hs_name = array_unique($hs_name_list);	
	    asort($hs_name);
		asort($dis_name);
		if(sizeof($dis_name) <= 1){
			$dis_name_list = array('Not listed' => 'Not listed');
			$dis_list = array_merge(array('' => 'Select district'), $dis_name_list);
		}
		else{
			$dis_name_list = $dis_name;
			$dis_list = array_merge(array('' => 'Select district','Not listed' => 'Not listed'), $dis_name_list);
		}
		//$dis_list = array_merge(array('Not listed' => 'Not listed'), $dis_name);
		//ksm(sizeof($dis_list));
		//$dis_list_array = array_merge(array('Not listed' => 'Not listed'), $dis_name);
		$hs_list = array_merge(array('' => 'Select high school','Not listed' => 'Not listed'), $hs_name);
	    //array_push($hs_name, array('None' => 'Select high school','Not listed' => 'Not listed'));
	
	    $form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['high_school_1']['#options'] = $hs_list;
	    $form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['district']['#options'] = $dis_list;
		$form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['us_high_school']['#options'] = $hs_list;
	    // ksm($form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']['high_school_1']);
		return $form['elements']['school_information']['please_enter_your_district_information']['us_district_hs_group']; 
  
}


