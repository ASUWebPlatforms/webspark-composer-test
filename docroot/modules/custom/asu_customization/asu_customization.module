//function dataAction($node){
function asu_customization_node_presave(NodeInterface $node) {
	//\Drupal::logger('$node')->notice('<pre>' . print_r($node, TRUE) . '</pre>');
    if ($node->bundle() == 'course_competency_new') {
		
		$id = $node->id();
		$temp_distrcit = !empty($node->get('field_temporary_district'))?$node->get('field_temporary_district')->value:''; 
		$temp_hs = !empty($node->get('field_temporary_high_school'))?$node->get('field_temporary_high_school')->value:''; 
		$temp_new_country = !empty($node->get('field_temporary_country'))?$node->get('field_temporary_country')->value:''; 
		if(!empty($temp_distrcit) || (!empty($temp_hs)) || (!empty($temp_new_country))){
			$temp_new_hs = array();
			$temp_new_hs[] = $node->get('field_temporary_high_school')->value; 
			$state_check = $node->get('field_school_state');
			$state = !empty($state_check) ? $node->field_school_state->value:'';
			$city_check = $node->get('field_school_city_import');
			$city = !empty($city_check) ? $node->get('field_school_city_import')->value:'';
			$hs_name_check = $node->get('field_high_school');
			$hs_name = !empty($hs_name_check) ? $node->get('field_high_school')->value:'';
			$district_check = $node->get('field_district');
			$district = !empty($district_check) ? $node->get('field_district')->value:'';
			$connection = \Drupal::database();
			$all_temp_hs = $node->get('field_temporary_high_school')->getValue();
			foreach($all_temp_hs as $temp_hs_value_each){
				$multi_temp_value[] = $temp_hs_value_each['value'];
		    }
				
			if(($node->original->field_needs_data_approval->value != $node->field_needs_data_approval->value) && ($node->original->field_needs_data_approval->value == "Yes")){
				//country changes
				if(!empty($temp_country)){
					$temp_country = $node->original->get('field_temporary_country')->getValue(); 
					$new_term = Term::create([
					  'vid' => 'Country',
					  'name' => $temp_new_country,
					]);
					$tid = $new_term->id();
					$new_term->enforceIsNew();
					$new_term->save();
					//$termId = \Drupal::entityQuery("taxonomy_term")->condition("vid", "vocab_name")->condition("Country", $temp_new_country)->execute();
					$node->set('field_choose_country',$tid);
					$node->set('field_temporary_country','');
				}
				
			   //High school update
				//ksm($temp_new_hs);
				//\Drupal::logger('$temp_new_hs')->notice('<pre>' . print_r($temp_new_hs, TRUE) . '</pre>');

				if(!empty($temp_new_hs)){
					$temp_changed_hs = $node->original->get('field_temporary_high_school')->getValue(); 
					//\Drupal::logger('$temp_changed_hs')->notice('<pre>' . print_r($temp_changed_hs, TRUE) . '</pre>');

					//ksm($temp_changed_hs);
					if($temp_changed_hs != $temp_hs){ //if there is change in the temporary school anme value, save it to asu_course_hs_data table
						
						if(!empty($state)){
							$st_query = $connection->select('asu_webform_fields_hs', 'awfh')
										->fields('awfh',['hs_state_code','hs_state_name'])
										->condition('hs_state_code',$state,'=')
										->execute()
										->fetchAll();
							foreach($st_query as $st_results){
									$state_name = $st_results->hs_state_name;

							}
						}
						else{
							$state_name = '';
						}

						foreach($multi_temp_value as $temp_hs_value){
							$un_id = $id.'-'.$temp_hs_value;
							//ksm($un_id);
							$check_nid = $connection->select('asu_course_hs_data', 'chd')
								->fields('chd',['hs_id'])
								//->condition('hs_id',$un_id,'=')
								->condition('hs_name',$temp_hs_value,'=')
								->condition('hs_state_code',$state,'=')
								->execute()
								->fetchAll();
							//ksm($check_nid);
							if (!$check_nid) {
								//insert temp high school value into asu in the node_course_hs_data table to be used for high school dropdown

								$data = $connection->insert('asu_course_hs_data')
								  ->fields(['hs_id', 'hs_state_code', 'hs_state_name', 'hs_city', 'hs_name', 'hs_district'])
								  ->values([
									'hs_id' => $un_id,
									'hs_state_code' => $state,
									'hs_state_name' => $state_name,
									'hs_city' => $city,
									'hs_name' => $temp_hs_value,
									'hs_district' => $district   

								  ])
								  ->execute();
							}
							else{
								//ksm($state_name);
								$data = $connection->update('asu_course_hs_data')
								  ->fields([
									'hs_id' => $un_id,
									'hs_state_code' => $state,
									'hs_state_name' => $state_name,
									'hs_city' => $city,
									'hs_name' => $temp_hs_value,
									'hs_district' => $district   
								  ])
								  ->condition('hs_id',$un_id,'=')		
								  ->execute();
							}
						}
					}
					
						//insert temp high school value into high school field
						$already_hs = array();
						$all_hs = array();
						$already_hs = !empty($node->get('field_high_school'))?$node->get('field_high_school')->getValue():'';
						//$all_hs = array_merge($already_hs,$temp_new_hs);
						$all_hs = array_merge($already_hs,$multi_temp_value);
						$node->set('field_high_school',$all_hs);
						$node->set('field_temporary_high_school','');
						$node_status = 1;
						$node->set('status',$node_status);
						
					//}	
						
					
					
				}
				if(!empty($temp_distrcit)){
					if(($temp_distrcit != $temp_original_distrcit)){
						$temp_original_distrcit = $node->original->get('field_temporary_district')->getValue(); 
						$node->set('field_district',$temp_original_distrcit);
						$node->set('field_temporary_district','');

					}
				}
				
			} 
		}
		
	}
	
}



function asu_customization_state(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
    $database = \Drupal::database();
	$state_list = array();
   
	$query = $database->select('asu_webform_fields_hs', 'wfh')
		->fields('wfh',['hs_state_code','hs_state_name'])
		->execute()
		->fetchAll();
	
    foreach($query as $results){
		 $state_list[$results->hs_state_code] = $results->hs_state_name;
		
    }
   
	 //$district_list = array_merge(array('All' => '- Any -'), $district_list);
	asort($state_list);
    return array_unique($state_list);
}

function asu_customization_city(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
    $database = \Drupal::database();
	$city_list = array();
	$city_list2 = array();
    $query = $database->select('asu_course_hs_data', 'awfh')
		->fields('awfh',['hs_city'])
		->execute()
		->fetchAll();
	
	$query2 =  $database->select('node__field_school_city_import','nfsc')
		->fields('nfsc',['field_school_city_import_value'])
		->execute()
		->fetchAll();
	
    foreach($query as $results){
		 $city_list[$results->hs_city] = $results->hs_city;
		
    }
	
	foreach($query2 as $cityresults2){
		$city_list2[$cityresults2->field_school_city_import_value] =  $cityresults2->field_school_city_import_value;
		
	}
   
	$all_city_list = $city_list+$city_list2;
	//$all_city_list = $city_list;
	asort($all_city_list);
	 //$district_list = array_merge(array('All' => '- Any -'), $district_list);
	// $all_city_list = array('Chandler' => 'Chandler');
    return array_unique($all_city_list);
}

function asu_customization_hs(FieldStorageConfig $definition, ContentEntityInterface $entity = NULL, $cacheable) {
    $database = \Drupal::database();
   /* $query1 = $database->select('node__field_high_school_import', 'nfs')
		->fields('nfs',['field_high_school_import_value'])
		->execute()
		->fetchAll();*/
		
	
	$query3 = $database->select('node__field_high_school', 'nhs')
		->fields('nhs',['field_high_school_value'])
		->execute()
		->fetchAll();
	
	$query4 = $database->select('asu_course_hs_data','afs')
		->fields('afs',['hs_name'])
		->execute()
		->fetchAll();
	
		
		
	$hslist1 = array();
	$hslist2 = array();
	$hslist3 = array();
	
   /* foreach($query1 as $hsresults1){
        $nh1 = $hsresults1->field_high_school_import_value;
		$hslist1[$nh1] =  $nh1;
		
	}*/
	
	foreach($query3 as $hsresults3){
		$nh3 = $hsresults3->field_high_school_value;
		$hslist3[$nh3] =  $nh3;
		
	}
	
    foreach($query4 as $hsresults4){
		$nh4 = $hsresults4->hs_name;
		$hslist4[$nh4] =  $nh4;
		
	};
		
	//$hs_list = $hslist1+$hslist2+$hslist3+$hslist4;
	$hs_list = $hslist3+$hslist4;
	asort($hs_list);
    return array_unique($hs_list);
}


/**
 * Implements hook_mail() to send confirmation email.
 */
function asu_customization_mail($key, &$message, $params) {
    $options = array(
        'langcode' => $message['langcode'],
    );
    switch ($key) {
        case 'send_course_email':
            //$message['from'] = \Drupal::config('system.site')->get('mail');
			$message['from'] = "courseapproval@asu.edu";
            $message['subject'] = t('@subject', ['@subject' => $params['subject']], $options);
            $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed; delsp=yes'; // Needed this to display images.
            $message['body'][] = $params['message'];
			$message['reply-to'] = "courseapproval@asu.edu";
            break;
    }
}