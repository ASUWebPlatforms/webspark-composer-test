function asu_customization_node_update(Node $node) {
	if ($node->bundle() == 'course_competency_new') {
	 	$title = $node->getTitle();
		$name = $node->get('field_first_name')->value;
		$email = $node->get('field_e_mail')->value;
		//approved field change
		$approve_initial_value = $node->original->get('field_approved_field')->value;
		$approve_updated_value = $node->get('field_approved_field')->value;
		if(($approve_updated_value != $approve_initial_value)){
			  if(($approve_updated_value == "Yes")){
				  $terms = $node->get('field_course_code_0')->referencedEntities();
				  foreach ($terms as $grant_type) {
					  $labels = $grant_type->label();
				  }
		      	  $decision = "approved";
				  sendContentUpdateEmail($node, $title, $name, $labels, $decision, $email);
				}
		}
		else{
			
		}
		//denied field change
		$denid_initial_value = $node->original->get('field_denied')->value;
		$denied_updated_value = $node->get('field_denied')->value;
		if(($denied_updated_value != $denid_initial_value) && $denied_updated_value == "Yes"){
			$decision = "denied";
			sendContentUpdateEmail($node, $title, $name, $labels, $decision, $email);
		}
		
		//deferred value
		$deferred_initial_value = $node->original->get('field_deferred')->value;
		$deferred_updated_value = $node->get('field_deferred')->value;
		//ksm($deferred_updated_value);
		//ksm($deferred_initial_value);
		if(($deferred_updated_value != $deferred_initial_value) && $deferred_updated_value == "Yes"){
			$decision = "deferred";
			sendContentUpdateEmail($node, $title, $name, $labels, $decision, $email);
		}
		
		//committee value
		$committee_initial_value = $node->original->get('field_committee_review')->value;
		$committee_updated_value = $node->get('field_committee_review')->value;
		//ksm($committee_initial_value);
		//ksm($committee_updated_value);
		if(($committee_updated_value != $committee_initial_value) && $committee_updated_value == "Yes"){
			$decision = "committee";
			sendContentUpdateEmail($node, $title, $name, $labels, $decision, $email);
		}
    }
	
}

function sendContentUpdateEmail($node, $title, $first_name, $code_label, $decision, $email){
	
		$mailManager = \Drupal::service('plugin.manager.mail');
		$domain = $_SERVER['HTTP_HOST'];
		$site = "https://$domain";
		$nid = $node->id();
	    $node_link = "$site/node/$nid";
		$approved = array();
	    if($decision == "approved"){
			$subject = "$title has been approved";
			$approved_data = array();
			$terms = $node->get('field_course_code_0')->referencedEntities();
			foreach ($terms as $term) {
				$parent_data = \Drupal\taxonomy\Entity\Term::load($term->parent->target_id)->get('name')->value;
				$approved_data[$parent_data] = $term->getName();
			}
			foreach($approved_data as $key => $code){
				$approved[] = $key." > ".$code."<br />";
			}
			$approved_code = implode('', $approved);
			$content = "<p>$first_name</p><p>Thank you for submitting a course to <a href='https://courseapproval.asu.edu'>courseapproval.asu.edu</a>. Your course has been approved.</p>";
			$content .= "<p>Course name: <a href='$node_link'>$title</a> <br />";
			$content .= "Approved as: $approved_code</p>";
			$content .= "<p>We reserve the right to re-evaluate courses if we find the content of the current course description does not match the previously approved course</p>";
			$content .= "<p>If you have any questions, please email <a href='mailto:courseapproval@asu.edu'>courseapproval@asu.edu</a>.</p>"; 
			$content .= "<p>Arizona State University | Northern Arizona University | University of Arizona</p>";
			$to_email_address = $email;
		}
		if($decision == "denied"){
			$subject = "$title has been denied";
			$new_dec_reason = $node->get('field_denied_reason')->value;
			if(!empty($new_dec_reason)){
				$denied_reason = "Reason denied: $new_dec_reason</p>";
			}
			else{
				$denied_reason = "</p>";
			}
			$content = "<p>$first_name</p><p>Thank you for submitting a course to <a href='https://courseapproval.asu.edu'>courseapproval.asu.edu</a>. Unfortunately, your course has been denied.</p>";
			$content .= "<p>Course name: <a href='$node_link'>$title</a> <br />";
			$content .= $denied_reason;
			$content .= "<p>If you have any questions, please email <a href='mailto:courseapproval@asu.edu'>courseapproval@asu.edu</a>.</p>"; 
			$content .= "<p>Arizona State University | Northern Arizona University | University of Arizona</p>";
			$to_email_address = $email;
		}
		if($decision == "deferred"){
			$subject = "$title has been deferred";
			$content = "<p>$first_name</p><p>Thank you for submitting a course to <a href='https://courseapproval.asu.edu'>courseapproval.asu.edu</a>. Your course has been deferred until we receive additional information.</p>";
			$content .= "<p>Course name: <a href='$node_link'>$title</a> <br />";
			$c_deferred_reason = $node->get('field_deferred_reason')->value;
			if(!empty($c_deferred_reason)){
				$deferred_reason = "Reason deferred: $c_deferred_reason</p>";
			}
			else{
				$deferred_reason = "</p>";
			}
			$content .= $deferred_reason;
			$content .= "<p>If you have additional information on the course that should be considered, please <a href='https://courseapproval.asu.edu/submit-course'>re-submit</a> the course to the Course Approval website with the additional information included in the new submission. For questions, please email <a href='mailto:courseapproval@asu.edu'>courseapproval@asu.edu</a>.</p>"; 
			$content .= "<p>Arizona State University | Northern Arizona University | University of Arizona</p>";
			$to_email_address = $email;

		}
		if($decision == "committee"){
			
			$subject = "$title is under committee review";
			$content = "<p>$first_name</p><p>Thank you for submitting a course to <a href='https://courseapproval.asu.edu'>courseapproval.asu.edu</a>. Your course is currently under committee review.</p>";
			$content .= "<p>Course name: <a href='$node_link'>$title</a></p>";
			$content .= "<p>Arizona State University, Northern Arizona University and University of Arizona committee members are reviewing your course. Please allow an additional two to four weeks for the committee to review the course.</p>";
			$content .= "<p>If you have any questions, please email <a href='mailto:courseapproval@asu.edu'>courseapproval@asu.edu</a>.</p>";
			$content .= "<p>Arizona State University | Northern Arizona University | University of Arizona</p>";
			$to_email_address = $email;
			sendCommitteeEmailToAdmins($node_link, $title);
		}
		
		//ksm($content);
		 $module = 'asu_customization';
		 $key = 'send_course_email';
		 //$to_email_address = "avannela@gmail.com";
		 $params['message'] = $content;
		 $params['subject'] = $subject;
	     $params['from_address'] = "courseapproval@asu.edu";
		 $langcode = \Drupal::currentUser()->getPreferredLangcode();
		 $send = true;
	  	 $result = $mailManager->mail($module, $key, $email, $langcode, $params, NULL, $send);
	     //ksm($result);
}


function sendCommitteeEmailToAdmins($node_link,$title){
	$mailManager = \Drupal::service('plugin.manager.mail');
	$content = "<p>A new course has been submitted to <a href='https://courseapproval.ws.asu.edu'>courseapproval.asu.edu</a> is now in committee review.</p>";
	$config = \Drupal::config('asu_customization.admin_settings');
	$admin_email = $config->get('admin_email_ids');
	 
	//$admin_email = "avannela@gmail.com";
	$content .=  "<p>Course name: <a href='$node_link'>$title</a></p>";
	$content  .= "<p>Please review this course within two to four weeks.</p>";
	$module = 'asu_customization';
	$key = 'send_course_email';
	$to_email_address = $admin_email;
	$params['message'] = $content;
	$params['subject'] = "$title course is in committee review";
	$params['from_address'] = "courseapproval@asu.edu";
	$langcode = \Drupal::currentUser()->getPreferredLangcode();
	$send = true;
	$result = $mailManager->mail($module, $key, $to_email_address, $langcode, $params, NULL, $send);
}

