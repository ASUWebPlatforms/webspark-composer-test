/**
 * Automatically set the proper Group.
 *
 * @param $form
 *
 * @return void
 */
function setGroupContentRelationship(&$form): void
{
  $route_name = Drupal::routeMatch()->getRouteName();
  if ($route_name == 'entity.group_relationship.create_form') {
    $group_id = Drupal::routeMatch()->getParameter('group');
    $form['field_group']['widget'][0]['target_id']['#default_value'] = $group_id;

    // Hide the field so the user cannot change it, regardless of permissions.
    // Admins and BI Team members can change a group's content relationship, however
    // this is not the location to do so.
    $form['field_group']['#access'] = false;
  }
}
